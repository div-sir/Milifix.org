---
import WorkSlugPage from '../../../components/pages/WorkSlugPage.astro';
import { getWorks } from '../../../lib/cms';

export async function getStaticPaths() {
  const works = await getWorks();
  return works.map((work) => ({
    params: { space: work.space, slug: work.slug },
    props: { work },
  }));
}
---

<WorkSlugPage lang="ja" work={Astro.props.work} spaceParam={Astro.params.space} />
