---
import { getCollection } from 'astro:content';
import WorkSlugPage from '../../../components/pages/WorkSlugPage.astro';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((entry) => ({
    params: { space: entry.data.space, slug: entry.id },
    props: { entry },
  }));
}
---

<WorkSlugPage lang="ja" entry={Astro.props.entry} spaceParam={Astro.params.space} />
