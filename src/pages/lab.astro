---
import AmbientBackdrop from '../components/AmbientBackdrop.astro';
import PortfolioChrome from '../components/PortfolioChrome.astro';
import Quote from '../components/Quote.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PillGroup from '../components/PillGroup.astro';
import FigureFrame from '../components/FigureFrame.astro';
import SectionBreak from '../components/SectionBreak.astro';
import MetricHighlight from '../components/MetricHighlight.astro';
import GlowCta from '../components/GlowCta.astro';
import StepTrail from '../components/StepTrail.astro';
import TerminalBlock from '../components/TerminalBlock.astro';
import MarqueeTags from '../components/MarqueeTags.astro';
import GlassCard from '../components/GlassCard.astro';
import '../styles/theme.css';
import '../styles/portfolio-atmosphere.css';

const navItems = [
  { id: 'proj-narrative', label: '敘事與引用' },
  { id: 'proj-labels', label: '標籤與層級' },
  { id: 'proj-data', label: '資料與流程' },
  { id: 'proj-media', label: '媒體框' },
  { id: 'proj-motion', label: '動態帶' },
  { id: 'proj-tech', label: '技術質感' },
] as const;

const labPathname = Astro.url.pathname;
const labDockSections = navItems.map((item) => ({ id: item.id, label: item.label }));
---

<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>元件實驗室 · 分項預覽</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('portfolio-theme');
          document.documentElement.dataset.theme =
            t === 'light' ? 'light' : t === 'dark' ? 'dark' : window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --mono: 'Space Mono', monospace;
        --sans: 'Space Grotesk', sans-serif;
      }
      html {
        scroll-behavior: smooth;
      }
      body.lab-page {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        cursor: auto;
        min-height: 100vh;
      }
      body.lab-page::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 1;
        opacity: 0.45;
      }
      .lab-top {
        position: sticky;
        top: 0;
        z-index: 30;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--line2);
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: blur(12px);
      }
      .lab-top a,
      .lab-top button {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        background: none;
        border: 1px solid var(--line2);
        padding: 10px 16px;
        border-radius: 8px;
        cursor: pointer;
        transition:
          border-color 0.2s,
          background 0.2s;
      }
      .lab-top a:hover,
      .lab-top button:hover {
        border-color: color-mix(in srgb, var(--accent) 40%, var(--line2));
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }
      .lab-layout {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 32px;
        max-width: 1080px;
        margin: 0 auto;
        padding: 36px 20px 120px;
      }
      @media (min-width: 900px) {
        .lab-layout {
          grid-template-columns: 200px minmax(0, 1fr);
          gap: 48px;
          padding: 48px 32px 120px;
        }
      }
      .lab-nav {
        position: sticky;
        top: 76px;
        align-self: start;
      }
      .lab-nav__title {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted-dim);
        margin-bottom: 16px;
      }
      .lab-nav ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .lab-nav a {
        display: block;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid transparent;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
        transition:
          color 0.15s,
          border-color 0.15s,
          background 0.15s;
      }
      .lab-nav a:hover,
      .lab-nav a:focus-visible {
        color: var(--accent);
        border-color: var(--line2);
        background: color-mix(in srgb, var(--accent) 6%, transparent);
        outline: none;
      }
      @media (max-width: 899px) {
        .lab-nav {
          position: relative;
          top: 0;
        }
        .lab-nav ul {
          flex-direction: row;
          flex-wrap: wrap;
        }
        .lab-nav a {
          padding: 8px 12px;
        }
      }
      .lab-panels {
        min-width: 0;
      }
      .lab-project {
        margin-bottom: 80px;
        scroll-margin-top: 88px;
      }
      .lab-project__head {
        margin-bottom: 28px;
      }
      .lab-project__id {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--accent);
        opacity: 0.85;
        margin-bottom: 8px;
      }
      .lab-project__title {
        font-size: clamp(1.35rem, 3vw, 1.65rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.25;
      }
      .lab-project__desc {
        margin-top: 12px;
        font-size: 14px;
        line-height: 1.65;
        color: var(--muted);
        max-width: 56ch;
      }
      .lab-stack {
        display: flex;
        flex-direction: column;
        gap: 28px;
      }
      .lab-row {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: flex-start;
      }
      .lab-placeholder {
        width: 100%;
        height: 100%;
        min-height: 160px;
        background:
          radial-gradient(ellipse 80% 60% at 30% 40%, color-mix(in srgb, var(--accent) 25%, transparent), transparent),
          linear-gradient(145deg, var(--bg3), var(--bg2));
      }
      .lab-prose {
        font-size: 14px;
        line-height: 1.7;
        color: var(--muted);
        max-width: 54ch;
      }
    </style>
  </head>
  <body class="lab-page portfolio-atmo">
    <AmbientBackdrop />
    <PortfolioChrome lang="zh" pathname={labPathname} dockSections={labDockSections} />
    <header class="lab-top">
      <a href="/">← Milifix 首頁</a>
      <button type="button" id="lab-theme-toggle" aria-label="切換深淺色">Theme</button>
    </header>
    <div class="lab-layout">
      <nav class="lab-nav" aria-label="實驗室分項">
        <p class="lab-nav__title">項目導覽</p>
        <ul>
          {
            navItems.map((item) => (
              <li>
                <a href={`#${item.id}`}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="lab-panels">
        <section class="lab-project" id="proj-narrative" aria-labelledby="t-narrative">
          <header class="lab-project__head">
            <p class="lab-project__id">01</p>
            <h1 class="lab-project__title" id="t-narrative">敘事與引用</h1>
            <p class="lab-project__desc">
              長篇脈絡中的引用區塊：帶狀、內聯、拉页摘句。此區元件已用在作品集內容頁，樣式與站內一致。
            </p>
          </header>
          <div class="lab-stack">
            <Quote
              variant="band"
              text="設計不是裝飾，而是讓意圖在混亂裡仍能被人看見的方式。"
              attribution="Studio note"
            />
            <Quote
              variant="inline"
              text="較短的內聯引用，適合夹在段落之間，不搶走主敘事的節奏。"
              attribution="Inline"
            />
            <Quote
              variant="pull"
              label="Pull quote"
              text="把一句話放大，讓讀者在滑動時仍能記住核心訊息。"
              attribution="Editorial"
            />
          </div>
        </section>

        <section class="lab-project" id="proj-labels" aria-labelledby="t-labels">
          <header class="lab-project__head">
            <p class="lab-project__id">02</p>
            <h2 class="lab-project__title" id="t-labels">標籤與層級</h2>
            <p class="lab-project__desc">區塊小標、技術標籤列、段落分隔線。尚未接入主流程，僅於實驗室預覽。</p>
          </header>
          <div class="lab-stack">
            <Eyebrow text="Section kicker" />
            <p class="lab-prose">Eyebrow 放在主標題上方，建立視覺層級與編輯節奏。</p>
            <Eyebrow text="No line" line={false} />
            <SectionBreak label="Segment" />
            <PillGroup items={['Astro', 'TypeScript', 'Motion', 'Content', 'Static', 'i18n']} />
          </div>
        </section>

        <section class="lab-project" id="proj-data" aria-labelledby="t-data">
          <header class="lab-project__head">
            <p class="lab-project__id">03</p>
            <h2 class="lab-project__title" id="t-data">資料與流程</h2>
            <p class="lab-project__desc">數字亮點與步驟軌跡，適合案例頁、後台示意或 Onboarding 說明。</p>
          </header>
          <div class="lab-stack">
            <div class="lab-row">
              <MetricHighlight value="36" label="Pages built" hint="Static routes" />
              <MetricHighlight value="3" label="Locales" hint="en / zh / ja" />
              <MetricHighlight value="∞" label="Iterations" hint="設計即迭代" />
            </div>
            <StepTrail
              steps={[
                { title: 'Brief', status: 'done' },
                { title: 'Structure', status: 'done' },
                { title: 'Motion', status: 'current' },
                { title: 'Ship', status: 'upcoming' },
              ]}
            />
            <GlowCta href="/" label="回到 Milifix" />
          </div>
        </section>

        <section class="lab-project" id="proj-media" aria-labelledby="t-media">
          <header class="lab-project__head">
            <p class="lab-project__id">04</p>
            <h2 class="lab-project__title" id="t-media">媒體框</h2>
            <p class="lab-project__desc">漸層邊框容器，slot 可替換為圖片、影片或互動內容。</p>
          </header>
          <div class="lab-stack">
            <FigureFrame caption="16:9 · placeholder">
              <div class="lab-placeholder"></div>
            </FigureFrame>
            <FigureFrame aspect="square" caption="1:1">
              <div class="lab-placeholder"></div>
            </FigureFrame>
          </div>
        </section>

        <section class="lab-project" id="proj-motion" aria-labelledby="t-motion">
          <header class="lab-project__head">
            <p class="lab-project__id">05</p>
            <h2 class="lab-project__title" id="t-motion">動態帶</h2>
            <p class="lab-project__desc">橫向無縫捲動標籤；若系統開啟「減少動態效果」會改為靜態換行。</p>
          </header>
          <MarqueeTags
            items={['Portfolio', 'Spatial', 'Typography', 'Grid', 'Motion', 'Light', 'Dark', 'Astro']}
            durationSec={32}
          />
        </section>

        <section class="lab-project" id="proj-tech" aria-labelledby="t-tech">
          <header class="lab-project__head">
            <p class="lab-project__id">06</p>
            <h2 class="lab-project__title" id="t-tech">技術質感</h2>
            <p class="lab-project__desc">毛玻璃卡片與終端機區塊，適合文件站、Changelog 或開發者向落地頁。</p>
          </header>
          <div class="lab-stack">
            <GlassCard subtitle="Frosted panel">
              <p class="lab-prose" style="margin: 0; color: var(--text)">
                內文放 slot：可放簡介、重點條列或 CTA。邊框為漸層描邊，內層含 backdrop-filter。
              </p>
            </GlassCard>
            <TerminalBlock
              title="portfolio — zsh"
              lines={[
                '$ astro build',
                '✓ 37 static pages',
                '✓ astro check passed',
                '',
                '$ git status',
                'On branch main — working tree clean',
              ]}
            />
          </div>
        </section>
      </div>
    </div>
    <script>
      import { toggleTheme } from '../scripts/theme-init';
      import { initAnimeSplitText } from '../scripts/init-anime-splittext';

      document.getElementById('lab-theme-toggle')?.addEventListener('click', (e) => toggleTheme(e));
      initAnimeSplitText();
    </script>
  </body>
</html>
