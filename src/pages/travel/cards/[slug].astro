---
import CardSlugPage from '../../../components/pages/CardSlugPage.astro';
import { getCreditCards } from '../../../lib/cms';

export async function getStaticPaths() {
  const cards = await getCreditCards();
  return cards.map((card) => ({
    params: { slug: card.slug },
    props: { card },
  }));
}
---

<CardSlugPage lang="en" card={Astro.props.card} />
