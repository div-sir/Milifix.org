---
import AirlineSlugPage from '../../../components/pages/AirlineSlugPage.astro';
import { getAirlines } from '../../../lib/cms';

export async function getStaticPaths() {
  const airlines = await getAirlines();
  return airlines.map((airline) => ({
    params: { slug: airline.slug },
    props: { airline },
  }));
}
---

<AirlineSlugPage lang="en" airline={Astro.props.airline} />
