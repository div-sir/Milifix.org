---
import { getCollection, render } from 'astro:content';
import PageTransition from '../../components/PageTransition.astro';

export async function getStaticPaths() {
  const works = await getCollection('solilium');
  return works.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, tags, cover, date, description } = entry.data;

const allWorks = (await getCollection('solilium')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);
const curIdx = allWorks.findIndex((w) => w.id === entry.id);
const prevWork = curIdx > 0 ? allWorks[curIdx - 1] : null;
const nextWork = curIdx >= 0 && curIdx < allWorks.length - 1 ? allWorks[curIdx + 1] : null;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SOLILIUM</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #080808;
      --bg2: #0f0f0f;
      --bg3: #141414;
      --line: rgba(255,255,255,0.06);
      --line2: rgba(255,255,255,0.12);
      --text: #e8e8e8;
      --muted: #555;
      --accent: #c8ff00;
      --mono: 'Space Mono', monospace;
      --sans: 'Space Grotesk', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      cursor: none;
      overflow-x: hidden;
      min-height: 100vh;
    }

    #cursor {
      width: 8px; height: 8px;
      background: var(--accent);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s, width 0.2s, height 0.2s, background 0.2s;
    }
    #cursor-ring {
      width: 32px; height: 32px;
      border: 1px solid rgba(200,255,0,0.4);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.12s ease-out, width 0.25s, height 0.25s, border-color 0.2s;
    }
    body:has(a:hover) #cursor { width: 12px; height: 12px; }
    body:has(a:hover) #cursor-ring {
      width: 48px; height: 48px;
      border-color: rgba(200,255,0,0.7);
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--line) 1px, transparent 1px),
        linear-gradient(90deg, var(--line) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 48px;
      border-bottom: 1px solid var(--line);
      background: rgba(8,8,8,0.75);
      backdrop-filter: blur(12px);
    }
    .nav-logo {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 36px; align-items: center; }
    .nav-links a {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }

    .work-hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      z-index: 1;
    }
    .work-hero__media {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .work-hero__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: grayscale(12%);
    }
    .work-hero__gradient {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(to top, rgba(8,8,8,0.95) 0%, rgba(8,8,8,0.25) 42%, rgba(8,8,8,0.55) 100%),
        linear-gradient(to right, rgba(8,8,8,0.5) 0%, transparent 55%);
      pointer-events: none;
    }
    .work-hero__content {
      position: relative;
      z-index: 2;
      padding: 100px 48px 56px;
      max-width: 900px;
      margin: 0 auto;
      width: 100%;
    }
    .work-hero__meta {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .work-hero__title {
      font-family: var(--mono);
      font-size: clamp(32px, 6vw, 56px);
      font-weight: 700;
      line-height: 1.08;
      margin-bottom: 24px;
      color: var(--text);
    }
    .work-hero__tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .work-tag {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
      border: 1px solid var(--line2);
      padding: 4px 10px;
      text-transform: uppercase;
    }

    .work-article {
      position: relative;
      z-index: 1;
      padding: 64px 48px 48px;
      max-width: 900px;
      margin: 0 auto;
    }
    .work-lead {
      font-size: 17px;
      color: var(--muted);
      line-height: 1.75;
      margin-bottom: 40px;
      max-width: 640px;
    }
    .work-body {
      font-size: 16px;
      color: var(--muted);
      line-height: 1.85;
    }
    .work-body :global(p) { margin-bottom: 1.25em; }
    .work-body :global(p:last-child) { margin-bottom: 0; }
    .work-body :global(a) {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid rgba(200,255,0,0.35);
    }
    .work-body :global(a:hover) { border-bottom-color: var(--accent); }
    .work-body :global(strong) { color: var(--text); font-weight: 500; }
    .work-body :global(ul), .work-body :global(ol) {
      margin: 1em 0 1em 1.25em;
    }
    .work-body :global(li) { margin-bottom: 0.5em; }

    .work-junction {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 40px 48px 32px;
      max-width: 900px;
      margin: 0 auto;
      border-top: 1px solid var(--line);
    }
    .work-junction__link {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      color: var(--muted);
      text-decoration: none;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .work-junction__link:hover { color: var(--accent); }
    .work-junction__spacer { flex: 1; min-width: 0; }
    .work-junction__link--next { margin-left: auto; text-align: right; }

    footer {
      position: relative;
      z-index: 1;
      padding: 48px;
      border-top: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .footer-logo {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.2em;
      color: var(--muted);
    }
    .footer-copy {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--muted);
      opacity: 0.4;
    }

    @media (max-width: 768px) {
      nav { padding: 20px 24px; }
      .nav-links { gap: 20px; }
      .work-hero__content { padding: 88px 24px 40px; }
      .work-article { padding: 48px 24px 32px; }
      .work-junction { padding: 32px 24px; flex-wrap: wrap; }
      footer { padding: 32px 24px; flex-direction: column; gap: 12px; text-align: center; }
    }
  </style>
</head>
<body>
  <PageTransition />

  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <nav>
    <a href="/solilium" class="nav-logo">SOLILIUM</a>
    <div class="nav-links">
      <a href="/">Platform</a>
      <a href="/solilium">All works</a>
    </div>
  </nav>

  <header class="work-hero">
    <div class="work-hero__media">
      <img class="work-hero__img" src={cover} alt="" loading="eager" />
      <div class="work-hero__gradient"></div>
    </div>
    <div class="work-hero__content">
      <p class="work-hero__meta work-hero-animate">{date}</p>
      <h1 class="work-hero__title work-hero-animate">{title}</h1>
      <div class="work-hero__tags work-hero-animate">
        {tags.map((tag) => (
          <span class="work-tag">{tag}</span>
        ))}
      </div>
    </div>
  </header>

  <article class="work-article">
    <p class="work-lead">{description}</p>
    <div class="work-body">
      <Content />
    </div>
  </article>

  <nav class="work-junction" aria-label="Adjacent works">
    {prevWork ? (
      <a class="work-junction__link work-junction__link--prev" href={`/solilium/${prevWork.id}`}>
        ← PREV WORK
      </a>
    ) : (
      <span class="work-junction__spacer" aria-hidden="true"></span>
    )}
    {nextWork ? (
      <a class="work-junction__link work-junction__link--next" href={`/solilium/${nextWork.id}`}>
        NEXT WORK →
      </a>
    ) : (
      <span class="work-junction__spacer" aria-hidden="true"></span>
    )}
  </nav>

  <footer>
    <span class="footer-logo">SOLILIUM</span>
    <span class="footer-copy">© 2026 — All rights reserved</span>
  </footer>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;

    document.addEventListener('mousemove', (e) => {
      mx = e.clientX;
      my = e.clientY;
      cursor.style.left = mx + 'px';
      cursor.style.top = my + 'px';
    });

    function animateRing() {
      rx += (mx - rx) * 0.12;
      ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px';
      ring.style.top = ry + 'px';
      requestAnimationFrame(animateRing);
    }
    animateRing();

    gsap.from('.work-hero-animate', {
      y: 60,
      opacity: 0,
      duration: 0.72,
      stagger: 0.1,
      ease: 'power2.out',
      delay: 0.08,
    });

    const lead = document.querySelector('.work-lead');
    if (lead) {
      gsap.from(lead, {
        scrollTrigger: { trigger: lead, start: 'top 88%', once: true },
        y: 48,
        opacity: 0,
        duration: 0.65,
        ease: 'power2.out',
      });
    }

    document.querySelectorAll('.work-body p').forEach((p) => {
      gsap.from(p, {
        scrollTrigger: { trigger: p, start: 'top 88%', once: true },
        y: 48,
        opacity: 0,
        duration: 0.65,
        ease: 'power2.out',
      });
    });
  </script>
</body>
</html>
