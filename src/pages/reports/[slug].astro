---
import TripReportPage from '../../components/pages/TripReportPage.astro';
import TripReportImmersivePage from '../../components/pages/TripReportImmersivePage.astro';
import { tripReports } from '../../data/trips/index';

export async function getStaticPaths() {
  return tripReports.map((trip) => ({
    params: { slug: trip.slug },
    props: { trip },
  }));
}

const { trip } = Astro.props;
---

{
  trip.presentation === 'immersive' ? (
    <TripReportImmersivePage lang="zh" trip={trip} />
  ) : (
    <TripReportPage lang="zh" trip={trip} />
  )
}
