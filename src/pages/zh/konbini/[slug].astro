---
import KonbiniProductPage from '../../../components/pages/KonbiniProductPage.astro';
import { allKonbiniSlugs } from '../../../lib/konbini';

export async function getStaticPaths() {
  const slugs = await allKonbiniSlugs();
  return slugs.map(({ slug }) => ({ params: { slug }, props: { slug } }));
}
---

<KonbiniProductPage lang="zh" slug={Astro.props.slug} />
