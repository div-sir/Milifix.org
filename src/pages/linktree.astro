---
import '../styles/theme.css';
import '../styles/portfolio-atmosphere.css';
---
<!DOCTYPE html>
<html lang="zh-Hant" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Solilium</title>
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --mono: 'Space Mono', monospace;
      --sans: 'Space Grotesk', sans-serif;
    }

    html {
      background: var(--bg);
      min-height: 100%;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      min-height: 100svh;
      overflow-x: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── 粒子畫布 ────────────────────────────── */
    #lt-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ── 背景網格 ─────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--line) 1px, transparent 1px),
        linear-gradient(90deg, var(--line) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 1;
      opacity: 0.45;
    }

    /* ── Ambient glow orbs ────────────────────── */
    .lt-orb {
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      filter: blur(80px);
      opacity: 0.18;
      animation: lt-orb-drift 12s ease-in-out infinite alternate;
    }
    .lt-orb--1 {
      width: 520px; height: 520px;
      background: var(--accent);
      top: -180px; left: -120px;
      animation-duration: 14s;
    }
    .lt-orb--2 {
      width: 380px; height: 380px;
      background: var(--nav-accent);
      bottom: -100px; right: -80px;
      animation-duration: 18s;
      animation-delay: -6s;
    }
    @keyframes lt-orb-drift {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(40px, 30px) scale(1.08); }
    }
    @media (prefers-reduced-motion: reduce) {
      .lt-orb { animation: none; }
    }

    /* ── 卡片容器 ─────────────────────────────── */
    .lt-card {
      position: relative;
      z-index: 2;
      width: min(420px, calc(100vw - 2.5rem));
      padding: 2.8rem 2.4rem 2.4rem;
      border-radius: 20px;
      border: 1px solid color-mix(in srgb, var(--line2) 88%, var(--accent) 12%);
      background: color-mix(in srgb, var(--bg2) 72%, transparent);
      backdrop-filter: blur(24px) saturate(1.2);
      -webkit-backdrop-filter: blur(24px) saturate(1.2);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--accent) 6%, transparent),
        0 32px 64px -24px color-mix(in srgb, var(--shadow-card) 85%, transparent),
        inset 0 1px 0 color-mix(in srgb, #fff 6%, transparent);
    }

    /* 角落裝飾線 */
    .lt-card::before,
    .lt-card::after {
      content: '';
      position: absolute;
      width: 22px; height: 22px;
      border-color: color-mix(in srgb, var(--accent) 50%, var(--line2));
      opacity: 0.7;
      pointer-events: none;
    }
    .lt-card::before {
      top: 14px; left: 14px;
      border-top: 1.5px solid;
      border-left: 1.5px solid;
      border-radius: 4px 0 0 0;
    }
    .lt-card::after {
      bottom: 14px; right: 14px;
      border-bottom: 1.5px solid;
      border-right: 1.5px solid;
      border-radius: 0 0 4px 0;
    }

    /* ── Avatar ───────────────────────────────── */
    .lt-avatar-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 1.4rem;
    }
    .lt-avatar {
      width: 72px; height: 72px;
      border-radius: 50%;
      border: 2px solid color-mix(in srgb, var(--accent) 55%, var(--line2));
      background: var(--bg3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--accent) 12%, transparent),
        0 0 28px color-mix(in srgb, var(--accent) 22%, transparent);
      animation: lt-avatar-pulse 3.5s ease-in-out infinite;
    }
    @keyframes lt-avatar-pulse {
      0%, 100% { box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 12%, transparent), 0 0 28px color-mix(in srgb, var(--accent) 22%, transparent); }
      50%       { box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent) 18%, transparent), 0 0 44px color-mix(in srgb, var(--accent) 32%, transparent); }
    }
    @media (prefers-reduced-motion: reduce) {
      .lt-avatar { animation: none; }
    }

    /* ── 名字與標語 ───────────────────────────── */
    .lt-name {
      font-family: var(--mono);
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text);
      text-align: center;
      margin-bottom: 0.38rem;
    }
    .lt-tagline {
      font-size: 0.82rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      text-align: center;
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    /* ── 連結列表 ─────────────────────────────── */
    .lt-links {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }

    .lt-link {
      position: relative;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.9rem 1.1rem;
      border-radius: 10px;
      border: 1px solid var(--line2);
      background: color-mix(in srgb, var(--bg3) 60%, transparent);
      text-decoration: none;
      color: var(--text);
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      overflow: hidden;
      transition: border-color 0.28s ease, transform 0.28s ease, box-shadow 0.28s ease;
    }

    /* 掃光效果 */
    .lt-link::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        110deg,
        transparent 20%,
        color-mix(in srgb, var(--accent) 10%, transparent) 50%,
        transparent 80%
      );
      transform: translateX(-120%);
      transition: transform 0.6s cubic-bezier(0.33, 1, 0.64, 1);
      pointer-events: none;
    }

    .lt-link:hover {
      border-color: color-mix(in srgb, var(--accent) 45%, var(--line2));
      transform: translateY(-2px);
      box-shadow: 0 8px 24px color-mix(in srgb, var(--shadow-card) 70%, transparent);
    }
    .lt-link:hover::before {
      transform: translateX(120%);
    }

    .lt-link__icon {
      flex-shrink: 0;
      width: 36px; height: 36px;
      border-radius: 8px;
      background: color-mix(in srgb, var(--accent) 12%, var(--bg2));
      border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      transition: background 0.28s ease, border-color 0.28s ease;
    }
    .lt-link:hover .lt-link__icon {
      background: color-mix(in srgb, var(--accent) 20%, var(--bg2));
      border-color: color-mix(in srgb, var(--accent) 50%, var(--line));
    }
    .lt-link__icon svg {
      width: 16px; height: 16px;
      fill: currentColor;
    }

    .lt-link__label {
      flex: 1;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .lt-link__arrow {
      font-size: 0.82rem;
      color: var(--muted-dim);
      transition: transform 0.22s ease, color 0.22s ease;
    }
    .lt-link:hover .lt-link__arrow {
      transform: translate(3px, -3px);
      color: var(--accent);
    }

    /* ── 分隔線 ───────────────────────────────── */
    .lt-divider {
      height: 1px;
      margin: 1.6rem 0 1.2rem;
      background: linear-gradient(90deg, transparent, var(--line2), transparent);
    }

    /* ── 底部 back ────────────────────────────── */
    .lt-back {
      display: flex;
      justify-content: center;
    }
    .lt-back a {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted-dim);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .lt-back a:hover { color: var(--accent); }

    /* ── 入場動畫 ─────────────────────────────── */
    .lt-card {
      opacity: 0;
      transform: translateY(24px);
      animation: lt-card-in 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
    }
    @keyframes lt-card-in {
      to { opacity: 1; transform: translateY(0); }
    }
    .lt-link {
      opacity: 0;
      animation: lt-link-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .lt-link:nth-child(1) { animation-delay: 0.35s; }
    .lt-link:nth-child(2) { animation-delay: 0.46s; }
    .lt-link:nth-child(3) { animation-delay: 0.57s; }
    @keyframes lt-link-in {
      from { opacity: 0; transform: translateX(-12px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .lt-card, .lt-link { animation: none; opacity: 1; transform: none; }
    }
  </style>
</head>
<body class="portfolio-atmo">
  <!-- Ambient orbs -->
  <div class="lt-orb lt-orb--1" aria-hidden="true"></div>
  <div class="lt-orb lt-orb--2" aria-hidden="true"></div>

  <!-- Particle canvas -->
  <canvas id="lt-canvas" aria-hidden="true"></canvas>

  <main>
    <div class="lt-card">
      <div class="lt-avatar-wrap">
        <div class="lt-avatar" aria-hidden="true">S</div>
      </div>

      <p class="lt-name">Solilium</p>
      <p class="lt-tagline">Photography · Motion · Archive</p>

      <div class="lt-links">
        <!-- LinkedIn -->
        <a class="lt-link" href="https://www.linkedin.com/in/solilium/" target="_blank" rel="noopener noreferrer">
          <span class="lt-link__icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </span>
          <span class="lt-link__label">LinkedIn</span>
          <span class="lt-link__arrow" aria-hidden="true">↗</span>
        </a>

        <!-- Instagram -->
        <a class="lt-link" href="https://www.instagram.com/solilium.mili/" target="_blank" rel="noopener noreferrer">
          <span class="lt-link__icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </span>
          <span class="lt-link__label">Instagram</span>
          <span class="lt-link__arrow" aria-hidden="true">↗</span>
        </a>

        <!-- Email -->
        <a class="lt-link" href="mailto:steven33152239@gmail.com">
          <span class="lt-link__icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </span>
          <span class="lt-link__label">Email</span>
          <span class="lt-link__arrow" aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="lt-divider" aria-hidden="true"></div>

      <div class="lt-back">
        <a href="/">← Milifix</a>
      </div>
    </div>
  </main>

  <script>
    // ── 粒子系統 ──────────────────────────────────────
    const canvas = document.getElementById('lt-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const style = getComputedStyle(document.documentElement);
    function getAccent() {
      return style.getPropertyValue('--accent').trim() || '#e2b565';
    }

    interface Particle {
      x: number; y: number;
      vx: number; vy: number;
      size: number;
      alpha: number;
      alphaDir: number;
    }

    const COUNT = 55;
    const particles: Particle[] = Array.from({ length: COUNT }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      vx: (Math.random() - 0.5) * 0.35,
      vy: (Math.random() - 0.5) * 0.35,
      size: Math.random() * 1.8 + 0.4,
      alpha: Math.random() * 0.4 + 0.1,
      alphaDir: Math.random() > 0.5 ? 1 : -1,
    }));

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const accent = getAccent();

      for (const p of particles) {
        if (!prefersReduced) {
          p.x += p.vx;
          p.y += p.vy;
          p.alpha += p.alphaDir * 0.003;
          if (p.alpha >= 0.5 || p.alpha <= 0.05) p.alphaDir *= -1;
          if (p.x < 0) p.x = canvas.width;
          if (p.x > canvas.width) p.x = 0;
          if (p.y < 0) p.y = canvas.height;
          if (p.y > canvas.height) p.y = 0;
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = accent;
        ctx.globalAlpha = p.alpha;
        ctx.fill();
      }

      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    }

    draw();
  </script>
</body>
</html>
