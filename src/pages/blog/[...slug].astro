---
import { getCollection, render } from 'astro:content';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/blog.css';
import SiteNav from '../../components/SiteNav.astro';
import PortfolioChrome from '../../components/PortfolioChrome.astro';
import AmbientBackdrop from '../../components/AmbientBackdrop.astro';
import zephlogBlogPathRedirects from '../../data/zephlogBlogPathRedirects.json';
import { resolveLegacyRedirect } from '../../data/blog-routing-rules';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const published = posts.filter((p) => !p.data.draft);
  const postPaths = published.map((p) => ({ params: { slug: p.id } }));
  const ids = new Set(published.map((p) => p.id));
  const redirectOnly = Object.keys(zephlogBlogPathRedirects as Record<string, string>).filter(
    (id) => !ids.has(id),
  );
  const redirectPaths = redirectOnly.map((slug) => ({ params: { slug } }));
  return [...postPaths, ...redirectPaths];
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join('/') : slugParam;

/** Location 標頭須為 ASCII；內容集合 id 可含中文等字元。支援 `#錨點`（觀光列車合併頁）。 */
function blogPostUrlFromId(id: string) {
  const hashIdx = id.indexOf('#');
  const pathPart = hashIdx === -1 ? id : id.slice(0, hashIdx);
  const hash = hashIdx === -1 ? '' : id.slice(hashIdx + 1);
  const base = `/blog/${pathPart.split('/').map((s) => encodeURIComponent(s)).join('/')}`;
  return hash ? `${base}#${hash}` : base;
}

if (!slug) {
  return Astro.redirect('/blog');
}

const all = await getCollection('blog');
const entry = all.find((p) => p.id === slug);
if (!entry || entry.data.draft) {
  const redirectUrl = resolveLegacyRedirect({
    slug,
    blogPathRedirects: zephlogBlogPathRedirects as Record<string, string>,
    blogPostUrlFromId,
  });
  if (redirectUrl) return Astro.redirect(redirectUrl);
  return Astro.redirect('/blog');
}

const { Content } = await render(entry);
const firstContentH1Match = entry.body.match(/^#\s+(.+)$/m);
const firstContentH1 = firstContentH1Match?.[1]?.trim() || '';
const displayTitle = firstContentH1 || entry.data.title;

const hl = Astro.url.searchParams.get('hl');
const lang = hl === 'en' || hl === 'ja' || hl === 'zh' ? hl : 'zh';
/** 僅供 aria，畫面上不顯示「目錄」標題 */
const tocAriaLabel = lang === 'en' ? 'On this page' : lang === 'ja' ? 'このページの見出し' : '本篇章節';
const tocToggleUnpin =
  lang === 'en' ? 'Collapse' : lang === 'ja' ? '閉じる' : '收合';
const tocTogglePin =
  lang === 'en' ? 'Expand' : lang === 'ja' ? '開く' : '展開';
const dockSections: { id: string; label: string; href?: string; icon?: 'back' }[] = [
  { id: 'back-to-blog', label: '返回', href: '/blog', icon: 'back' },
];
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-Hant' : lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{displayTitle} · Blog</title>
    <meta name="description" content={entry.data.description} />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('portfolio-theme');
          document.documentElement.dataset.theme =
            t === 'light' ? 'light' : t === 'dark' ? 'dark' : window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          if (!sessionStorage.getItem('portfolio:lang-transition-v1')) return;
          var light = document.documentElement.dataset.theme === 'light';
          var bg = light ? '#f4f2ec' : '#111318';
          var d = document.createElement('div');
          d.id = 'portfolio-lang-transition';
          d.setAttribute('data-early', '1');
          d.setAttribute('aria-hidden', 'true');
          d.style.cssText =
            'position:fixed;inset:0;z-index:999;background:' +
            bg +
            ';opacity:1;pointer-events:auto';
          document.documentElement.appendChild(d);
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      (function () {
        try {
          var qs = new URLSearchParams(window.location.search);
          if (qs.get('hl')) return;
          var preferred = (localStorage.getItem('portfolio:preferred-lang') || '').toLowerCase();
          if (preferred !== 'en' && preferred !== 'ja') return;
          var url = new URL(window.location.href);
          url.searchParams.set('hl', preferred);
          window.location.replace(url.toString());
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="portfolio-atmo">
    <AmbientBackdrop />
    <div id="cursor"></div>
    <div id="cursor-ring"></div>
    <SiteNav variant="platform" lang={lang} pathname={Astro.url.pathname} />
    <PortfolioChrome
      lang={lang}
      pathname={Astro.url.pathname}
      dockSections={dockSections}
      dockOrder="sections-first"
      dockHomeHref="/"
      dockHomeLabel="Milifix"
      dockHomeIcon="home"
    />
    <article class="article-wrap" id="main-content" tabindex="-1">
      <a class="back" href="/blog">← Blog</a>
      <h1 class="post-title">{displayTitle}</h1>
      <div class="prose">
        <Content />
      </div>
    </article>
    {
      !entry.data.hideToc && (
        <!-- 勿加 notranslate：hl=en|ja 時需與正文一併由 Google Translate 處理目錄標題 -->
        <aside id="blog-post-toc" class="blog-toc" aria-label={tocAriaLabel} hidden>
          <div class="blog-toc__shell">
            <div id="blog-toc-panel" class="blog-toc__panel">
              <nav class="blog-toc__nav" aria-label={tocAriaLabel} />
            </div>
            <button
              type="button"
              class="blog-toc__toggle"
              aria-expanded="false"
              aria-controls="blog-toc-panel"
              data-label-collapse={tocToggleUnpin}
              data-label-expand={tocTogglePin}
            >
              <span class="blog-toc__toggle-chevron" aria-hidden="true">
                <svg width="12" height="18" viewBox="0 0 11 18" fill="none" aria-hidden="true">
                  <path
                    d="M9.5 1L2 9l7.5 8"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </button>
          </div>
        </aside>
      )
    }
    <script>
      import { initBlogPostToc } from '../../scripts/init-blog-post-toc';
      import { initPretextLayout } from '../../scripts/init-pretext-layout';
      import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
      import {
        consumeLangTransitionPending,
        finishBlogLangTransitionOverlay,
        prepareBlogLangTransitionOverlay,
      } from '../../scripts/lang-transition';

      initPortfolioCursor();
      initPretextLayout();
      initBlogPostToc();

      const BLOG_VIEW_LANG_KEY = 'portfolio:blog-view-lang';
      const PREFERRED_LANG_KEY = 'portfolio:preferred-lang';

      function clearGoogleTranslateState() {
        const expire = 'Thu, 01 Jan 1970 00:00:00 GMT';
        document.cookie = `googtrans=; expires=${expire}; path=/`;
        document.cookie = `googtrans=; expires=${expire}; path=/; domain=${window.location.hostname}`;
      }

      function getBlogDisplayLang() {
        const qsLang = (new URL(window.location.href).searchParams.get('hl') || '').toLowerCase();
        if (qsLang === 'en' || qsLang === 'ja' || qsLang === 'zh') return qsLang;
        const savedBlog = (localStorage.getItem(BLOG_VIEW_LANG_KEY) || '').toLowerCase();
        if (savedBlog === 'en' || savedBlog === 'ja' || savedBlog === 'zh') return savedBlog;
        const preferred = (localStorage.getItem(PREFERRED_LANG_KEY) || '').toLowerCase();
        if (preferred === 'en' || preferred === 'ja' || preferred === 'zh') return preferred;
        return 'zh';
      }

      function applyGoogleTranslate(targetLang) {
        const combo = document.querySelector('.goog-te-combo');
        if (!combo) return false;
        if (combo.value === targetLang) return true;
        combo.value = targetLang;
        combo.dispatchEvent(new Event('change'));
        return true;
      }

      function mountTranslateScript(targetLang, onSettled) {
        const host = document.createElement('div');
        host.id = 'google_translate_element';
        host.style.display = 'none';
        document.body.appendChild(host);

        window.googleTranslateElementInit = () => {
          // eslint-disable-next-line no-undef
          new google.translate.TranslateElement(
            {
              pageLanguage: 'zh-TW',
              includedLanguages: 'zh-TW,ja,en',
              autoDisplay: false,
            },
            'google_translate_element'
          );

          let retries = 0;
          const maxRetries = 24;
          const timer = window.setInterval(() => {
            retries += 1;
            if (applyGoogleTranslate(targetLang) || retries >= maxRetries) {
              window.clearInterval(timer);
              onSettled?.();
            }
          }, 250);
        };

        const script = document.createElement('script');
        script.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
        script.defer = true;
        document.body.appendChild(script);
      }

      const displayLang = getBlogDisplayLang();
      const fromLangNav = consumeLangTransitionPending();

      if (displayLang === 'zh') {
        if (fromLangNav) prepareBlogLangTransitionOverlay(true);
        clearGoogleTranslateState();
        if (fromLangNav) requestAnimationFrame(() => finishBlogLangTransitionOverlay());
      } else if (displayLang === 'en' || displayLang === 'ja') {
        prepareBlogLangTransitionOverlay(fromLangNav);
        mountTranslateScript(displayLang, () => finishBlogLangTransitionOverlay());
      }

    </script>
  </body>
</html>
