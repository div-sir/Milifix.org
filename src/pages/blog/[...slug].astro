---
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/blog.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import PortfolioChrome from '../../components/PortfolioChrome.astro';
import AmbientBackdrop from '../../components/AmbientBackdrop.astro';
import LexicalContent from '../../components/LexicalContent.astro';
import { getPosts } from '../../lib/cms';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const displayTitle = post.title;

const hl = Astro.url.searchParams.get('hl');
const lang = hl === 'en' || hl === 'ja' || hl === 'zh' ? hl : 'zh';
const tocAriaLabel = lang === 'en' ? 'On this page' : lang === 'ja' ? 'このページの見出し' : '本篇章節';
const tocToggleUnpin = lang === 'en' ? 'Collapse' : lang === 'ja' ? '閉じる' : '收合';
const tocTogglePin = lang === 'en' ? 'Expand' : lang === 'ja' ? '開く' : '展開';
const dockSections: { id: string; label: string; href?: string; icon?: 'back' }[] = [
  { id: 'back-to-blog', label: '返回', href: '/blog', icon: 'back' },
];
---

<BaseLayout
  lang={lang}
  title={`${displayTitle} · Blog`}
  description={post.description}
  canonicalPath={Astro.url.pathname}
  hreflangAlternates={false}
>
    <script slot="head" is:inline>
      (function () {
        try {
          if (!sessionStorage.getItem('portfolio:lang-transition-v1')) return;
          var light = document.documentElement.dataset.theme === 'light';
          var bg = light ? '#f4f2ec' : '#111318';
          var d = document.createElement('div');
          d.id = 'portfolio-lang-transition';
          d.setAttribute('data-early', '1');
          d.setAttribute('aria-hidden', 'true');
          d.style.cssText =
            'position:fixed;inset:0;z-index:999;background:' +
            bg +
            ';opacity:1;pointer-events:auto';
          document.documentElement.appendChild(d);
        } catch (e) {}
      })();
    </script>
    <script slot="head" is:inline>
      (function () {
        try {
          var qs = new URLSearchParams(window.location.search);
          if (qs.get('hl')) return;
          var preferred = (localStorage.getItem('portfolio:preferred-lang') || '').toLowerCase();
          if (preferred !== 'en' && preferred !== 'ja') return;
          var url = new URL(window.location.href);
          url.searchParams.set('hl', preferred);
          window.location.replace(url.toString());
        } catch (e) {}
      })();
    </script>
    <AmbientBackdrop />
    <div id="cursor"></div>
    <div id="cursor-ring"></div>
    <SiteNav variant="platform" lang={lang} pathname={Astro.url.pathname} />
    <PortfolioChrome
      lang={lang}
      pathname={Astro.url.pathname}
      dockSections={dockSections}
      dockOrder="sections-first"
      dockHomeHref="/"
      dockHomeLabel="Milifix"
      dockHomeIcon="home"
    />
    <article class="article-wrap" id="main-content" tabindex="-1">
      <a class="back" href="/blog">← Blog</a>
      <h1 class="post-title">{displayTitle}</h1>
      <div class="prose">
        <LexicalContent content={post.content} />
      </div>
    </article>
    {
      !post.hideToc && (
        <aside id="blog-post-toc" class="blog-toc" aria-label={tocAriaLabel} hidden>
          <div class="blog-toc__shell">
            <div id="blog-toc-panel" class="blog-toc__panel">
              <nav class="blog-toc__nav" aria-label={tocAriaLabel} />
            </div>
            <button
              type="button"
              class="blog-toc__toggle"
              aria-expanded="false"
              aria-controls="blog-toc-panel"
              data-label-collapse={tocToggleUnpin}
              data-label-expand={tocTogglePin}
            >
              <span class="blog-toc__toggle-chevron" aria-hidden="true">
                <svg width="12" height="18" viewBox="0 0 11 18" fill="none" aria-hidden="true">
                  <path
                    d="M9.5 1L2 9l7.5 8"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </button>
          </div>
        </aside>
      )
    }
    <script>
      import { initBlogPostToc } from '../../scripts/init-blog-post-toc';
      import { initPretextLayout } from '../../scripts/init-pretext-layout';
      import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
      import { initBlogTranslate } from '../../scripts/blog-translate';

      initPortfolioCursor();
      initPretextLayout();
      initBlogPostToc();

      initBlogTranslate();
    </script>
</BaseLayout>
