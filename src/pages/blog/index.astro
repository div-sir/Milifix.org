---
import { getCollection } from 'astro:content';
import '../../styles/theme.css';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const isTravelDataPost = (id: string) =>
  id.startsWith('travel-') ||
  id.startsWith('timeline-') ||
  id.startsWith('records-') ||
  id.startsWith('cabin-') ||
  id.startsWith('aircraft-') ||
  id.startsWith('airline-') ||
  id.startsWith('train-') ||
  [
    'tokyo-wide-pass',
    'nex-roundtrip-ticket',
    'yufuin-no-mori',
    'aoniyoshi-train',
    'iruca-tokyo',
    'sugita',
  ].includes(id);
---

<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog · Milifix</title>
    <meta name="description" content="Milifix 筆記與更新" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('portfolio-theme');
          document.documentElement.dataset.theme =
            t === 'light' ? 'light' : t === 'dark' ? 'dark' : window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --mono: 'Space Mono', monospace;
        --sans: 'Space Grotesk', sans-serif;
      }
      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.6;
      }
      .wrap {
        max-width: 40rem;
        margin: 0 auto;
        padding: 4rem 1.5rem 5rem;
      }
      h1 {
        font-family: var(--mono);
        font-size: clamp(1.35rem, 4vw, 1.75rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 2rem;
        color: var(--accent);
      }
      ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .post-item {
        position: relative;
      }
      .post-item[data-travel='true'] {
        padding: 0.55rem 0.65rem 0.65rem;
        border: 1px solid color-mix(in srgb, var(--line2) 68%, var(--accent) 32%);
        border-radius: 12px;
        background: color-mix(in srgb, var(--bg2) 64%, transparent);
      }
      .travel-badge {
        display: inline-flex;
        align-items: center;
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--accent) 74%, var(--text) 26%);
        margin-bottom: 0.45rem;
      }
      .travel-badge::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        margin-right: 0.5rem;
        background: currentColor;
        box-shadow: 0 0 12px color-mix(in srgb, var(--accent) 55%, transparent);
      }
      .post-title {
        position: relative;
      }
      .post-item[data-travel='true'] .post-title {
        background: linear-gradient(
          100deg,
          color-mix(in srgb, var(--text) 88%, var(--accent) 12%),
          color-mix(in srgb, var(--accent) 70%, var(--text) 30%),
          color-mix(in srgb, var(--text) 88%, var(--accent) 12%)
        );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        background-size: 220% 100%;
        animation: blog-travel-sheen 5.4s linear infinite;
      }
      @keyframes blog-travel-sheen {
        0% { background-position: 130% 0; }
        100% { background-position: -80% 0; }
      }
      @media (prefers-reduced-motion: reduce) {
        .post-item[data-travel='true'] .post-title {
          animation: none;
        }
      }
      a {
        text-decoration: none;
        color: var(--text);
        border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
        padding-bottom: 2px;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      a:hover {
        color: var(--accent);
        border-color: var(--accent);
      }
      .meta {
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-dim);
        margin-top: 0.35rem;
      }
      .back {
        display: inline-block;
        margin-bottom: 2rem;
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href="/">← Milifix</a>
      <h1>Blog</h1>
      <ul>
        {
          posts.map((p) => (
            <li class="post-item" data-travel={isTravelDataPost(p.id) ? 'true' : 'false'}>
              <a href={`/blog/${p.id}`}>
                {isTravelDataPost(p.id) && <div class="travel-badge">Travel Data</div>}
                <div class="post-title">{p.data.title}</div>
                <div class="meta">{p.data.date}</div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <script>
      import { initPretextLayout } from '../../scripts/init-pretext-layout';

      initPretextLayout();
    </script>
  </body>
</html>
