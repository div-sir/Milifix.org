---
import { getCollection, render } from 'astro:content';
import '../../styles/theme.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.id } }));
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect('/blog');
}

const all = await getCollection('blog');
const entry = all.find((p) => p.id === slug);
if (!entry || entry.data.draft) {
  return Astro.redirect('/blog');
}

const { Content } = await render(entry);
const isTravelDataPost =
  entry.id.startsWith('travel-') ||
  entry.id.startsWith('timeline-') ||
  entry.id.startsWith('records-') ||
  entry.id.startsWith('cabin-') ||
  entry.id.startsWith('aircraft-') ||
  entry.id.startsWith('airline-') ||
  entry.id.startsWith('train-') ||
  [
    'tokyo-wide-pass',
    'nex-roundtrip-ticket',
    'yufuin-no-mori',
    'aoniyoshi-train',
    'iruca-tokyo',
    'sugita',
  ].includes(entry.id);
---

<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} · Blog</title>
    <meta name="description" content={entry.data.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('portfolio-theme');
          document.documentElement.dataset.theme =
            t === 'light' ? 'light' : t === 'dark' ? 'dark' : window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --mono: 'Space Mono', monospace;
        --sans: 'Space Grotesk', sans-serif;
      }
      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.75;
      }
      .wrap {
        max-width: 42rem;
        margin: 0 auto;
        padding: 4rem 1.5rem 5rem;
      }
      .back {
        display: inline-block;
        margin-bottom: 2rem;
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
        border: none;
      }
      .back:hover {
        color: var(--accent);
      }
      .post-meta {
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-dim);
        margin-bottom: 1.25rem;
      }
      .post-title {
        font-size: clamp(1.5rem, 4vw, 2rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        margin-bottom: 2rem;
        line-height: 1.25;
      }
      .post-title--travel-data {
        background: linear-gradient(
          95deg,
          color-mix(in srgb, var(--text) 88%, var(--accent) 12%),
          color-mix(in srgb, var(--accent) 62%, var(--text) 38%),
          color-mix(in srgb, var(--text) 88%, var(--accent) 12%)
        );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        background-size: 220% 100%;
        animation: travel-data-title-sheen 5.2s linear infinite;
      }
      @keyframes travel-data-title-sheen {
        0% { background-position: 140% 0; }
        100% { background-position: -80% 0; }
      }
      @media (prefers-reduced-motion: reduce) {
        .post-title--travel-data {
          animation: none;
          background-position: 0 0;
        }
      }
      .prose {
        color: var(--muted);
        font-size: 1.05rem;
      }
      .prose :global(h2) {
        font-size: 1.15rem;
        color: var(--text);
        margin: 2rem 0 0.75rem;
      }
      .prose :global(p) {
        margin-bottom: 1rem;
      }
      .prose :global(ul),
      .prose :global(ol) {
        margin: 1rem 0 1rem 1.25rem;
      }
      .prose :global(li) {
        margin-bottom: 0.35rem;
      }
      .prose :global(pre) {
        margin: 1.25rem 0;
        padding: 1rem 1.1rem;
        border-radius: 8px;
        border: 1px solid var(--line2);
        background: var(--bg2);
        overflow-x: auto;
        font-family: var(--mono);
        font-size: 0.82rem;
      }
      .prose :global(code) {
        font-family: var(--mono);
        font-size: 0.88em;
      }
      .prose :global(a) {
        color: var(--accent);
      }
      .prose :global(.data-snapshot) {
        margin: 1.25rem 0 1.75rem;
        padding: 1rem;
        border: 1px solid color-mix(in srgb, var(--line2) 70%, var(--accent) 30%);
        border-radius: 14px;
        background: color-mix(in srgb, var(--bg2) 72%, transparent);
      }
      .prose :global(.data-snapshot__grid) {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.7rem;
        margin-bottom: 0.95rem;
      }
      .prose :global(.data-kpi) {
        border: 1px solid color-mix(in srgb, var(--line2) 75%, transparent);
        border-radius: 10px;
        padding: 0.55rem 0.65rem;
        background: color-mix(in srgb, var(--bg) 72%, transparent);
      }
      .prose :global(.data-kpi__label) {
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-dim);
      }
      .prose :global(.data-kpi__value) {
        margin-top: 0.3rem;
        font-family: var(--mono);
        font-size: 1.05rem;
        color: var(--text);
      }
      .prose :global(.data-bars) {
        display: grid;
        gap: 0.52rem;
      }
      .prose :global(.data-bars__row) {
        display: grid;
        grid-template-columns: 6.5rem minmax(0, 1fr);
        gap: 0.6rem;
        align-items: center;
      }
      .prose :global(.data-bars__row > span) {
        font-family: var(--mono);
        font-size: 0.65rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prose :global(.data-bars__track) {
        height: 8px;
        border-radius: 999px;
        background: color-mix(in srgb, var(--line2) 56%, transparent);
        overflow: hidden;
      }
      .prose :global(.data-bars__track > i) {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 85%, #fff 15%), color-mix(in srgb, var(--accent) 65%, #8fa8e8 35%));
        transform-origin: left center;
        animation: data-bar-in 1.1s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      @keyframes data-bar-in {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
      }
      @media (max-width: 640px) {
        .prose :global(.data-snapshot__grid) {
          grid-template-columns: 1fr;
        }
        .prose :global(.data-bars__row) {
          grid-template-columns: 1fr;
          gap: 0.35rem;
        }
      }
    </style>
  </head>
  <body>
    <article class="wrap">
      <a class="back" href="/blog">← Blog</a>
      <p class="post-meta">{entry.data.date}</p>
      <h1 class:list={['post-title', isTravelDataPost && 'post-title--travel-data']}>{entry.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </article>
    <script>
      import { initPretextLayout } from '../../scripts/init-pretext-layout';

      initPretextLayout();
    </script>
  </body>
</html>
