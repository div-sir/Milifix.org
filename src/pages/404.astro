---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbientBackdrop from '../components/AmbientBackdrop.astro';
import '../styles/theme.css';
import '../styles/portfolio-atmosphere.css';
---

<BaseLayout lang="en" title="404 — Milifix" noindex bodyClass="portfolio-atmo">
  <AmbientBackdrop />
  <main class="nf-main" id="main-content">
    <p class="nf-code">404</p>
    <h1 class="nf-title">This page drifted off the map.</h1>
    <p class="nf-desc">
      The link may be broken or the page may have moved. Here are a few ways back.
    </p>
    <nav class="nf-links" aria-label="Site sections">
      <a class="nf-link" href="/">Home</a>
      <a class="nf-link" href="/blog">Blog</a>
      <a class="nf-link" href="/konbini">Konbini</a>
    </nav>
  </main>
</BaseLayout>

<style>
  .nf-main {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    max-width: 640px;
    margin: 0 auto;
    padding: 120px 32px 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.1rem;
  }
  .nf-code {
    font-family: var(--mono, 'Space Mono', monospace);
    font-size: clamp(3.5rem, 14vw, 6rem);
    line-height: 1;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--accent) 80%, var(--text));
  }
  .nf-title {
    font-family: var(--sans, 'Space Grotesk', sans-serif);
    font-size: clamp(1.35rem, 4vw, 2rem);
    font-weight: 500;
    color: var(--text);
  }
  .nf-desc {
    font-family: var(--sans, 'Space Grotesk', sans-serif);
    font-size: 0.95rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--text) 70%, transparent);
    max-width: 42ch;
  }
  .nf-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.6rem;
  }
  .nf-link {
    font-family: var(--mono, 'Space Mono', monospace);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text);
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--line2, currentColor));
    background: color-mix(in srgb, var(--bg) 60%, transparent);
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .nf-link:hover {
    color: color-mix(in srgb, var(--accent) 90%, var(--text));
    border-color: color-mix(in srgb, var(--accent) 70%, transparent);
    transform: translateY(-2px);
  }
</style>
