---
import type { Lang } from '../i18n/types';
import { HTML_LANG } from '../i18n/types';
import { availableLangsForPath, equivalentUrl } from '../i18n/routes';
import LegalLinks from '../components/LegalLinks.astro';

interface Props {
  /** 邏輯語系；決定 <html lang> 與 hreflang */
  lang: Lang;
  /** <title> 內容 */
  title: string;
  /** meta description；空字串或未提供則不輸出 */
  description?: string;
  /** 目前頁面的 pathname，用於 canonical 與 hreflang（未提供則不輸出） */
  canonicalPath?: string;
  /** Open Graph 圖片（絕對或站內相對路徑）；未提供則不輸出 og:image */
  ogImage?: string;
  /** 是否輸出 noindex robots meta（linktree 用） */
  noindex?: boolean;
  /** <body> 的 class */
  bodyClass?: string;
  /** 強制指定 <html data-theme>（invoice-pass / linktree 固定 dark）。
   *  設定時會略過主題初始化 script，使該頁鎖定該主題。 */
  htmlDataTheme?: string;
  /** 是否自動產生 hreflang 互指（預設開啟；僅無語系路由的單頁需關閉） */
  hreflangAlternates?: boolean;
  /** 額外的 <body> 屬性（如 space 頁的 data-space） */
  bodyAttrs?: Record<string, string | number | boolean | undefined>;
  /** og:type；預設 website。文章頁傳 'article' 才會輸出 article:published_time */
  ogType?: string;
  /** article:published_time（ISO 字串）。僅 ogType='article' 時有意義 */
  articlePublishedTime?: string;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  ogImage,
  noindex = false,
  bodyClass = 'portfolio-atmo',
  htmlDataTheme,
  hreflangAlternates = true,
  bodyAttrs = {},
  ogType = 'website',
  articlePublishedTime,
} = Astro.props;

const htmlLang = HTML_LANG[lang];
const forcedTheme = typeof htmlDataTheme === 'string' && htmlDataTheme.length > 0;
const hasDescription = typeof description === 'string' && description.trim().length > 0;

const canonicalUrl = canonicalPath ? new URL(canonicalPath, Astro.site).href : undefined;

// 未提供 ogImage 時 fallback 到全站預設分享圖，確保任何頁面分享出去
// 都至少有預覽圖（twitter:card 也才能升級為 summary_large_image）。
const resolvedOgImage = ogImage ?? '/og-default.png';

// hreflang：僅在可索引、有 canonicalPath 且啟用時輸出
const alternates =
  !noindex && canonicalPath && hreflangAlternates
    ? availableLangsForPath(canonicalPath).map((l) => ({
        hreflang: HTML_LANG[l],
        href: new URL(equivalentUrl(l, canonicalPath), Astro.site).href,
      }))
    : [];
const xDefault = alternates.find((a) => a.hreflang === 'en');

const ogLocaleMap: Record<Lang, string> = {
  en: 'en_US',
  zh: 'zh_TW',
  ja: 'ja_JP',
};
const ogImageUrl = new URL(resolvedOgImage, Astro.site).href;
---

<!doctype html>
<html lang={htmlLang} data-theme={forcedTheme ? htmlDataTheme : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />

    <title>{title}</title>
    {hasDescription && <meta name="description" content={description} />}

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault.href} />}

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    {hasDescription && <meta property="og:description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocaleMap[lang]} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta property="og:site_name" content="Milifix" />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}

    {/* Twitter Card */}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {hasDescription && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    {
      /* 主題初始化：全站唯一一份。強制主題頁（forcedTheme）不執行，鎖定 data-theme。 */
      !forcedTheme && (
        <script is:inline>
          {/* eslint-disable-next-line @typescript-eslint/no-unused-expressions -- <script> 內容是單一 template literal 表達式，非裸陳述式，屬 astro-eslint-parser 誤判 */}
          {`(function () {
  try {
    var t = localStorage.getItem('portfolio-theme');
    document.documentElement.dataset.theme =
      t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
  } catch (e) {
    document.documentElement.dataset.theme = 'dark';
  }
})();`}
        </script>
      )
    }

    <slot name="head" />
  </head>
  <body class={bodyClass} {...bodyAttrs}>
    <slot />
    <LegalLinks lang={lang} />
  </body>
</html>
