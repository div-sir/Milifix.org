---
import type { Lang } from '../i18n/types';

interface Props { lang: Lang }
const { lang } = Astro.props;
const prefix = lang === 'zh' ? '/zh' : '';
const copy = lang === 'zh'
  ? { privacy: '隱私權政策', terms: '使用與投稿規範' }
  : { privacy: 'Privacy', terms: 'Terms & community rules' };
---

<nav class="legal-links" aria-label={lang === 'zh' ? '法律資訊' : 'Legal information'}>
  <a href={`${prefix}/privacy`}>{copy.privacy}</a>
  <a href={`${prefix}/terms`}>{copy.terms}</a>
</nav>

<style>
  .legal-links { display: flex; flex-wrap: wrap; justify-content: center; gap: .6rem 1rem; padding: 1.5rem 1rem; font: 500 .72rem/1.5 var(--mono, ui-monospace, monospace); }
  .legal-links a { color: var(--muted, currentColor); text-underline-offset: .25em; }
  .legal-links a:hover, .legal-links a:focus-visible { color: var(--text, currentColor); }
</style>
