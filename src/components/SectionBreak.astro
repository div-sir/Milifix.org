---
interface Props {
  /** 中間小標，留空則僅線條 */
  label?: string;
}

const { label } = Astro.props;
---

<div class="ui-section-break" role="presentation">
  <span class="ui-section-break__line" aria-hidden="true" />
  {label && <span class="ui-section-break__label">{label}</span>}
  <span class="ui-section-break__line" aria-hidden="true" />
</div>

<style>
  .ui-section-break {
    display: flex;
    align-items: center;
    gap: 20px;
    margin: 32px 0;
    width: 100%;
  }
  .ui-section-break__line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line2), transparent);
  }
  .ui-section-break__label {
    flex-shrink: 0;
    font-family: var(--mono, 'Space Mono', monospace);
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted-dim);
  }
</style>
