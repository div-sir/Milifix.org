---
/**
 * 把 Payload Lexical rich text JSON 渲染成 HTML
 * 只處理基本節點：paragraph, heading, text（含 bold/italic/underline）
 */
import { renderChildren, type LexicalRoot } from '../lib/lexical';

interface Props {
  content: unknown;
}

const { content } = Astro.props;

const html = (() => {
  try {
    const root = content as LexicalRoot;
    if (!root?.root?.children) return '';
    return renderChildren(root.root.children);
  } catch {
    return '';
  }
})();
---

<Fragment set:html={html} />
