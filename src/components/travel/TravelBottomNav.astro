---
import type { Lang } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import DockNav from '../DockNav.astro';
import type { DockSection } from '../DockNav.astro';
import { travelPath } from '../../i18n/routes';

interface Props {
  lang: Lang;
  current?: string;
}

const { lang } = Astro.props;
const t = ui(lang).travel;

const sections: DockSection[] = [
  { id: 'cards', label: t.sectionCards },
  { id: 'airlines', label: t.sectionAirlines },
  { id: 'lounges', label: t.sectionLounges },
  { id: 'programs', label: t.programs },
];
---

<DockNav
  lang={lang}
  pathname={Astro.url.pathname}
  dockSections={sections}
  dockSectionLinkMode="scroll"
  dockHomeHref={travelPath(lang)}
  dockHomeLabel="Travel"
  dockHomeIcon="home"
  dockOrder="home-first"
  showScrollTop={true}
/>
