---
import type { Lang } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import {
  travelPath,
  cardListPath,
  loungeListPath,
  airlineListPath,
  programListPath,
  matrixPath,
} from '../../i18n/routes';

interface Props {
  lang: Lang;
  current?: 'index' | 'cards' | 'lounges' | 'airlines' | 'programs' | 'matrix';
}

const { lang, current } = Astro.props;
const t = ui(lang).travel;

const items = [
  { href: travelPath(lang), label: t.heroTitle, key: 'index' as const },
  { href: cardListPath(lang), label: t.sectionCards, key: 'cards' as const },
  { href: airlineListPath(lang), label: t.sectionAirlines, key: 'airlines' as const },
  { href: loungeListPath(lang), label: t.sectionLounges, key: 'lounges' as const },
  { href: programListPath(lang), label: t.programs, key: 'programs' as const },
  { href: matrixPath(lang), label: t.matrix, key: 'matrix' as const },
];
---

<nav class="travel-bottomnav" aria-label="Travel bottom navigation">
  {items.map((item) => (
    <a
      class:list={['travel-bottomnav__item', { 'is-active': current === item.key }]}
      href={item.href}
      aria-current={current === item.key ? 'page' : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
