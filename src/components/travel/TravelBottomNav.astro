---
import type { Lang } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import DockNav from '../DockNav.astro';
import type { DockSection } from '../DockNav.astro';
import { travelPath } from '../../i18n/routes';

interface Props {
  lang: Lang;
  current?: string;
}

const { lang, current } = Astro.props;
const t = ui(lang).travel;
const base = travelPath(lang);
const isDetailPage = !!current;

const sections: DockSection[] = [
  { id: 'cards', label: t.sectionCards, glyph: 'card', ...(isDetailPage ? { href: `${base}#cards` } : {}) },
  { id: 'airlines', label: t.sectionAirlines, glyph: 'airline', ...(isDetailPage ? { href: `${base}#airlines` } : {}) },
  { id: 'lounges', label: t.sectionLounges, glyph: 'lounge', ...(isDetailPage ? { href: `${base}#lounges` } : {}) },
  { id: 'programs', label: t.programs, glyph: 'program', ...(isDetailPage ? { href: `${base}#programs` } : {}) },
];
---

<DockNav
  lang={lang}
  pathname={Astro.url.pathname}
  dockSections={sections}
  dockSectionLinkMode="scroll"
  dockHomeHref={travelPath(lang)}
  dockHomeLabel={isDetailPage ? t.backToTravel : 'Travel'}
  dockHomeIcon={isDetailPage ? 'back' : 'home'}
  dockOrder="home-first"
  showScrollTop={true}
  disableSectionSpy={!isDetailPage}
/>
