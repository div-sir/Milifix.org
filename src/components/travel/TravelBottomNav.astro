---
import type { Lang } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import DockNav from '../DockNav.astro';
import type { DockSection } from '../DockNav.astro';
import {
  travelPath,
  cardListPath,
  loungeListPath,
  airlineListPath,
  programListPath,
  matrixPath,
} from '../../i18n/routes';

interface Props {
  lang: Lang;
  current?: 'index' | 'cards' | 'lounges' | 'airlines' | 'programs' | 'matrix';
}

const { lang, current } = Astro.props;
const t = ui(lang).travel;

const sections: DockSection[] = [
  { id: 'cards', label: t.sectionCards, href: cardListPath(lang) },
  { id: 'airlines', label: t.sectionAirlines, href: airlineListPath(lang) },
  { id: 'lounges', label: t.sectionLounges, href: loungeListPath(lang) },
  { id: 'programs', label: t.programs, href: programListPath(lang) },
  { id: 'matrix', label: t.matrix, href: matrixPath(lang) },
];
---

<DockNav
  lang={lang}
  pathname={Astro.url.pathname}
  dockSections={sections}
  dockSectionLinkMode="hash"
  dockHomeHref={travelPath(lang)}
  dockHomeLabel={t.heroTitle}
  dockHomeIcon="back"
  dockOrder="sections-first"
/>
