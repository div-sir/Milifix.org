---
import type { PhotoSlot } from '../../data/trips/types';

interface Props {
  photo: PhotoSlot;
}

const { photo } = Astro.props;
const hasSrc = typeof photo.src === 'string' && photo.src.length > 0;
---

{
  hasSrc ? (
    <figure class="trip-photo" data-onscroll-reveal>
      <button
        type="button"
        class="trip-photo__trigger"
        data-lightbox-src={photo.src}
        data-lightbox-alt={photo.alt ?? photo.caption ?? ''}
        data-lightbox-caption={photo.caption ?? ''}
        aria-label={photo.caption ?? photo.alt ?? '放大檢視'}
      >
        {/* 實際照片尺寸未知（外部圖檔，build 時無 CMS 圖片管線）；
           父層 .trip-photo 已用 CSS aspect-ratio: 3/2 佔位防止 CLS，
           此處 width/height 屬性依同比例給瀏覽器預留空間的提示 */}
        <img src={photo.src} alt={photo.alt ?? photo.caption ?? ''} width="600" height="400" loading="lazy" decoding="async" />
        {photo.caption && (
          <span class="trip-photo__overlay">
            <span class="trip-photo__overlay-caption">{photo.caption}</span>
          </span>
        )}
      </button>
    </figure>
  ) : (
    <div class="trip-photo trip-photo--placeholder" data-onscroll-reveal>
      <span class="trip-photo__icon" aria-hidden="true">
        📷
      </span>
      {photo.caption && <span class="trip-photo__caption">{photo.caption}</span>}
    </div>
  )
}
