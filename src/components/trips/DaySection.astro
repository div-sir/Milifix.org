---
import type { TripDay, TransportSegment, TripStop } from '../../data/trips/types';
import PhotoPlaceholder from './PhotoPlaceholder.astro';
import TripConnector from './TripConnector.astro';

export interface DayLabels {
  dayWord: string;
  timeline: string;
  activities: string;
  costs: string;
  tips: string;
  links: string;
  photos: string;
  passBadge: string;
  /** 「沿途」小標 */
  stopsHeading: string;
  /** 實用資訊 dossier 標題（如「行程手記」） */
  dossier: string;
  /** 景點類型標籤 */
  kindLabels: Partial<Record<NonNullable<TripStop['kind']>, string>>;
}

interface Props {
  day: TripDay;
  labels: DayLabels;
}

const { day, labels } = Astro.props;

const MODE_ICON: Record<TransportSegment['mode'], string> = {
  flight: '✈️',
  shinkansen: '🚄',
  'night-train': '🌙',
  train: '🚃',
  tram: '🚋',
  monorail: '🚝',
  ferry: '⛴️',
  bus: '🚌',
  walk: '🚶',
};

const segments = day.segments ?? [];
const timeline = day.timeline ?? [];
const costs = day.costs ?? [];
const tips = day.tips ?? [];
const links = day.links ?? [];
const photos = day.photos ?? [];
const stops = day.stops ?? [];

// 路線 dek：以景點名串成「A → B → C」
const routeDek = stops.map((s) => s.name).join(' → ');
// 兩位數編排（Day 02）
const dayNum = String(day.day).padStart(2, '0');

const fmtJpy = (n: number) => `¥${n.toLocaleString('en-US')}`;
const kindLabel = (k?: TripStop['kind']) => (k ? labels.kindLabels[k] ?? '' : '');

// 預估移動時間 → 文字
const fmtDur = (min?: number): string => {
  if (!min || min <= 0) return '';
  if (min < 60) return `約 ${min} 分`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m ? `約 ${h} 小時 ${m} 分` : `約 ${h} 小時`;
};

// ── 把交通段對應到「兩景點之間」，供條目間顯示移動方式與時間 ──
const stopIdSet = new Set(stops.map((s) => s.id));
const usedSeg = new Set<TransportSegment>();
// 相鄰景點之間（stops[i] → stops[i+1]）
const betweenSegs: TransportSegment[][] = stops.map((_, i) => {
  const a = stops[i]?.id;
  const b = stops[i + 1]?.id;
  if (i >= stops.length - 1 || !a || !b) return [];
  const found = segments.filter((sg) => sg.from === a && sg.to === b);
  found.forEach((sg) => usedSeg.add(sg));
  return found;
});
// 進入本日前的銜接（他處 → 首站，如夜車／清晨返回）
const firstId = stops[0]?.id;
const leadingSegs = firstId
  ? segments.filter((sg) => sg.to === firstId && !stopIdSet.has(sg.from) && !usedSeg.has(sg))
  : [];
leadingSegs.forEach((sg) => usedSeg.add(sg));
// 本日結束後的離開（末站 → 他處，如夜車）
const lastId = stops[stops.length - 1]?.id;
const trailingSegs = lastId
  ? segments.filter((sg) => sg.from === lastId && !usedSeg.has(sg))
  : [];

const hasDossier =
  timeline.length > 0 || costs.length > 0 || links.length > 0 || day.activities.length > 0;
---

<section class="trip-day" data-trip-day={day.day} aria-labelledby={`day-${day.day}-title`}>
  <!-- ── 編輯式標頭 ── -->
  <header class="trip-day__head">
    <p class="trip-day__kicker">
      <span class="trip-day__num">{labels.dayWord} {dayNum}</span>
      {day.regionLabel && <span class="trip-day__region">{day.regionLabel}</span>}
    </p>
    <h2 class="trip-day__title" id={`day-${day.day}-title`} data-anime-splittext="chars-inview">
      {day.title}
    </h2>
    {routeDek && <p class="trip-day__dek">{routeDek}</p>}
  </header>

  <!-- ── 沿途景點：各景點一條，供地圖逐點帶入 ── -->
  {
    stops.length > 0 && (
      <div class="trip-stops">
        <p class="trip-block__label trip-stops__heading">{labels.stopsHeading}</p>
        <ol class="trip-stops__list">
          <TripConnector segs={leadingSegs} variant="lead" icons={MODE_ICON} fmtDur={fmtDur} />
          {stops.map((stop, i) => (
            <>
              <li
                class={`trip-stop${i === 0 ? ' trip-stop--lead' : ''}`}
                data-trip-stop={stop.id}
                data-day={day.day}
                tabindex="0"
                role="button"
                aria-label={`在地圖聚焦 ${stop.name}`}
              >
                <span class="trip-stop__index" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="trip-stop__body">
                  <h3 class="trip-stop__name">
                    {stop.name}
                    {kindLabel(stop.kind) && <span class="trip-stop__kind">{kindLabel(stop.kind)}</span>}
                  </h3>
                  {stop.desc && <p class="trip-stop__desc">{stop.desc}</p>}
                  {stop.note && (
                    <p class="trip-stop__note">
                      <span class="trip-stop__note-mark" aria-hidden="true">
                        ✦
                      </span>
                      {stop.note}
                    </p>
                  )}
                  {stop.photos && stop.photos.length > 0 && (
                    <div class="trip-photos trip-photos--stop">
                      {stop.photos.map((photo) => (
                        <PhotoPlaceholder photo={photo} />
                      ))}
                    </div>
                  )}
                </div>
              </li>
              <TripConnector segs={betweenSegs[i]} icons={MODE_ICON} fmtDur={fmtDur} />
            </>
          ))}
          <TripConnector segs={trailingSegs} variant="trail" icons={MODE_ICON} fmtDur={fmtDur} />
        </ol>
      </div>
    )
  }

  <!-- ── 容易忽略的 → pull-quote ── -->
  {
    tips.length > 0 && (
      <aside class="trip-pullquote" aria-label={labels.tips}>
        <p class="trip-pullquote__eyebrow">{labels.tips}</p>
        {tips.map((tip) => (
          <p class="trip-pullquote__text">{tip}</p>
        ))}
      </aside>
    )
  }

  <!-- ── 行程手記 dossier（時間、費用、連結、重點）── -->
  {
    hasDossier && (
      <div class="trip-dossier">
        <p class="trip-dossier__title">{labels.dossier}</p>
        <div class="trip-dossier__grid">
          {timeline.length > 0 && (
            <div class="trip-block">
              <div class="trip-block__label">{labels.timeline}</div>
              <ol class="trip-timeline">
                {timeline.map((entry) => (
                  <li class="trip-timeline__item">
                    {entry.time && <span class="trip-timeline__time">{entry.time}</span>}
                    <span class="trip-timeline__text">{entry.text}</span>
                  </li>
                ))}
              </ol>
            </div>
          )}

          {day.activities.length > 0 && (
            <div class="trip-block">
              <div class="trip-block__label">{labels.activities}</div>
              <ul class="trip-activities">
                {day.activities.map((a) => (
                  <li>{a}</li>
                ))}
              </ul>
            </div>
          )}

          {costs.length > 0 && (
            <div class="trip-block trip-block--wide">
              <div class="trip-block__label">{labels.costs}</div>
              <table class="trip-costs">
                <tbody>
                  {costs.map((c) => (
                    <tr>
                      <td class="trip-costs__label">
                        {c.label}
                        {c.coveredByPass && <span class="trip-pass-badge">{labels.passBadge}</span>}
                        {c.note && <span class="trip-costs__note">{c.note}</span>}
                      </td>
                      <td class="trip-costs__amt">
                        {typeof c.amountJpy === 'number'
                          ? fmtJpy(c.amountJpy)
                          : c.coveredByPass
                            ? '—'
                            : ''}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {links.length > 0 && (
            <div class="trip-block trip-block--wide">
              <div class="trip-block__label">{labels.links}</div>
              <div class="trip-links">
                {links.map((link) =>
                  link.url ? (
                    <a class="trip-link" href={link.url} target="_blank" rel="noopener noreferrer">
                      {link.label}
                      <span class="trip-link__ext" aria-hidden="true">
                        ↗
                      </span>
                    </a>
                  ) : (
                    <span class="trip-link trip-link--text">{link.label}</span>
                  )
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    )
  }

  <!-- ── 當日影像帶 ── -->
  {
    photos.length > 0 && (
      <figure class="trip-day__photos">
        <div class="trip-photos">
          {photos.map((photo) => (
            <PhotoPlaceholder photo={photo} />
          ))}
        </div>
      </figure>
    )
  }
</section>
