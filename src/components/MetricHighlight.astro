---
interface Props {
  value: string;
  label: string;
  /** 副說明，例如趨勢或單位補充 */
  hint?: string;
}

const { value, label, hint } = Astro.props;
---

<div class="ui-metric">
  <span class="ui-metric__value">{value}</span>
  <span class="ui-metric__label">{label}</span>
  {hint && <span class="ui-metric__hint">{hint}</span>}
</div>

<style>
  .ui-metric {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 20px 22px;
    border-radius: 12px;
    border: 1px solid var(--line2);
    background: color-mix(in srgb, var(--bg2) 75%, transparent);
    min-width: 140px;
  }
  .ui-metric__value {
    font-family: var(--mono, 'Space Mono', monospace);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--accent);
  }
  .ui-metric__label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ui-metric__hint {
    font-size: 12px;
    color: var(--muted-dim);
    line-height: 1.4;
    margin-top: 4px;
  }
</style>
