---
---
<div id="page-transition" class="page-transition-layer" aria-hidden="true"></div>

<style is:global>
  .page-transition-layer {
    position: fixed;
    inset: 0;
    background: #080808;
    z-index: 9999;
    pointer-events: auto;
    will-change: transform;
  }
</style>

<script>
  import { gsap } from 'gsap';

  const el = document.getElementById('page-transition');
  if (el) {
    const layer: HTMLElement = el;
    gsap.set(layer, { xPercent: 0 });

    function runExit() {
      gsap.to(layer, {
        xPercent: 100,
        duration: 0.7,
        ease: 'power2.inOut',
        onComplete: () => {
          layer.style.pointerEvents = 'none';
        },
      });
    }

    function bindNavClicks() {
      document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
        const href = a.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:')) return;
        if (a.target === '_blank') return;
        // konbini 商品卡片：一般點擊由卡片自己的腳本攔截去開快速預覽視窗
        // （而不是整頁跳轉），這裡的動畫式頁面轉場要讓開，否則兩邊搶著
        // 處理同一次點擊，視窗才剛開就被這裡的 window.location.href 蓋掉。
        if (a.hasAttribute('data-product-slug')) return;

        let url;
        try {
          url = new URL(href, window.location.origin);
        } catch {
          return;
        }
        if (url.origin !== window.location.origin) return;
        if (url.pathname === window.location.pathname) return;

        a.addEventListener('click', (e) => {
          if (!(e instanceof MouseEvent)) return;
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          if (e.button !== 0) return;
          e.preventDefault();
          layer.style.pointerEvents = 'auto';
          gsap.fromTo(
            layer,
            { xPercent: -100 },
            {
              xPercent: 0,
              duration: 0.7,
              ease: 'power2.inOut',
              onComplete: () => {
                window.location.href = url.pathname + url.search + url.hash;
              },
            },
          );
        });
      });
    }

    function boot() {
      runExit();
      bindNavClicks();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    } else {
      boot();
    }

    window.addEventListener('pageshow', (e) => {
      if (e.persisted) {
        runExit();
        bindNavClicks();
      }
    });
  }
</script>
