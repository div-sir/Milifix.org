---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../SiteNav.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import PageTransition from '../PageTransition.astro';
import TravelBottomNav from '../travel/TravelBottomNav.astro';
import type { Lang } from '../../i18n/types';
import { travelPath } from '../../i18n/routes';
import { tripReports } from '../../data/trips/index';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import '../../styles/trip-report.css';

interface Props {
  lang: Lang;
}

interface IndexLabels {
  tag: string;
  title: string;
  desc: string;
  days: string;
  stops: string;
  empty: string;
}

const LABELS: Record<Lang, IndexLabels> = {
  zh: {
    tag: '旅行報告書',
    title: '旅行報告書',
    desc: '逐日行程、交通與費用紀錄，跟著地圖一起旅行。',
    days: '天',
    stops: '個停靠點',
    empty: '尚未有報告書。',
  },
  en: {
    tag: 'Trip Reports',
    title: 'Trip Reports',
    desc: 'Day-by-day itineraries, transit and cost logs — travel along with the map.',
    days: 'days',
    stops: 'stops',
    empty: 'No reports yet.',
  },
  ja: {
    tag: 'Trip Reports',
    title: 'Trip Reports',
    desc: 'Day-by-day itineraries, transit and cost logs — travel along with the map.',
    days: 'days',
    stops: 'stops',
    empty: 'No reports yet.',
  },
};

const { lang } = Astro.props;
const t = LABELS[lang];
const base = `${travelPath(lang)}/reports`;

const countStops = (report: (typeof tripReports)[number]): number => {
  const ids = new Set<string>();
  for (const d of report.days) for (const s of d.stops) ids.add(s.id);
  return ids.size;
};
---

<BaseLayout
  lang={lang}
  title={`${t.title} — Milifix`}
  description={t.desc}
  canonicalPath={Astro.url.pathname}
  hreflangAlternates={false}
>
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <header class="trip-hero">
      <p class="trip-hero__overline">{t.tag}</p>
      <h1 class="trip-hero__title" data-anime-splittext="chars">{t.title}</h1>
      <p class="trip-hero__summary">{t.desc}</p>
    </header>

    <section class="trip-index">
      {
        tripReports.length > 0 ? (
          <div class="trip-index__grid">
            {tripReports.map((report) => (
              <a class="trip-index-card" href={`${base}/${report.slug}`}>
                <span class="trip-index-card__overline">
                  {report.country} · {report.year}
                </span>
                <span class="trip-index-card__title">{report.title}</span>
                {report.subtitle && <span class="trip-index-card__subtitle">{report.subtitle}</span>}
                <span class="trip-index-card__summary">{report.summary}</span>
                <span class="trip-index-card__meta">
                  <span class="trip-index-card__chip">
                    {report.durationDays} {t.days}
                  </span>
                  <span class="trip-index-card__chip">
                    {countStops(report)} {t.stops}
                  </span>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <p class="trip-footer">{t.empty}</p>
        )
      }
    </section>
  </main>

  <TravelBottomNav lang={lang} />

  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    import { initAnimeSplitText } from '../../scripts/init-anime-splittext';

    initPortfolioCursor();
    initAnimeSplitText();
  </script>
</BaseLayout>
