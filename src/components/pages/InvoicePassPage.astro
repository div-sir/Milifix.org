  const iconGrid        = document.getElementById('icon-grid');

  function updateTriggerDisplay() {
    const icon = ICONS.find(i => i.id === selectedIconId);
    if (!icon) return;
    iconTriggerPrev.innerHTML = makeSvg(icon.path, 16);
    iconTriggerName.textContent = icon.label;
  }

  function renderIconGrid(filter = '') {
    iconGrid.innerHTML = '';
    const q = filter.toLowerCase();
    const cats = [...new Set(ICONS.map(i => i.cat))];
    cats.forEach(cat => {
      const filtered = ICONS.filter(i => i.cat === cat && (
        !q || i.label.includes(q) || i.id.includes(q) || i.cat.includes(q)
      ));
      if (!filtered.length) return;
      const catEl = document.createElement('div');
      catEl.className = 'ip-icon-cat';
      catEl.textContent = cat;
      iconGrid.appendChild(catEl);
      filtered.forEach(icon => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'ip-icon-btn' + (icon.id === selectedIconId ? ' ip-icon-btn--active' : '');
        btn.title = icon.label;
        btn.dataset.id = icon.id;
        btn.innerHTML = makeSvg(icon.path, 18) + `<span class="ip-icon-btn-label">${icon.label}</span>`;
        btn.addEventListener('click', () => {
          selectedIconId = icon.id;
          iconGrid.querySelectorAll('.ip-icon-btn').forEach(b => b.classList.remove('ip-icon-btn--active'));
          btn.classList.add('ip-icon-btn--active');
          updateCardIcon();
          updateTriggerDisplay();
          iconPanel.hidden = true;
        });
        iconGrid.appendChild(btn);
      });
    });
  }

  function updateCardIcon() {
    const icon = ICONS.find(i => i.id === selectedIconId);
    if (!icon) return;
    cardIconEl.innerHTML = makeSvg(icon.path, 14, 'currentColor');
  }

  // Toggle panel
  iconTrigger.addEventListener('click', () => {
    iconPanel.hidden = !iconPanel.hidden;
    if (!iconPanel.hidden) {
      iconSearchInput.value = '';
      renderIconGrid();
      iconSearchInput.focus();
    }
  });

  // Close panel on outside click
  document.addEventListener('click', e => {
    if (!iconTrigger.contains(e.target) && !iconPanel.contains(e.target)) {
      iconPanel.hidden = true;
    }
  });

  // Search filter
  iconSearchInput.addEventListener('input', () => renderIconGrid(iconSearchInput.value));

  renderIconGrid();
  updateCardIcon();
  updateTriggerDisplay();

  // ── Logo text (card title) ─────────────────────────────────────────
  logoTextInput.addEventListener('input', () => {
    cardLogoText.textContent = logoTextInput.value || COPY.logoTextPH;
  });

  // ── Secondary / Auxiliary field preview update ─────────────────────
  const ALIGN_CSS = { left: 'flex-start', center: 'center', right: 'flex-end' };

  const LABEL_ELS = { sec1: sec1LabelEl, sec2: sec2LabelEl, aux1: aux1LabelEl, aux2: aux2LabelEl };
  const VALUE_ELS = { sec1: sec1ValueEl, sec2: sec2ValueEl, aux1: aux1ValueEl, aux2: aux2ValueEl };

  function applyFieldAlign(fieldId) {
    const aLabel = fieldAlign[fieldId].label;
    const aValue = fieldAlign[fieldId].value;
    const lEl = LABEL_ELS[fieldId];
    const vEl = VALUE_ELS[fieldId];
    if (lEl) { lEl.style.alignSelf = ALIGN_CSS[aLabel]; lEl.style.textAlign = aLabel; }
    if (vEl) { vEl.style.alignSelf = ALIGN_CSS[aValue]; vEl.style.textAlign = aValue; }
  }

  function updateSecPreview() {
    sec1LabelEl.textContent = sec1LabelInput.value.trim() || COPY.sec1LabelPH.split('（')[0].trim();
    sec1ValueEl.textContent = sec1ValueInput.value.trim() || COPY.sec1ValuePH.split('（')[0].trim();
    sec2LabelEl.textContent = sec2LabelInput.value.trim() || COPY.sec2LabelPH.split('（')[0].trim();
    sec2ValueEl.textContent = sec2ValueInput.value.trim() || COPY.sec2ValuePH.split('（')[0].trim();
  }

  [sec1LabelInput, sec1ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));
  [sec2LabelInput, sec2ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));

  function updateAuxPreview() {
    const l1 = aux1LabelInput.value.trim();
    const v1 = aux1ValueInput.value.trim();
    const l2 = aux2LabelInput.value.trim();
    const v2 = aux2ValueInput.value.trim();
    const has1 = l1 || v1;
    const has2 = l2 || v2;
    auxRow.style.display = (has1 || has2) ? 'flex' : 'none';
    aux1Wrap.style.display = has1 ? 'flex' : 'none';
    aux2Wrap.style.display = has2 ? 'flex' : 'none';
    aux1LabelEl.textContent = l1;
    aux1ValueEl.textContent = v1;
    aux2LabelEl.textContent = l2;
    aux2ValueEl.textContent = v2;
  }

  [aux1LabelInput, aux1ValueInput, aux2LabelInput, aux2ValueInput].forEach(el => {
    el.addEventListener('input', updateAuxPreview);
  });

  // ── Alignment buttons (inline, per subfield) ──────────────────────
  document.querySelectorAll('.ip-align-inline').forEach(group => {
    const fieldId   = group.dataset.field;
    const subfield  = group.dataset.subfield; // 'label' | 'value'
    group.querySelectorAll('.ip-aln').forEach(btn => {
      btn.addEventListener('click', () => {
        fieldAlign[fieldId][subfield] = btn.dataset.align;
        group.querySelectorAll('.ip-aln').forEach(b => b.classList.remove('ip-aln--active'));
        btn.classList.add('ip-aln--active');
        applyFieldAlign(fieldId);
      });
    });
  });

  applyFieldAlign('sec1');
  applyFieldAlign('sec2');
  applyFieldAlign('aux1');
  applyFieldAlign('aux2');

  // ── Carrier validation ─────────────────────────────────────────────
  function isValidCarrier(v) {
    return /^\/[A-Z0-9+\-.]{7}$/.test(v);
  }

  carrierInput.addEventListener('input', () => {
    const raw = carrierInput.value;
    carrierId = raw.length > 0 ? (raw[0] === '/' ? '/' + raw.slice(1).toUpperCase() : raw.toUpperCase()) : '';
    carrierInput.value = carrierId;
    cardNumber.textContent = carrierId || '––';
    barcodeAlt.textContent = carrierId || '––';
    carrierError.textContent = (carrierId && !isValidCarrier(carrierId)) ? COPY.errorInvalid : '';
    cta.disabled = !isValidCarrier(carrierId);
    updateBarcode();
  });

  // ── Gradient theme picker ──────────────────────────────────────────
  const gradientGrid = document.getElementById('gradient-grid');
  let selectedGradientId = 'midnight'; // default

  function applyGradientTheme(theme) {
    selectedGradientId = theme.id;
    if (theme.css) {
      cardBg.style.background = theme.css;
      currentGradient = theme.css;
      // Use the 'from' colour for the solid pass background
      if (theme.from) {
        currentBgColor = theme.from;
        bgColorInput.value = theme.from;
        bgColorHex.textContent = theme.from;
      }
      if (theme.fg) {
        currentFgColor = theme.fg;
        fgColorInput.value = theme.fg;
        fgColorHex.textContent = theme.fg;
        cardContent.style.color = theme.fg;
        updateBarcode();
      }
    } else {
      // 'none' = solid — restore picker value
      currentGradient = '';
      cardBg.style.background = currentBgColor;
    }
    // Update active state
    gradientGrid.querySelectorAll('.ip-gradient-btn').forEach(b => {
      b.classList.toggle('ip-gradient-btn--active', b.dataset.id === theme.id);
    });
  }

  function renderGradientGrid() {
    gradientGrid.innerHTML = '';
    GRADIENTS.forEach(theme => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ip-gradient-btn' + (theme.id === selectedGradientId ? ' ip-gradient-btn--active' : '');
      btn.dataset.id = theme.id;
      btn.title = theme.label;
      // Swatch: mini preview of the gradient (or solid checker for 'none')
      const swatch = document.createElement('span');
      swatch.className = 'ip-gradient-swatch';
      if (theme.css) {
        swatch.style.background = theme.css;
      } else {
        swatch.style.background = 'var(--bg2)';
        swatch.style.border = '1px dashed var(--line2)';
      }
      const label = document.createElement('span');
      label.className = 'ip-gradient-label';
      label.textContent = theme.label;
      btn.appendChild(swatch);
      btn.appendChild(label);
      btn.addEventListener('click', () => applyGradientTheme(theme));
      gradientGrid.appendChild(btn);
    });
    // Apply default theme on init
    applyGradientTheme(GRADIENTS.find(g => g.id === selectedGradientId));
  }

  renderGradientGrid();

  // ── Background color ───────────────────────────────────────────────
  bgColorInput.addEventListener('input', () => {
    currentBgColor = bgColorInput.value;
    bgColorHex.textContent = currentBgColor;
    // Switching to custom colour clears gradient
    currentGradient = '';
    selectedGradientId = 'none';
    cardBg.style.background = currentBgColor;
    gradientGrid.querySelectorAll('.ip-gradient-btn').forEach(b => {
      b.classList.toggle('ip-gradient-btn--active', b.dataset.id === 'none');
    });
  });

  // ── Foreground color ───────────────────────────────────────────────
  fgColorInput.addEventListener('input', () => {
    currentFgColor = fgColorInput.value;
    fgColorHex.textContent = currentFgColor;
    cardContent.style.color = currentFgColor;
    updateBarcode();
  });
  cardContent.style.color = currentFgColor;

  // ── 3D tilt (mouse on desktop, gyroscope on mobile) ────────────────
  const card = document.getElementById('wallet-card');
  let tiltEnabled = false;

  function applyTilt(rx, ry) {
    card.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
    const glareX = 50 + ry * 2;
    const glareY = 50 - rx * 2;
    cardGlare.style.background = `radial-gradient(circle at ${glareX}% ${glareY}%, rgba(255,255,255,0.22) 0%, transparent 65%)`;
  }

  function resetTilt() {
    card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)';
    cardGlare.style.background = 'none';
  }

  cardScene.addEventListener('mousemove', e => {
    const rect = cardScene.getBoundingClientRect();
    const rx = ((e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2)) * -10;
    const ry = ((e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2)) * 10;
    applyTilt(rx, ry);
  });
  cardScene.addEventListener('mouseleave', resetTilt);

  function attachGyro() {
    tiltEnabled = true;
    if (tiltHint) tiltHint.style.display = 'block';
    window.addEventListener('deviceorientation', e => {
      if (!tiltEnabled) return;
      const rx = Math.max(-15, Math.min(15, (e.beta ?? 0) - 45)) * 0.5;
      const ry = Math.max(-15, Math.min(15, e.gamma ?? 0)) * 0.5;
      applyTilt(rx, ry);
    });
  }

  function requestGyro() {
    if (typeof DeviceOrientationEvent === 'undefined') return;
    if (typeof DeviceOrientationEvent.requestPermission === 'function') {
      DeviceOrientationEvent.requestPermission()
        .then(state => { if (state === 'granted') attachGyro(); })
        .catch(() => {});
    } else {
      attachGyro();
    }
  }

  const isIOS = /iphone|ipad/i.test(navigator.userAgent);
  const isMobile = /iphone|ipad|android/i.test(navigator.userAgent);

  if (isMobile) card.addEventListener('click', requestGyro, { once: true });
  if (!isIOS) iosNote.textContent = COPY.iosOnly;

  // ── Generate pass ──────────────────────────────────────────────────
  cta.addEventListener('click', async () => {
    if (!isValidCarrier(carrierId)) return;

    const originalText = cta.textContent;
    cta.textContent = COPY.adding;
    cta.disabled = true;

    try {
      // Render selected icon to PNG (58x58 @2x on coloured circle background)
      const iconPng = await renderIconToPng(selectedIconId, currentBgColor, currentFgColor);

      const ALIGN_MAP = { left: 'PKTextAlignmentLeft', center: 'PKTextAlignmentCenter', right: 'PKTextAlignmentRight' };

      const secFields = [
        { key: 'sec1', label: sec1LabelInput.value.trim() || ' ', value: sec1ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec1.value] },
        { key: 'sec2', label: sec2LabelInput.value.trim() || ' ', value: sec2ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec2.value] },
      ];

      const auxFields = [];
      const l1 = aux1LabelInput.value.trim(), v1 = aux1ValueInput.value.trim();
      const l2 = aux2LabelInput.value.trim(), v2 = aux2ValueInput.value.trim();
      if (l1 || v1) auxFields.push({ key: 'aux1', label: l1 || ' ', value: v1 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux1.value] });
      if (l2 || v2) auxFields.push({ key: 'aux2', label: l2 || ' ', value: v2 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux2.value] });

      const res = await fetch('/api/generate-pass', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          carrierId,
          backgroundColor: currentBgColor,
          foregroundColor: currentFgColor,
          labelColor: currentFgColor,
          logoText: logoTextInput.value.trim() || COPY.logoTextPH,
          secFields,
          iconPng,
          auxFields,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        carrierError.textContent = err.error ?? COPY.errorServer;
        return;
      }

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `invoice-${carrierId}.pkpass`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch {
      carrierError.textContent = COPY.errorServer;
    } finally {
      cta.textContent = originalText;
      cta.disabled = !isValidCarrier(carrierId);
    }
  });
</script>

