    adding: 'Generating…',
    errorInvalid: 'Invalid format: must start with / followed by 7 uppercase letters, digits, or symbols (e.g. /KPEHNLS)',
    errorServer: 'Server error — please try again',
    iosOnly: 'Requires iPhone to add to Apple Wallet',
    tiltHint: 'Tilt your device to see the 3D light effect',
