    sec1ValuePH: '內容（如：Milifix）',
    sec2Label: '欄位 2（右）',
    sec2LabelPH: '標籤（如：類型）',
    sec2ValuePH: '內容（如：統一發票）',
    aux1Label: '自訂欄位 1',
    aux1LabelPH: '標籤（如：日期）',
    aux1ValuePH: '內容（如：2026/06）',
    aux2Label: '自訂欄位 2',
    aux2LabelPH: '標籤（如：備註）',
    aux2ValuePH: '內容',
    alignLeft: '左',
    alignCenter: '中',
    alignRight: '右',
    previewLabel: '卡片預覽',
    previewCarrier: '載具號碼',
    previewOrg: '台灣統一發票',
    secOrgLabel: '發行單位',
    secOrgValue: 'Milifix',
    secTypeLabel: '類型',
    secTypeValue: '統一發票',
    addToWallet: '加入 Apple Wallet',
    adding: '打包中…',
    errorInvalid: '格式錯誤：需為 / 開頭接 7 個大寫英數字或符號，例如 /KPEHNLS',
    errorServer: '伺服器錯誤，請稍後再試',
    iosOnly: '需要 iPhone 才能加入 Apple Wallet',
    tiltHint: '傾斜裝置看 3D 光影效果',
    back: '← Milifix',
    footer: '© 2026 Milifix. All rights reserved.',
  },
  en: {
    htmlTitle: 'Invoice Pass — Your personalized Taiwan invoice carrier card',
    metaDesc: 'Enter your Taiwan invoice carrier ID, pick a background and color, and generate your own Apple Wallet card in seconds.',
    eyebrow: 'Taiwan Invoice Carrier',
    h1a: 'Make your invoice',
    h1b: 'carrier actually cool',
    heroDesc: 'Enter your carrier ID, pick a background, tweak the colors — and get an Apple Wallet card worth showing off.',
    stepLabel: 'How it works',
    step1: 'Enter your carrier ID',
    step2: 'Design your card',
    step3: 'Add to Wallet',
    inputLabel: 'Carrier ID',
    inputPlaceholder: '/KPEHNLS',
    inputHint: '/ followed by 7 uppercase letters, digits, or symbols (8 chars total)',
    bgLabel: 'Background Color',
    colorLabel: 'Text Color',
    gradientLabel: 'Gradient Theme',
    iconLabel: 'Card Icon',
    logoTextLabel: 'Card Title',
    logoTextPH: 'Invoice Pass',
    sec1Label: 'Field 1 (Left)',
    sec1LabelPH: 'Label (e.g. Issued by)',
    sec1ValuePH: 'Value (e.g. Milifix)',
    sec2Label: 'Field 2 (Right)',
    sec2LabelPH: 'Label (e.g. Type)',
    sec2ValuePH: 'Value (e.g. Invoice)',
    aux1Label: 'Custom Field 1',
    aux1LabelPH: 'Label (e.g. Date)',
    aux1ValuePH: 'Value (e.g. 2026/06)',
    aux2Label: 'Custom Field 2',
    aux2LabelPH: 'Label (e.g. Note)',
    aux2ValuePH: 'Value',
    alignLeft: 'L',
    alignCenter: 'C',
    alignRight: 'R',
    previewLabel: 'Card Preview',
    previewCarrier: 'Carrier ID',
    previewOrg: 'Taiwan Invoice',
    secOrgLabel: 'Issued by',
    secOrgValue: 'Milifix',
    secTypeLabel: 'Type',
    secTypeValue: 'Invoice',
    addToWallet: 'Add to Apple Wallet',
    adding: 'Generating…',
    errorInvalid: 'Invalid format: must start with / followed by 7 uppercase letters, digits, or symbols (e.g. /KPEHNLS)',
    errorServer: 'Server error — please try again',
    iosOnly: 'Requires iPhone to add to Apple Wallet',
    tiltHint: 'Tilt your device to see the 3D light effect',
    back: '← Milifix',
    footer: '© 2026 Milifix. All rights reserved.',
  },
  ja: {
    htmlTitle: 'Invoice Pass — あなた専用の発票キャリアカード',
    metaDesc: '台湾の発票キャリアIDを入力して、背景とカラーを選ぶだけ。数秒でApple Walletカードを生成できます。',
    eyebrow: '台湾発票キャリア',
    h1a: '発票キャリアを',
    h1b: 'あなた色に変える',
    heroDesc: 'キャリアIDを入力して、背景を選んで、色を調整する——数秒で見せたくなる Apple Wallet カードの完成。',
    stepLabel: '使い方',
    step1: 'キャリアIDを入力',
    step2: 'デザインを選ぶ',
    step3: 'Walletに追加',
    inputLabel: 'キャリアID',
    inputPlaceholder: '/KPEHNLS',
    inputHint: '/ で始まり、大文字・数字・記号7文字、計8文字',
    bgLabel: '背景カラー',
    colorLabel: 'テキストカラー',
    gradientLabel: 'グラデーションテーマ',
    iconLabel: 'カードアイコン',
    logoTextLabel: 'カードタイトル',
    logoTextPH: 'Invoice Pass',
    sec1Label: 'フィールド 1（左）',
    sec1LabelPH: 'ラベル（例：発行元）',
    sec1ValuePH: '内容（例：Milifix）',
    sec2Label: 'フィールド 2（右）',
    sec2LabelPH: 'ラベル（例：種別）',
    sec2ValuePH: '内容（例：統一発票）',
    aux1Label: 'カスタムフィールド 1',
    aux1LabelPH: 'ラベル（例：日付）',
    aux1ValuePH: '内容（例：2026/06）',
    aux2Label: 'カスタムフィールド 2',
    aux2LabelPH: 'ラベル（例：メモ）',
    aux2ValuePH: '内容',
    alignLeft: '左',
    alignCenter: '中',
    alignRight: '右',
    previewLabel: 'カードプレビュー',
    previewCarrier: 'キャリアID',
    previewOrg: '台湾統一発票',
    secOrgLabel: '発行元',
    secOrgValue: 'Milifix',
    secTypeLabel: '種別',
    secTypeValue: '統一発票',
    addToWallet: 'Apple Walletに追加',
    adding: '生成中…',
    errorInvalid: '形式エラー：/ で始まり大文字・数字・記号7文字（例：/KPEHNLS）',
    errorServer: 'サーバーエラーが発生しました。しばらくしてからお試しください',
    iosOnly: 'Apple WalletへはiPhoneが必要です',
    tiltHint: 'デバイスを傾けて3Dライトエフェクトを確認',
    back: '← Milifix',
    footer: '© 2026 Milifix. All rights reserved.',
  },
};

const copy = t[lang];
const htmlLang = HTML_LANG[lang];
const copyJson = JSON.stringify({ previewCarrier: copy.previewCarrier, sec1LabelPH: copy.sec1LabelPH, sec1ValuePH: copy.sec1ValuePH, sec2LabelPH: copy.sec2LabelPH, sec2ValuePH: copy.sec2ValuePH, adding: copy.adding, errorInvalid: copy.errorInvalid, errorServer: copy.errorServer, iosOnly: copy.iosOnly, logoTextPH: copy.logoTextPH });
---

<!doctype html>
<html lang={htmlLang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{copy.htmlTitle}</title>
  <meta name="description" content={copy.metaDesc} />
</head>
<body class="portfolio-atmo">

<AmbientBackdrop />
<SiteNav lang={lang} pathname={pathname} />
<PortfolioChrome lang={lang} pathname={pathname} showDock={false} />

<main class="ip-main">

  <!-- Hero -->
  <section class="ip-hero">
    <p class="ip-eyebrow">{copy.eyebrow}</p>
    <h1 class="ip-h1">
      <span class="ip-h1-a">{copy.h1a}</span>
      <span class="ip-h1-b">{copy.h1b}</span>
    </h1>
    <p class="ip-hero-desc">{copy.heroDesc}</p>

    <!-- Step pills -->
    <div class="ip-steps">
      {[copy.step1, copy.step2, copy.step3].map((s, i) => (
        <div class="ip-step">
          <span class="ip-step-num">{i + 1}</span>
          <span class="ip-step-label">{s}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Editor + Preview -->
  <section class="ip-workspace">

    <!-- Left: controls -->
    <div class="ip-controls">

      <!-- Carrier ID input -->
      <div class="ip-field">
        <label for="carrier-input" class="ip-label">{copy.inputLabel}</label>
        <input
          id="carrier-input"
          type="text"
          class="ip-input"
          placeholder={copy.inputPlaceholder}
          maxlength="8"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="none"
          spellcheck="false"
        />
        <span class="ip-hint">{copy.inputHint}</span>
        <span class="ip-error" id="carrier-error" role="alert" aria-live="polite"></span>
      </div>

      <!-- Icon picker -->
      <div class="ip-field">
        <span class="ip-label">{copy.iconLabel}</span>
        <div class="ip-icon-trigger-wrap">
          <button type="button" class="ip-icon-trigger" id="icon-trigger">
            <span class="ip-icon-trigger-preview" id="icon-trigger-preview"></span>
            <span class="ip-icon-trigger-name" id="icon-trigger-name">收據</span>
            <svg class="ip-icon-trigger-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <!-- Icon panel -->
          <div class="ip-icon-panel" id="icon-panel" hidden>
            <div class="ip-icon-search-wrap">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input id="icon-search" type="text" class="ip-icon-search" placeholder="搜尋圖示…" autocomplete="off" />
            </div>
            <div class="ip-icon-grid" id="icon-grid"></div>
          </div>
        </div>
      </div>

      <!-- Card title (logoText) -->
      <div class="ip-field">
        <label for="logo-text-input" class="ip-label">{copy.logoTextLabel}</label>
        <input id="logo-text-input" type="text" class="ip-input" value={lang === 'zh' ? DEFAULT_LOGO_TEXT_ZH : lang === 'ja' ? DEFAULT_LOGO_TEXT_JA : DEFAULT_LOGO_TEXT_EN} maxlength="20" autocomplete="off" />
      </div>

      <!-- Secondary field 1 -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec1Label}</span>
        <div class="ip-inline-row">
          <input id="sec1-label-input" type="text" class="ip-input ip-input--label" value={lang === 'zh' ? DEFAULT_SEC1_LABEL_ZH : lang === 'ja' ? DEFAULT_SEC1_LABEL_JA : DEFAULT_SEC1_LABEL_EN} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec1" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="sec1-value-input" type="text" class="ip-input ip-input--value" value={lang === 'zh' ? DEFAULT_SEC1_VALUE_ZH : lang === 'ja' ? DEFAULT_SEC1_VALUE_JA : DEFAULT_SEC1_VALUE_EN} maxlength="24" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec1" data-subfield="value">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Secondary field 2 -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec2Label}</span>
        <div class="ip-inline-row">
          <input id="sec2-label-input" type="text" class="ip-input ip-input--label" value={lang === 'zh' ? DEFAULT_SEC2_LABEL_ZH : lang === 'ja' ? DEFAULT_SEC2_LABEL_JA : DEFAULT_SEC2_LABEL_EN} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec2" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="sec2-value-input" type="text" class="ip-input ip-input--value" value={lang === 'zh' ? DEFAULT_SEC2_VALUE_ZH : lang === 'ja' ? DEFAULT_SEC2_VALUE_JA : DEFAULT_SEC2_VALUE_EN} maxlength="24" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec2" data-subfield="value">
            <button type="button" class="ip-aln" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln ip-aln--active" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 1 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux1Label}</span>
        <div class="ip-inline-row">
          <input id="aux1-label-input" type="text" class="ip-input ip-input--label" placeholder={copy.aux1LabelPH} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux1" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="aux1-value-input" type="text" class="ip-input ip-input--value" placeholder={copy.aux1ValuePH} maxlength="30" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux1" data-subfield="value">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 2 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux2Label}</span>
        <div class="ip-inline-row">
          <input id="aux2-label-input" type="text" class="ip-input ip-input--label" placeholder={copy.aux2LabelPH} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux2" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="aux2-value-input" type="text" class="ip-input ip-input--value" placeholder={copy.aux2ValuePH} maxlength="30" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux2" data-subfield="value">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Gradient theme picker -->
      <div class="ip-field">
        <span class="ip-label">{copy.gradientLabel}</span>
        <div class="ip-gradient-grid" id="gradient-grid"></div>
      </div>

      <!-- Background color picker -->
      <div class="ip-field ip-field--inline">
        <label for="bg-color-input" class="ip-label">{copy.bgLabel}</label>
        <div class="ip-color-wrap">
          <input id="bg-color-input" type="color" class="ip-color" value={DEFAULT_BG} />
          <span class="ip-color-hex" id="bg-color-hex">{DEFAULT_BG}</span>
        </div>
      </div>

      <!-- Text color picker -->
      <div class="ip-field ip-field--inline">
        <label for="color-input" class="ip-label">{copy.colorLabel}</label>
        <div class="ip-color-wrap">
          <input id="color-input" type="color" class="ip-color" value={DEFAULT_FG} />
          <span class="ip-color-hex" id="color-hex">{DEFAULT_FG}</span>
        </div>
      </div>

      <!-- CTA -->
      <button class="ip-cta" id="add-to-wallet" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        {copy.addToWallet}
      </button>
      <p class="ip-ios-note" id="ios-note"></p>

    </div>

    <!-- Right: card preview -->
    <div class="ip-preview-wrap">
      <p class="ip-preview-label">{copy.previewLabel}</p>
      <div class="ip-card-scene" id="card-scene">
        <div class="ip-card" id="wallet-card">
          <div class="ip-card-bg" id="card-bg" style={`background: ${DEFAULT_BG}`} data-bg={DEFAULT_BG} data-gradient=""></div>
          <div class="ip-card-glare" id="card-glare"></div>
          <div class="ip-card-content" id="card-content">

            <!-- Row 1: header row (icon + logoText left) -->
            <div class="ip-card-row ip-card-row--header">
              <div class="ip-card-logo-wrap">
                <div class="ip-card-icon" id="card-icon"></div>
                <span class="ip-card-logo-text" id="card-logo-text">{lang === 'zh' ? DEFAULT_LOGO_TEXT_ZH : lang === 'ja' ? DEFAULT_LOGO_TEXT_JA : DEFAULT_LOGO_TEXT_EN}</span>
              </div>
            </div>

            <!-- Row 2: primaryField (full width) -->
            <div class="ip-card-row ip-card-row--primary">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="primary-label">{copy.previewCarrier}</span>
                <span class="ip-card-fvalue ip-card-fvalue--lg" id="card-number">––</span>
              </div>
            </div>

            <!-- Row 3: secondaryFields (2 cols) -->
            <div class="ip-card-row ip-card-row--secondary" id="secondary-row">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="sec1-label">{lang === 'zh' ? DEFAULT_SEC1_LABEL_ZH : lang === 'ja' ? DEFAULT_SEC1_LABEL_JA : DEFAULT_SEC1_LABEL_EN}</span>
                <span class="ip-card-fvalue" id="sec1-value">{lang === 'zh' ? DEFAULT_SEC1_VALUE_ZH : lang === 'ja' ? DEFAULT_SEC1_VALUE_JA : DEFAULT_SEC1_VALUE_EN}</span>
              </div>
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="sec2-label">{lang === 'zh' ? DEFAULT_SEC2_LABEL_ZH : lang === 'ja' ? DEFAULT_SEC2_LABEL_JA : DEFAULT_SEC2_LABEL_EN}</span>
                <span class="ip-card-fvalue" id="sec2-value">{lang === 'zh' ? DEFAULT_SEC2_VALUE_ZH : lang === 'ja' ? DEFAULT_SEC2_VALUE_JA : DEFAULT_SEC2_VALUE_EN}</span>
              </div>
            </div>

            <!-- Row 4: auxiliaryFields (up to 3 cols) -->
            <div class="ip-card-row ip-card-row--aux" id="aux-row" style="display:none">
              <div class="ip-card-field" id="aux1-wrap">
                <span class="ip-card-flabel" id="aux1-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux1-value"></span>
              </div>
              <div class="ip-card-field" id="aux2-wrap" style="display:none">
                <span class="ip-card-flabel" id="aux2-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux2-value"></span>
              </div>
            </div>

            <!-- Spacer: pushes barcode to bottom -->
            <div class="ip-card-spacer"></div>

            <!-- Row 5: barcode (full width, bottom) -->
            <div class="ip-card-row ip-card-row--barcode">
              <div class="ip-barcode-wrap" id="barcode-wrap">
                <canvas id="barcode-canvas" class="ip-barcode" width="320" height="48"></canvas>
                <span class="ip-barcode-alt" id="barcode-alt">––</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <p class="ip-tilt-hint" id="tilt-hint" style="display:none">{copy.tiltHint}</p>
    </div>

  </section>

  <footer class="ip-footer">
    <a href="/" class="ip-back">{copy.back}</a>
    <span>{copy.footer}</span>
  </footer>

</main>

<script define:vars={{ copyJson }}>
  const COPY = JSON.parse(copyJson);

  // ── State ──────────────────────────────────────────────────────────
