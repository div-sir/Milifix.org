    logoTextLabel: 'タイトル',
    logoTextPH: 'Invoice Pass',
    sec1Label: 'メインフィールド 1',
    sec1LabelPH: 'ラベル',
    sec1ValuePH: '内容',
    sec2Label: 'メインフィールド 2',
    sec2LabelPH: 'ラベル',
    sec2ValuePH: '内容',
    aux1Label: 'カスタムフィールド 1',
    aux1LabelPH: 'ラベル',
    aux1ValuePH: '内容',
    aux2Label: 'カスタムフィールド 2',
    aux2LabelPH: 'ラベル',
    aux2ValuePH: '内容',
