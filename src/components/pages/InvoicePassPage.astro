const copy = t[lang];
const htmlLang = HTML_LANG[lang];
const copyJson = JSON.stringify({ previewCarrier: copy.previewCarrier, sec1LabelPH: copy.sec1LabelPH, sec1ValuePH: copy.sec1ValuePH, sec2LabelPH: copy.sec2LabelPH, sec2ValuePH: copy.sec2ValuePH, adding: copy.adding, errorInvalid: copy.errorInvalid, errorServer: copy.errorServer, iosOnly: copy.iosOnly, logoTextPH: copy.logoTextPH });
---

<!doctype html>
<html lang={htmlLang} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{copy.htmlTitle}</title>
  <meta name="description" content={copy.metaDesc} />
</head>
<body class="portfolio-atmo">

<AmbientBackdrop />
<SiteNav lang={lang} pathname={pathname} />
<PortfolioChrome lang={lang} pathname={pathname} showDock={false} />

<main class="ip-main">

  <!-- Hero -->
  <section class="ip-hero">
    <p class="ip-eyebrow">{copy.eyebrow}</p>
    <h1 class="ip-h1">
      <span class="ip-h1-a">{copy.h1a}</span>
      <span class="ip-h1-b">{copy.h1b}</span>
    </h1>
    <p class="ip-hero-desc">{copy.heroDesc}</p>

    <!-- Step pills -->
    <div class="ip-steps">
      {[copy.step1, copy.step2, copy.step3].map((s, i) => (
        <div class="ip-step">
          <span class="ip-step-num">{i + 1}</span>
          <span class="ip-step-label">{s}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Editor + Preview -->
  <section class="ip-workspace">

    <!-- Left: controls -->
    <div class="ip-controls">

      <!-- Carrier ID input -->
      <div class="ip-field">
        <label for="carrier-input" class="ip-label">{copy.inputLabel}</label>
        <input
          id="carrier-input"
          type="text"
          class="ip-input"
          placeholder={copy.inputPlaceholder}
          maxlength="8"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="none"
          spellcheck="false"
        />
        <span class="ip-hint">{copy.inputHint}</span>
        <span class="ip-error" id="carrier-error" role="alert" aria-live="polite"></span>
      </div>

      <!-- Icon picker -->
      <div class="ip-field">
        <span class="ip-label">{copy.iconLabel}</span>
        <div class="ip-icon-grid" id="icon-grid">
          <!-- icons injected by JS -->
        </div>
      </div>

      <!-- Card title (logoText) -->
      <div class="ip-field">
        <label for="logo-text-input" class="ip-label">{copy.logoTextLabel}</label>
        <input
          id="logo-text-input"
          type="text"
          class="ip-input"
          placeholder={copy.logoTextPH}
          maxlength="20"
          autocomplete="off"
        />
      </div>

      <!-- Secondary field 1 (left) -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec1Label}</span>
        <div class="ip-field-row">
          <div class="ip-aux-row">
            <input id="sec1-label-input" type="text" class="ip-input ip-input--half" placeholder={copy.sec1LabelPH} maxlength="20" autocomplete="off" />
            <input id="sec1-value-input" type="text" class="ip-input ip-input--half" placeholder={copy.sec1ValuePH} maxlength="24" autocomplete="off" />
          </div>
          <div class="ip-align-btns" data-field="sec1">
            <button type="button" class="ip-align-btn ip-align-btn--active" data-align="left" title="靠左">&#8676;</button>
            <button type="button" class="ip-align-btn" data-align="center" title="置中">&#8596;</button>
            <button type="button" class="ip-align-btn" data-align="right" title="靠右">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Secondary field 2 (right) -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec2Label}</span>
        <div class="ip-field-row">
          <div class="ip-aux-row">
            <input id="sec2-label-input" type="text" class="ip-input ip-input--half" placeholder={copy.sec2LabelPH} maxlength="20" autocomplete="off" />
            <input id="sec2-value-input" type="text" class="ip-input ip-input--half" placeholder={copy.sec2ValuePH} maxlength="24" autocomplete="off" />
          </div>
          <div class="ip-align-btns" data-field="sec2">
            <button type="button" class="ip-align-btn" data-align="left" title="靠左">&#8676;</button>
            <button type="button" class="ip-align-btn" data-align="center" title="置中">&#8596;</button>
            <button type="button" class="ip-align-btn ip-align-btn--active" data-align="right" title="靠右">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 1 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux1Label}</span>
        <div class="ip-field-row">
          <div class="ip-aux-row">
            <input id="aux1-label-input" type="text" class="ip-input ip-input--half" placeholder={copy.aux1LabelPH} maxlength="20" autocomplete="off" />
            <input id="aux1-value-input" type="text" class="ip-input ip-input--half" placeholder={copy.aux1ValuePH} maxlength="30" autocomplete="off" />
          </div>
          <div class="ip-align-btns" data-field="aux1">
            <button type="button" class="ip-align-btn ip-align-btn--active" data-align="left" title="靠左">&#8676;</button>
            <button type="button" class="ip-align-btn" data-align="center" title="置中">&#8596;</button>
            <button type="button" class="ip-align-btn" data-align="right" title="靠右">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 2 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux2Label}</span>
        <div class="ip-field-row">
          <div class="ip-aux-row">
            <input id="aux2-label-input" type="text" class="ip-input ip-input--half" placeholder={copy.aux2LabelPH} maxlength="20" autocomplete="off" />
            <input id="aux2-value-input" type="text" class="ip-input ip-input--half" placeholder={copy.aux2ValuePH} maxlength="30" autocomplete="off" />
          </div>
          <div class="ip-align-btns" data-field="aux2">
            <button type="button" class="ip-align-btn ip-align-btn--active" data-align="left" title="靠左">&#8676;</button>
            <button type="button" class="ip-align-btn" data-align="center" title="置中">&#8596;</button>
            <button type="button" class="ip-align-btn" data-align="right" title="靠右">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Background color picker -->
      <div class="ip-field ip-field--inline">
        <label for="bg-color-input" class="ip-label">{copy.bgLabel}</label>
        <div class="ip-color-wrap">
          <input id="bg-color-input" type="color" class="ip-color" value={DEFAULT_BG} />
          <span class="ip-color-hex" id="bg-color-hex">{DEFAULT_BG}</span>
        </div>
      </div>

      <!-- Text color picker -->
      <div class="ip-field ip-field--inline">
        <label for="color-input" class="ip-label">{copy.colorLabel}</label>
        <div class="ip-color-wrap">
          <input id="color-input" type="color" class="ip-color" value="#ffffff" />
          <span class="ip-color-hex" id="color-hex">#ffffff</span>
        </div>
      </div>

      <!-- CTA -->
      <button class="ip-cta" id="add-to-wallet" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        {copy.addToWallet}
      </button>
      <p class="ip-ios-note" id="ios-note"></p>

    </div>

    <!-- Right: card preview -->
    <div class="ip-preview-wrap">
      <p class="ip-preview-label">{copy.previewLabel}</p>
      <div class="ip-card-scene" id="card-scene">
        <div class="ip-card" id="wallet-card">
          <div class="ip-card-bg" id="card-bg" style={`background: ${DEFAULT_BG}`}></div>
          <div class="ip-card-glare" id="card-glare"></div>
          <div class="ip-card-content" id="card-content">

            <!-- Row 1: header row (icon + logoText left) -->
            <div class="ip-card-row ip-card-row--header">
              <div class="ip-card-logo-wrap">
                <div class="ip-card-icon" id="card-icon"></div>
                <span class="ip-card-logo-text" id="card-logo-text">Invoice Pass</span>
              </div>
            </div>

            <!-- Row 2: primaryField (full width) -->
            <div class="ip-card-row ip-card-row--primary">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="primary-label">{copy.previewCarrier}</span>
                <span class="ip-card-fvalue ip-card-fvalue--lg" id="card-number">––</span>
              </div>
            </div>

            <!-- Row 3: secondaryFields (2 cols) -->
            <div class="ip-card-row ip-card-row--secondary" id="secondary-row">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="sec1-label">{copy.secOrgLabel}</span>
                <span class="ip-card-fvalue" id="sec1-value">{copy.secOrgValue}</span>
              </div>
              <div class="ip-card-field ip-card-field--right">
                <span class="ip-card-flabel" id="sec2-label">{copy.secTypeLabel}</span>
                <span class="ip-card-fvalue" id="sec2-value">{copy.secTypeValue}</span>
              </div>
            </div>

            <!-- Row 4: auxiliaryFields (up to 3 cols) -->
            <div class="ip-card-row ip-card-row--aux" id="aux-row" style="display:none">
              <div class="ip-card-field" id="aux1-wrap">
                <span class="ip-card-flabel" id="aux1-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux1-value"></span>
              </div>
              <div class="ip-card-field" id="aux2-wrap" style="display:none">
                <span class="ip-card-flabel" id="aux2-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux2-value"></span>
              </div>
            </div>

            <!-- Spacer: pushes barcode to bottom -->
            <div class="ip-card-spacer"></div>

            <!-- Row 5: barcode (full width, bottom) -->
            <div class="ip-card-row ip-card-row--barcode">
              <div class="ip-barcode-wrap" id="barcode-wrap">
                <canvas id="barcode-canvas" class="ip-barcode" width="320" height="48"></canvas>
                <span class="ip-barcode-alt" id="barcode-alt">––</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <p class="ip-tilt-hint" id="tilt-hint" style="display:none">{copy.tiltHint}</p>
    </div>

  </section>

  <footer class="ip-footer">
    <a href="/" class="ip-back">{copy.back}</a>
    <span>{copy.footer}</span>
  </footer>

</main>

<script define:vars={{ copyJson }}>
  const COPY = JSON.parse(copyJson);

  // ── State ──────────────────────────────────────────────────────────
  let currentBgColor = '#1a1a2e';
  let currentFgColor = '#ffffff';
  let carrierId = '';
  let selectedIconId = 'receipt';
  // alignment per field: 'left' | 'center' | 'right'
  const fieldAlign = { sec1: 'left', sec2: 'right', aux1: 'left', aux2: 'left' };

  // ── Lucide icons (24 selected) — SVG path data only ───────────────
  const ICONS = [
    { id: 'receipt',       label: '收據',   path: 'M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1zm3 5h10M7 12h10M7 15h5' },
    { id: 'wallet',        label: '錢包',   path: 'M21 12V7H5a2 2 0 0 1 0-4h14v4M21 12v5H5a2 2 0 0 0 0 4h14v-4M3 5v14' },
    { id: 'credit-card',   label: '信用卡', path: 'M2 5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2zM2 10h20M7 15h.01M11 15h2' },
    { id: 'star',          label: '星星',   path: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z' },
    { id: 'tag',           label: '標籤',   path: 'M12 2H2v10l9.29 9.29a1 1 0 0 0 1.41 0l9.59-9.59a1 1 0 0 0 0-1.41zM7 7h.01' },
    { id: 'gift',          label: '禮物',   path: 'M20 12v10H4V12M22 7H2v5h20zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7' },
    { id: 'shopping-bag',  label: '購物袋', path: 'M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0' },
    { id: 'coffee',        label: '咖啡',   path: 'M17 8h1a4 4 0 1 1 0 8h-1M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4zM6 2v2M10 2v2M14 2v2' },
    { id: 'utensils',      label: '餐具',   path: 'M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7' },
    { id: 'car',           label: '汽車',   path: 'M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2M7 17a2 2 0 1 0 4 0 2 2 0 0 0-4 0m8 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0' },
    { id: 'fuel',          label: '加油',   path: 'M3 22V6l10-3v19M3 10h10M13 22V11l7 4v7M13 14h7' },
    { id: 'train',         label: '捷運',   path: 'M12 2c-4 0-8 .5-8 4v9.5A3.5 3.5 0 0 0 7.5 19L6 21h1.5l1-1.5h7L16.5 21H18l-1.5-2A3.5 3.5 0 0 0 20 15.5V6c0-3.5-4-4-8-4zM6.5 17A1.5 1.5 0 1 1 8 15.5 1.5 1.5 0 0 1 6.5 17zm11 0A1.5 1.5 0 1 1 19 15.5 1.5 1.5 0 0 1 17.5 17zM4 11V7h16v4' },
    { id: 'plane',         label: '飛機',   path: 'M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.1z' },
    { id: 'hotel',         label: '飯店',   path: 'M3 22V11l9-9 9 9v11H3zm6 0v-7h6v7' },
    { id: 'ticket',        label: '票券',   path: 'M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2zm11 1-1 2h2l-1.5 3' },
    { id: 'landmark',      label: '建築',   path: 'M3 22h18M6 18v-7M10 18v-7M14 18v-7M18 18v-7M12 2 2 7h20z' },
    { id: 'package',       label: '包裹',   path: 'M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16zM3.27 6.96 12 12.01l8.73-5.05M12 22.08V12' },
    { id: 'zap',           label: '閃電',   path: 'M13 2 3 14h9l-1 8 10-12h-9z' },
    { id: 'heart',         label: '愛心',   path: 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z' },
    { id: 'music',         label: '音樂',   path: 'M9 18V5l12-2v13M9 9l12-2M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm15-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6' },
    { id: 'camera',        label: '相機',   path: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2zM12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8' },
    { id: 'book',          label: '書本',   path: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5z' },
    { id: 'activity',      label: '活動',   path: 'M22 12h-4l-3 9L9 3l-3 9H2' },
    { id: 'gem',           label: '寶石',   path: 'M12 2L2 7l2 12 8 3 8-3 2-12zM2 7l10 5 10-5M12 12v10' },
  ];

  // ── Element refs ───────────────────────────────────────────────────
  const carrierInput     = /** @type {HTMLInputElement} */ (document.getElementById('carrier-input'));
  const carrierError     = document.getElementById('carrier-error');
  const bgColorInput     = /** @type {HTMLInputElement} */ (document.getElementById('bg-color-input'));
  const bgColorHex       = document.getElementById('bg-color-hex');
  const fgColorInput     = /** @type {HTMLInputElement} */ (document.getElementById('color-input'));
  const fgColorHex       = document.getElementById('color-hex');
  const cta              = /** @type {HTMLButtonElement} */ (document.getElementById('add-to-wallet'));
  const iosNote          = document.getElementById('ios-note');
  const cardBg           = document.getElementById('card-bg');
  const cardGlare        = document.getElementById('card-glare');
  const cardContent      = document.getElementById('card-content');
  const cardNumber       = document.getElementById('card-number');
  const barcodeAlt       = document.getElementById('barcode-alt');
  const cardScene        = document.getElementById('card-scene');
  const tiltHint         = document.getElementById('tilt-hint');
  const barcodeCanvas    = /** @type {HTMLCanvasElement} */ (document.getElementById('barcode-canvas'));
  const cardLogoText     = document.getElementById('card-logo-text');
  const cardIconEl       = document.getElementById('card-icon');
  const iconGrid         = document.getElementById('icon-grid');
  const logoTextInput    = /** @type {HTMLInputElement} */ (document.getElementById('logo-text-input'));
  // sec1
  const sec1LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec1-label-input'));
  const sec1ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec1-value-input'));
  const sec1LabelEl      = document.getElementById('sec1-label');
  const sec1ValueEl      = document.getElementById('sec1-value');
  // sec2
  const sec2LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec2-label-input'));
  const sec2ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec2-value-input'));
  const sec2LabelEl      = document.getElementById('sec2-label');
  const sec2ValueEl      = document.getElementById('sec2-value');
  // aux1
  const aux1LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux1-label-input'));
  const aux1ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux1-value-input'));
  const aux1LabelEl      = document.getElementById('aux1-label');
  const aux1ValueEl      = document.getElementById('aux1-value');
  // aux2
  const aux2LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux2-label-input'));
  const aux2ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux2-value-input'));
  const aux2LabelEl      = document.getElementById('aux2-label');
  const aux2ValueEl      = document.getElementById('aux2-value');
  const auxRow           = document.getElementById('aux-row');
  const aux1Wrap         = document.getElementById('aux1-wrap');
  const aux2Wrap         = document.getElementById('aux2-wrap');

  // ── Code 39 barcode renderer ───────────────────────────────────────
  // Each char encoded as 5 bars + 4 spaces (9 elements), narrow=1 wide=3
  const C39 = {
    '0':'nnnwwnwnn','1':'wnnwnnnnw','2':'nnwwnnnnw','3':'wnwwnnnnn',
    '4':'nnnwwnnnw','5':'wnnwwnnnn','6':'nnwwwnnnn','7':'nnnwnnwnw',
    'A':'wnnnnwnnw','B':'nnwnnwnnw','C':'wnwnnwnnn','D':'nnnnwwnnw',
    'E':'wnnnwwnnn','F':'nnwnwwnnn','G':'nnnnnwwnw','H':'wnnnnwwnn',
    'I':'nnwnnwwnn','J':'nnnnwwwnn','K':'wnnnnnnww','L':'nnwnnnnww',
    'M':'wnwnnnnwn','N':'nnnnwnnww','O':'wnnnwnnwn','P':'nnwnwnnwn',
    'Q':'nnnnnnwww','R':'wnnnnnwwn','S':'nnwnnnwwn','T':'nnnnwnwwn',
    'U':'wwnnnnnnw','V':'nwwnnnnnw','W':'wwwnnnnnn','X':'nwnnwnnnw',
    'Y':'wwnnwnnnn','Z':'nwwnwnnnn',
    '+':'nwnnnnwnw','-':'nwnnnnnnw','.':'wwnnnnnnn',
    ' ':'nwnnwnnnn','*':'nwnnwnnnw',
    '/':'nwnnnnwnn', // Code 39 special
  };

  function drawCode39(canvas, text, fgColor) {
    const ctx = canvas.getContext('2d');
    const encoded = '*' + text + '*';
    const narrow = 1.4;
    const wide = narrow * 3;
    const gap = narrow; // inter-char gap (white)
    let totalWidth = 0;
    for (const ch of encoded) {
      const pattern = C39[ch];
      if (!pattern) continue;
      for (const w of pattern) totalWidth += (w === 'w' ? wide : narrow);
      totalWidth += gap;
    }
    totalWidth -= gap;

    const h = canvas.height;
    const scaleX = canvas.width / totalWidth;
    ctx.clearRect(0, 0, canvas.width, h);

    let x = 0;
    for (let ci = 0; ci < encoded.length; ci++) {
      const pattern = C39[encoded[ci]];
      if (!pattern) continue;
      for (let i = 0; i < pattern.length; i++) {
        const w = (pattern[i] === 'w' ? wide : narrow) * scaleX;
        if (i % 2 === 0) { // even = bar
          ctx.fillStyle = fgColor;
          ctx.fillRect(Math.round(x), 0, Math.ceil(w), h);
        }
        x += w;
      }
      if (ci < encoded.length - 1) x += gap * scaleX;
    }
  }

  function updateBarcode() {
    drawCode39(barcodeCanvas, carrierId || '/XXXXXXX', '#1a1a1a');
  }
  updateBarcode();

  // ── Icon → PNG (for pkpass logo) ──────────────────────────────────
  async function renderIconToPng(iconId, bgColor, fgColor) {
    const icon = ICONS.find(i => i.id === iconId);
    if (!icon) return null;
    const size = 58;
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    const ctx = c.getContext('2d');
    // filled circle background
    ctx.fillStyle = bgColor;
    ctx.beginPath();
    ctx.arc(size/2, size/2, size/2, 0, Math.PI*2);
    ctx.fill();
    // draw SVG icon via Image + Blob
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${fgColor}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="${icon.path}"/></svg>`;
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    await new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => { ctx.drawImage(img, 7, 7, size - 14, size - 14); resolve(); };
      img.onerror = reject;
      img.src = url;
    });
    URL.revokeObjectURL(url);
    // return base64 PNG without data: prefix
    return c.toDataURL('image/png').split(',')[1];
  }

  // ── Icon picker ────────────────────────────────────────────────────
  function makeSvg(pathData, size = 20, color = 'currentColor') {
    return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="${pathData}"/></svg>`;
  }

  function renderIconGrid() {
    iconGrid.innerHTML = '';
    ICONS.forEach(icon => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ip-icon-btn' + (icon.id === selectedIconId ? ' ip-icon-btn--active' : '');
      btn.title = icon.label;
      btn.dataset.id = icon.id;
      btn.innerHTML = makeSvg(icon.path, 20);
      btn.addEventListener('click', () => {
        selectedIconId = icon.id;
        document.querySelectorAll('.ip-icon-btn').forEach(b => b.classList.remove('ip-icon-btn--active'));
        btn.classList.add('ip-icon-btn--active');
        updateCardIcon();
      });
      iconGrid.appendChild(btn);
    });
  }

  function updateCardIcon() {
    const icon = ICONS.find(i => i.id === selectedIconId);
    if (!icon) return;
    cardIconEl.innerHTML = makeSvg(icon.path, 14, 'currentColor');
  }

  renderIconGrid();
  updateCardIcon();

  // ── Logo text (card title) ─────────────────────────────────────────
  logoTextInput.addEventListener('input', () => {
    cardLogoText.textContent = logoTextInput.value || COPY.logoTextPH;
  });

  // ── Secondary / Auxiliary field preview update ─────────────────────
  const ALIGN_CSS = { left: 'flex-start', center: 'center', right: 'flex-end' };

  function applyFieldAlign(fieldId) {
    const a = fieldAlign[fieldId];
    const labelEl = { sec1: sec1LabelEl, sec2: sec2LabelEl, aux1: aux1LabelEl, aux2: aux2LabelEl }[fieldId];
    const valueEl = { sec1: sec1ValueEl, sec2: sec2ValueEl, aux1: aux1ValueEl, aux2: aux2ValueEl }[fieldId];
    const wrap = labelEl?.closest('.ip-card-field');
    if (wrap) {
      wrap.style.alignItems = ALIGN_CSS[a] ?? 'flex-start';
      wrap.style.textAlign = a;
    }
  }

  function updateSecPreview() {
    sec1LabelEl.textContent = sec1LabelInput.value.trim() || COPY.sec1LabelPH.split('（')[0].trim();
    sec1ValueEl.textContent = sec1ValueInput.value.trim() || COPY.sec1ValuePH.split('（')[0].trim();
    sec2LabelEl.textContent = sec2LabelInput.value.trim() || COPY.sec2LabelPH.split('（')[0].trim();
    sec2ValueEl.textContent = sec2ValueInput.value.trim() || COPY.sec2ValuePH.split('（')[0].trim();
  }

  [sec1LabelInput, sec1ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));
  [sec2LabelInput, sec2ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));

  function updateAuxPreview() {
    const l1 = aux1LabelInput.value.trim();
    const v1 = aux1ValueInput.value.trim();
    const l2 = aux2LabelInput.value.trim();
    const v2 = aux2ValueInput.value.trim();
    const has1 = l1 || v1;
    const has2 = l2 || v2;
    auxRow.style.display = (has1 || has2) ? 'flex' : 'none';
    aux1Wrap.style.display = has1 ? 'flex' : 'none';
    aux2Wrap.style.display = has2 ? 'flex' : 'none';
    aux1LabelEl.textContent = l1;
    aux1ValueEl.textContent = v1;
    aux2LabelEl.textContent = l2;
    aux2ValueEl.textContent = v2;
  }

  [aux1LabelInput, aux1ValueInput, aux2LabelInput, aux2ValueInput].forEach(el => {
    el.addEventListener('input', updateAuxPreview);
  });

  // ── Alignment buttons ──────────────────────────────────────────────
  document.querySelectorAll('.ip-align-btns').forEach(group => {
    const fieldId = group.dataset.field;
    group.querySelectorAll('.ip-align-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        fieldAlign[fieldId] = btn.dataset.align;
        group.querySelectorAll('.ip-align-btn').forEach(b => b.classList.remove('ip-align-btn--active'));
        btn.classList.add('ip-align-btn--active');
        applyFieldAlign(fieldId);
      });
    });
  });

  // Apply default alignment to sec2 (right-aligned by default)
  applyFieldAlign('sec1');
  applyFieldAlign('sec2');
  applyFieldAlign('aux1');
  applyFieldAlign('aux2');

  // ── Carrier validation ─────────────────────────────────────────────
  function isValidCarrier(v) {
    return /^\/[A-Z0-9+\-.]{7}$/.test(v);
  }

  carrierInput.addEventListener('input', () => {
    const raw = carrierInput.value;
    carrierId = raw.length > 0 ? (raw[0] === '/' ? '/' + raw.slice(1).toUpperCase() : raw.toUpperCase()) : '';
    carrierInput.value = carrierId;
    cardNumber.textContent = carrierId || '––';
    barcodeAlt.textContent = carrierId || '––';
    carrierError.textContent = (carrierId && !isValidCarrier(carrierId)) ? COPY.errorInvalid : '';
    cta.disabled = !isValidCarrier(carrierId);
    updateBarcode();
  });

  // ── Background color ───────────────────────────────────────────────
  bgColorInput.addEventListener('input', () => {
    currentBgColor = bgColorInput.value;
    bgColorHex.textContent = currentBgColor;
    cardBg.style.background = currentBgColor;
  });

  // ── Foreground color ───────────────────────────────────────────────
  fgColorInput.addEventListener('input', () => {
    currentFgColor = fgColorInput.value;
    fgColorHex.textContent = currentFgColor;
    cardContent.style.color = currentFgColor;
    updateBarcode();
  });
  cardContent.style.color = currentFgColor;

  // ── 3D tilt (mouse on desktop, gyroscope on mobile) ────────────────
  const card = document.getElementById('wallet-card');
  let tiltEnabled = false;

  function applyTilt(rx, ry) {
    card.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
    const glareX = 50 + ry * 2;
    const glareY = 50 - rx * 2;
    cardGlare.style.background = `radial-gradient(circle at ${glareX}% ${glareY}%, rgba(255,255,255,0.22) 0%, transparent 65%)`;
  }

  function resetTilt() {
    card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)';
    cardGlare.style.background = 'none';
  }

  cardScene.addEventListener('mousemove', e => {
    const rect = cardScene.getBoundingClientRect();
    const rx = ((e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2)) * -10;
    const ry = ((e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2)) * 10;
    applyTilt(rx, ry);
  });
  cardScene.addEventListener('mouseleave', resetTilt);

  function attachGyro() {
    tiltEnabled = true;
    if (tiltHint) tiltHint.style.display = 'block';
    window.addEventListener('deviceorientation', e => {
      if (!tiltEnabled) return;
      const rx = Math.max(-15, Math.min(15, (e.beta ?? 0) - 45)) * 0.5;
      const ry = Math.max(-15, Math.min(15, e.gamma ?? 0)) * 0.5;
      applyTilt(rx, ry);
    });
  }

  function requestGyro() {
    if (typeof DeviceOrientationEvent === 'undefined') return;
    if (typeof DeviceOrientationEvent.requestPermission === 'function') {
      DeviceOrientationEvent.requestPermission()
        .then(state => { if (state === 'granted') attachGyro(); })
        .catch(() => {});
    } else {
      attachGyro();
    }
  }

  const isIOS = /iphone|ipad/i.test(navigator.userAgent);
  const isMobile = /iphone|ipad|android/i.test(navigator.userAgent);

  if (isMobile) card.addEventListener('click', requestGyro, { once: true });
  if (!isIOS) iosNote.textContent = COPY.iosOnly;

  // ── Generate pass ──────────────────────────────────────────────────
  cta.addEventListener('click', async () => {
    if (!isValidCarrier(carrierId)) return;

    const originalText = cta.textContent;
    cta.textContent = COPY.adding;
    cta.disabled = true;

    try {
      // Render selected icon to PNG (58x58 @2x on coloured circle background)
      const iconPng = await renderIconToPng(selectedIconId, currentBgColor, currentFgColor);

      const ALIGN_MAP = { left: 'PKTextAlignmentLeft', center: 'PKTextAlignmentCenter', right: 'PKTextAlignmentRight' };

      const secFields = [
        { key: 'sec1', label: sec1LabelInput.value.trim() || ' ', value: sec1ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec1] },
        { key: 'sec2', label: sec2LabelInput.value.trim() || ' ', value: sec2ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec2] },
      ];

      const auxFields = [];
      const l1 = aux1LabelInput.value.trim(), v1 = aux1ValueInput.value.trim();
      const l2 = aux2LabelInput.value.trim(), v2 = aux2ValueInput.value.trim();
      if (l1 || v1) auxFields.push({ key: 'aux1', label: l1 || ' ', value: v1 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux1] });
      if (l2 || v2) auxFields.push({ key: 'aux2', label: l2 || ' ', value: v2 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux2] });

      const res = await fetch('/api/generate-pass', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          carrierId,
          backgroundColor: currentBgColor,
          foregroundColor: currentFgColor,
          labelColor: currentFgColor,
          logoText: logoTextInput.value.trim() || COPY.logoTextPH,
          secFields,
          iconPng,
          auxFields,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        carrierError.textContent = err.error ?? COPY.errorServer;
        return;
      }

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `invoice-${carrierId}.pkpass`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch {
      carrierError.textContent = COPY.errorServer;
    } finally {
      cta.textContent = originalText;
      cta.disabled = !isValidCarrier(carrierId);
    }
  });
</script>

<style>
  /* ── Layout ───────────────────────────────────────────────────────── */
  .ip-main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
    padding-top: 6rem;
    color: var(--text);
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .ip-hero {
    max-width: 680px;
    margin: 0 auto 5rem;
    text-align: center;
  }

  .ip-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.25rem;
  }

  .ip-h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .ip-h1-a { display: block; }
  .ip-h1-b { display: block; color: var(--accent); }

  .ip-hero-desc {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  /* ── Steps ────────────────────────────────────────────────────────── */
  .ip-steps {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ip-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg2);
    border: 1px solid var(--line2);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .ip-step-num {
    width: 1.25rem;
    height: 1.25rem;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  /* ── Workspace ────────────────────────────────────────────────────── */
  .ip-workspace {
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: row;
    gap: 3rem;
    align-items: flex-start;
  }

  /* Controls: 左欄，撐滿剩餘空間，最小寬度保護 */
  .ip-controls {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Preview: 右欄，固定 260px，不縮不長 */
  .ip-preview-wrap {
    flex: 0 0 260px;
    width: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: sticky;
    top: 7rem;
  }

  /* Tablet ≤ 760px：preview 縮小 */
  @media (max-width: 760px) {
    .ip-workspace { gap: 1.75rem; }
    .ip-preview-wrap { flex: 0 0 180px; width: 180px; }
  }

  /* Mobile ≤ 540px：堆疊，preview 在上、縮至 160px 置中 */
  @media (max-width: 540px) {
    .ip-workspace {
      flex-direction: column;
      gap: 1.75rem;
    }
    .ip-preview-wrap {
      flex: unset;
      width: 160px;
      position: static;
      align-self: center;
      order: -1;
    }
  }

  /* ── Controls ─────────────────────────────────────────────────────── */
  .ip-field { display: flex; flex-direction: column; gap: 0.5rem; }
  .ip-field--inline { flex-direction: row; align-items: center; justify-content: space-between; }

  /* Icon grid */
  .ip-icon-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.35rem;
  }

  .ip-icon-btn {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 1;
    background: var(--bg2);
    border: 1px solid var(--line2);
    border-radius: 0.5rem;
    cursor: pointer;
    color: var(--muted);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    padding: 0;
  }

  .ip-icon-btn:hover {
    background: var(--bg3, var(--bg2));
    border-color: var(--accent);
    color: var(--text);
  }

  .ip-icon-btn--active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--on-accent);
  }

  /* Field row: inputs + alignment buttons */
  .ip-field-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* Aux / sec field: two inputs side by side */
  .ip-aux-row {
    display: flex;
    gap: 0.5rem;
  }

  .ip-input--half {
    flex: 1 1 0;
    min-width: 0;
    font-size: 0.85rem;
    padding: 0.6rem 0.75rem;
    letter-spacing: 0;
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  /* Alignment toggle buttons */
  .ip-align-btns {
    display: flex;
    gap: 0.25rem;
  }

  .ip-align-btn {
    flex: 1;
    padding: 0.3rem 0;
    background: var(--bg2);
    border: 1px solid var(--line2);
    border-radius: 0.4rem;
    color: var(--muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .ip-align-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .ip-align-btn--active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--on-accent);
  }

  .ip-label {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  .ip-input {
    background: var(--bg2);
    border: 1px solid var(--line2);
    border-radius: 0.6rem;
    padding: 0.75rem 1rem;
    color: var(--text);
    font-size: 1rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.08em;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .ip-input:focus { border-color: var(--accent); }
  .ip-input::placeholder { color: var(--muted-dim); }

  .ip-hint {
    font-size: 0.72rem;
    color: var(--muted-dim);
  }

  .ip-error {
    font-size: 0.78rem;
    color: #f87171;
    min-height: 1rem;
  }

  /* ── Color picker ─────────────────────────────────────────────────── */
  .ip-color-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .ip-color {
    -webkit-appearance: none;
    appearance: none;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    background: none;
    padding: 0;
  }

  .ip-color::-webkit-color-swatch-wrapper { padding: 0; }
  .ip-color::-webkit-color-swatch { border-radius: 50%; border: 2px solid var(--line2); }

  .ip-color-hex {
    font-size: 0.85rem;
    font-family: 'Space Mono', monospace;
    color: var(--muted);
  }

  /* ── CTA ──────────────────────────────────────────────────────────── */
  .ip-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--accent);
    color: var(--on-accent);
    border: none;
    border-radius: 0.7rem;
    padding: 0.9rem 1.5rem;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    width: 100%;
  }

  .ip-cta:hover:not(:disabled) { transform: translateY(-1px); opacity: 0.92; }
  .ip-cta:disabled { opacity: 0.4; cursor: not-allowed; }

  .ip-ios-note {
    font-size: 0.72rem;
    color: var(--muted-dim);
    text-align: center;
    min-height: 1rem;
    margin: 0;
  }

  /* ── Card preview ─────────────────────────────────────────────────── */
  .ip-preview-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  /* Card scene: perspective container — width controlled by grid column */
  .ip-card-scene {
    width: 100%;
    perspective: 1000px;
    cursor: pointer;
  }

  /* Generic pass: width ≈ 375pt, height ≈ 550pt → ratio ~375:550 ≈ 15:22 */
  .ip-card {
    width: 100%;
    aspect-ratio: 375 / 550;
    border-radius: 1.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.07);
    transform-style: preserve-3d;
    transition: transform 0.12s ease-out, box-shadow 0.12s;
    will-change: transform;
  }

  .ip-card:hover {
    box-shadow: 0 32px 80px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.12);
  }

  .ip-card-bg {
    position: absolute;
    inset: 0;
    transition: background 0.4s ease;
  }

  .ip-card-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    transition: background 0.1s;
  }

  /* Content: column layout matching real Wallet generic pass */
  .ip-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 1rem 1.1rem 0.8rem;
    color: #ffffff;
    transition: color 0.2s;
    gap: 0;
  }

  /* Row: shared row styles */
  .ip-card-row {
    display: flex;
    align-items: flex-start;
  }

  /* Row 1: logoText + headerField */
  .ip-card-row--header {
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .ip-card-logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .ip-card-icon {
    display: flex;
    align-items: center;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .ip-card-logo-text {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    opacity: 0.9;
  }

  /* Row 2: primary — 固定高度，不撐滿 */
  .ip-card-row--primary {
    flex-direction: column;
    justify-content: flex-start;
    margin-bottom: 0.65rem;
  }

  /* Row 3: secondary (2 cols) */
  .ip-card-row--secondary {
    justify-content: space-between;
    margin-bottom: 0.4rem;
  }

  /* Row 4: auxiliary */
  .ip-card-row--aux {
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  /* Spacer — pushes barcode to bottom */
  .ip-card-spacer { flex: 1; }

  /* Row 5: barcode — fixed at bottom */
  .ip-card-row--barcode {
    margin-top: auto;
  }

  /* Field: label + value stacked */
  .ip-card-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .ip-card-field--right {
    align-items: flex-end;
    text-align: right;
  }

  .ip-card-flabel {
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.55;
    font-weight: 500;
  }

  .ip-card-fvalue {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    opacity: 0.9;
  }

  .ip-card-fvalue--lg {
    font-size: 1.35rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.06em;
    font-weight: 700;
    opacity: 1;
  }

  .ip-card-fvalue--sm {
    font-size: 0.65rem;
    opacity: 0.85;
  }

  /* Barcode area */
  .ip-barcode-wrap {
    width: 100%;
    background: rgba(255,255,255,0.95);
    border-radius: 0.5rem;
    padding: 0.5rem 0.6rem 0.3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .ip-barcode {
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    display: block;
  }

  .ip-barcode-alt {
    font-size: 0.55rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.08em;
    color: #222;
    opacity: 0.8;
  }

  .ip-tilt-hint {
    font-size: 0.72rem;
    color: var(--muted-dim);
    text-align: center;
    margin: 0;
  }

  /* ── Footer ───────────────────────────────────────────────────────── */
  .ip-footer {
    margin-top: auto;
    padding: 3rem 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: var(--muted-dim);
    border-top: 1px solid var(--line);
    max-width: 1100px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .ip-back {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ip-back:hover { color: var(--text); }
</style>

</body>
</html>
