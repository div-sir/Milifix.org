const copy = t[lang];
const copyJson = JSON.stringify({ previewCarrier: copy.previewCarrier, sec1LabelPH: copy.sec1LabelPH, sec1ValuePH: copy.sec1ValuePH, sec2LabelPH: copy.sec2LabelPH, sec2ValuePH: copy.sec2ValuePH, adding: copy.adding, errorInvalid: copy.errorInvalid, errorServer: copy.errorServer, iosOnly: copy.iosOnly, logoTextPH: copy.logoTextPH });
---

<BaseLayout
  lang={lang}
  title={copy.htmlTitle}
  description={copy.metaDesc}
  canonicalPath={pathname}
  htmlDataTheme="dark"
>

<AmbientBackdrop />
<SiteNav variant="platform" lang={lang} pathname={pathname} />
<PortfolioChrome lang={lang} pathname={pathname} showDock={false} />

<main class="ip-main">

  <!-- Hero -->
  <section class="ip-hero">
    <p class="ip-eyebrow">{copy.eyebrow}</p>
    <h1 class="ip-h1">
      <span class="ip-h1-a">{copy.h1a}</span>
      <span class="ip-h1-b">{copy.h1b}</span>
    </h1>
    <p class="ip-hero-desc">{copy.heroDesc}</p>

    <!-- Step pills -->
    <div class="ip-steps">
      {[copy.step1, copy.step2, copy.step3].map((s, i) => (
        <div class="ip-step">
          <span class="ip-step-num">{i + 1}</span>
          <span class="ip-step-label">{s}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Editor + Preview -->
  <section class="ip-workspace">

    <!-- Left: controls -->
    <div class="ip-controls">

      <!-- Carrier ID input -->
      <div class="ip-field">
        <label for="carrier-input" class="ip-label">{copy.inputLabel}</label>
        <input
          id="carrier-input"
          type="text"
          class="ip-input"
          placeholder={copy.inputPlaceholder}
          maxlength="8"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="none"
          spellcheck="false"
        />
        <span class="ip-hint">{copy.inputHint}</span>
        <span class="ip-error" id="carrier-error" role="alert" aria-live="polite"></span>
      </div>

      <!-- Icon + Card title (same row) -->
      <div class="ip-field">
        <div class="ip-icon-title-labels">
          <span class="ip-label">{copy.iconLabel}</span>
          <label for="logo-text-input" class="ip-label">{copy.logoTextLabel}</label>
        </div>
        <div class="ip-icon-title-row">
          <button type="button" class="ip-icon-trigger" id="icon-trigger" title={copy.iconLabel}>
            <span class="ip-icon-trigger-preview" id="icon-trigger-preview"></span>
          </button>
          <input id="logo-text-input" type="text" class="ip-input ip-input--title" value={DEFAULT_LOGO_TEXT[lang]} maxlength="20" autocomplete="off" />
          <!-- Icon panel anchored to title-row -->
          <div class="ip-icon-panel" id="icon-panel" hidden>
            <div class="ip-icon-search-wrap">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input id="icon-search" type="text" class="ip-icon-search" placeholder="搜尋圖示…" autocomplete="off" />
            </div>
            <div class="ip-icon-grid" id="icon-grid"></div>
          </div>
        </div>
      </div>

      <!-- Secondary field 1 -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec1Label}</span>
        <div class="ip-inline-row">
          <input id="sec1-label-input" type="text" class="ip-input ip-input--label" value={DEFAULT_SEC1_LABEL[lang]} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec1" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="sec1-value-input" type="text" class="ip-input ip-input--value" value={DEFAULT_SEC1_VALUE[lang]} maxlength="24" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec1" data-subfield="value">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Secondary field 2 -->
      <div class="ip-field">
        <span class="ip-label">{copy.sec2Label}</span>
        <div class="ip-inline-row">
          <input id="sec2-label-input" type="text" class="ip-input ip-input--label" value={DEFAULT_SEC2_LABEL[lang]} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec2" data-subfield="label">
            <button type="button" class="ip-aln" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln ip-aln--active" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="sec2-value-input" type="text" class="ip-input ip-input--value" value={DEFAULT_SEC2_VALUE[lang]} maxlength="24" autocomplete="off" />
          <div class="ip-align-inline" data-field="sec2" data-subfield="value">
            <button type="button" class="ip-aln" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln ip-aln--active" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 1 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux1Label}</span>
        <div class="ip-inline-row">
          <input id="aux1-label-input" type="text" class="ip-input ip-input--label" placeholder={copy.aux1LabelPH} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux1" data-subfield="label">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="aux1-value-input" type="text" class="ip-input ip-input--value" placeholder={copy.aux1ValuePH} maxlength="30" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux1" data-subfield="value">
            <button type="button" class="ip-aln ip-aln--active" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Auxiliary field 2 -->
      <div class="ip-field">
        <span class="ip-label">{copy.aux2Label}</span>
        <div class="ip-inline-row">
          <input id="aux2-label-input" type="text" class="ip-input ip-input--label" placeholder={copy.aux2LabelPH} maxlength="20" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux2" data-subfield="label">
            <button type="button" class="ip-aln" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln ip-aln--active" data-align="right">&#8677;</button>
          </div>
        </div>
        <div class="ip-inline-row">
          <input id="aux2-value-input" type="text" class="ip-input ip-input--value" placeholder={copy.aux2ValuePH} maxlength="30" autocomplete="off" />
          <div class="ip-align-inline" data-field="aux2" data-subfield="value">
            <button type="button" class="ip-aln" data-align="left">&#8676;</button>
            <button type="button" class="ip-aln" data-align="center">&#8596;</button>
            <button type="button" class="ip-aln ip-aln--active" data-align="right">&#8677;</button>
          </div>
        </div>
      </div>

      <!-- Pass style picker -->
      <div class="ip-field ip-field--inline">
        <label for="pass-style-select" class="ip-label">{copy.passStyleLabel}</label>
        <select id="pass-style-select" class="ip-select">
          <option value="eventTicket">{copy.passStyleEventTicket}</option>
          <option value="storeCard">{copy.passStyleStoreCard}</option>
          <option value="generic">{copy.passStyleGeneric}</option>
        </select>
      </div>

      <!-- Background image upload -->
      <div class="ip-field" id="bg-image-field">
        <span class="ip-label">{copy.bgImageLabel}</span>
        <label class="ip-bg-upload" id="bg-upload-label" for="bg-image-input">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          <span id="bg-upload-text">{copy.bgImageHint}</span>
          <input id="bg-image-input" type="file" accept="image/png,image/jpeg,image/webp" style="display:none" />
        </label>
        <div class="ip-bg-preview-wrap" id="bg-preview-wrap" hidden>
          <img id="bg-preview-img" class="ip-bg-preview-img" src="" alt="" width="58" height="70" loading="lazy" decoding="async" />
          <button type="button" class="ip-bg-clear" id="bg-clear">{copy.bgImageClear}</button>
        </div>
      </div>

      <!-- Gradient theme picker -->
      <div class="ip-field ip-field--inline" id="gradient-field">
        <label for="gradient-select" class="ip-label">{copy.gradientLabel}</label>
        <select id="gradient-select" class="ip-select"></select>
      </div>

      <!-- Background color picker -->
      <div class="ip-field ip-field--inline" id="bg-color-field">
        <label for="bg-color-input" class="ip-label">{copy.bgLabel}</label>
        <div class="ip-color-wrap">
          <input id="bg-color-input" type="color" class="ip-color" value={DEFAULT_BG} />
          <span class="ip-color-hex" id="bg-color-hex">{DEFAULT_BG}</span>
        </div>
      </div>

      <!-- Text color picker -->
      <div class="ip-field ip-field--inline">
        <label for="color-input" class="ip-label">{copy.colorLabel}</label>
        <div class="ip-color-wrap">
          <input id="color-input" type="color" class="ip-color" value={DEFAULT_FG} />
          <span class="ip-color-hex" id="color-hex">{DEFAULT_FG}</span>
        </div>
      </div>

      <!-- CTA -->
      <button class="ip-cta" id="add-to-wallet" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
        {copy.addToWallet}
      </button>
      <p class="ip-ios-note" id="ios-note"></p>

    </div>

    <!-- Right: card preview -->
    <div class="ip-preview-wrap">
      <p class="ip-preview-label">{copy.previewLabel}</p>
      <div class="ip-card-scene" id="card-scene">
        <div class="ip-card" id="wallet-card">
          <div class="ip-card-bg" id="card-bg" style={`background: ${DEFAULT_BG}`} data-bg={DEFAULT_BG} data-gradient=""></div>
          <div class="ip-card-strip" id="card-strip" hidden></div>
          <div class="ip-card-glare" id="card-glare"></div>
          <div class="ip-card-content" id="card-content">

            <!-- Row 1: header row (icon + logoText left) -->
            <div class="ip-card-row ip-card-row--header">
              <div class="ip-card-logo-wrap">
                <div class="ip-card-icon" id="card-icon"></div>
                <span class="ip-card-logo-text" id="card-logo-text">{DEFAULT_LOGO_TEXT[lang]}</span>
              </div>
            </div>

            <!-- Row 2: primaryField (full width) -->
            <div class="ip-card-row ip-card-row--primary">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="primary-label">{copy.previewCarrier}</span>
                <span class="ip-card-fvalue ip-card-fvalue--lg" id="card-number">––</span>
              </div>
            </div>

            <!-- Row 3: secondaryFields (2 cols) -->
            <div class="ip-card-row ip-card-row--secondary" id="secondary-row">
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="sec1-label">{DEFAULT_SEC1_LABEL[lang]}</span>
                <span class="ip-card-fvalue" id="sec1-value">{DEFAULT_SEC1_VALUE[lang]}</span>
              </div>
              <div class="ip-card-field">
                <span class="ip-card-flabel" id="sec2-label">{DEFAULT_SEC2_LABEL[lang]}</span>
