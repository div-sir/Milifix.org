              </div>
            </div>

            <!-- Row 4: auxiliaryFields (up to 3 cols) -->
            <div class="ip-card-row ip-card-row--aux" id="aux-row" style="display:none">
              <div class="ip-card-field" id="aux1-wrap">
                <span class="ip-card-flabel" id="aux1-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux1-value"></span>
              </div>
              <div class="ip-card-field" id="aux2-wrap" style="display:none">
                <span class="ip-card-flabel" id="aux2-label"></span>
                <span class="ip-card-fvalue ip-card-fvalue--sm" id="aux2-value"></span>
              </div>
            </div>

            <!-- Spacer: pushes barcode to bottom -->
            <div class="ip-card-spacer"></div>

            <!-- Row 5: barcode (full width, bottom) -->
            <div class="ip-card-row ip-card-row--barcode">
              <div class="ip-barcode-wrap" id="barcode-wrap">
                <canvas id="barcode-canvas" class="ip-barcode" width="320" height="48"></canvas>
                <span class="ip-barcode-alt" id="barcode-alt">––</span>
              </div>
            </div>

          </div>
        </div>
      </div>
      <p class="ip-tilt-hint" id="tilt-hint" style="display:none">{copy.tiltHint}</p>
    </div>

  </section>

  <footer class="ip-footer">
    <a href="/" class="ip-back">{copy.back}</a>
    <span>{copy.footer}</span>
  </footer>

</main>

