---
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import SiteNav from '../SiteNav.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import PortfolioChrome from '../PortfolioChrome.astro';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;

const DEFAULT_BG = '#111318';
const DEFAULT_FG = '#e2b565';
const DEFAULT_LOGO_TEXT_ZH = '發票載具';
const DEFAULT_LOGO_TEXT_EN = 'Invoice Pass';
const DEFAULT_LOGO_TEXT_JA = '発票キャリア';
const DEFAULT_SEC1_LABEL_ZH = '發行單位';
const DEFAULT_SEC1_VALUE_ZH = 'Milifix';
const DEFAULT_SEC2_LABEL_ZH = '類型';
const DEFAULT_SEC2_VALUE_ZH = '統一發票';
const DEFAULT_SEC1_LABEL_EN = 'Issued by';
const DEFAULT_SEC1_VALUE_EN = 'Milifix';
const DEFAULT_SEC2_LABEL_EN = 'Type';
const DEFAULT_SEC2_VALUE_EN = 'Invoice';
const DEFAULT_SEC1_LABEL_JA = '発行元';
const DEFAULT_SEC1_VALUE_JA = 'Milifix';
const DEFAULT_SEC2_LABEL_JA = '種別';
const DEFAULT_SEC2_VALUE_JA = '統一発票';

const t = {
  zh: {
    htmlTitle: 'Invoice Pass — 打造你的專屬發票載具卡',
    metaDesc: '輸入你的發票載具號碼，挑選背景、調整顏色，一鍵生成屬於你的 Apple Wallet 個人化載具卡片。',
