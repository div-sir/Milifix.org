---
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import SiteNav from '../SiteNav.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import PortfolioChrome from '../PortfolioChrome.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../i18n/types';

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;

const DEFAULT_BG = '#111318';
const DEFAULT_FG = '#e2b565';
