  const logoTextInput    = /** @type {HTMLInputElement} */ (document.getElementById('logo-text-input'));
  // sec1
  const sec1LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec1-label-input'));
  const sec1ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec1-value-input'));
  const sec1LabelEl      = document.getElementById('sec1-label');
  const sec1ValueEl      = document.getElementById('sec1-value');
  // sec2
  const sec2LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec2-label-input'));
  const sec2ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('sec2-value-input'));
  const sec2LabelEl      = document.getElementById('sec2-label');
  const sec2ValueEl      = document.getElementById('sec2-value');
  // aux1
  const aux1LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux1-label-input'));
  const aux1ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux1-value-input'));
  const aux1LabelEl      = document.getElementById('aux1-label');
  const aux1ValueEl      = document.getElementById('aux1-value');
  // aux2
  const aux2LabelInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux2-label-input'));
  const aux2ValueInput   = /** @type {HTMLInputElement} */ (document.getElementById('aux2-value-input'));
  const aux2LabelEl      = document.getElementById('aux2-label');
  const aux2ValueEl      = document.getElementById('aux2-value');
  const auxRow           = document.getElementById('aux-row');
  const aux1Wrap         = document.getElementById('aux1-wrap');
  const aux2Wrap         = document.getElementById('aux2-wrap');

  // ── Code 39 barcode renderer ───────────────────────────────────────
  // Each char encoded as 5 bars + 4 spaces (9 elements), narrow=1 wide=3
  const C39 = {
    '0':'nnnwwnwnn','1':'wnnwnnnnw','2':'nnwwnnnnw','3':'wnwwnnnnn',
    '4':'nnnwwnnnw','5':'wnnwwnnnn','6':'nnwwwnnnn','7':'nnnwnnwnw',
    'A':'wnnnnwnnw','B':'nnwnnwnnw','C':'wnwnnwnnn','D':'nnnnwwnnw',
    'E':'wnnnwwnnn','F':'nnwnwwnnn','G':'nnnnnwwnw','H':'wnnnnwwnn',
    'I':'nnwnnwwnn','J':'nnnnwwwnn','K':'wnnnnnnww','L':'nnwnnnnww',
    'M':'wnwnnnnwn','N':'nnnnwnnww','O':'wnnnwnnwn','P':'nnwnwnnwn',
    'Q':'nnnnnnwww','R':'wnnnnnwwn','S':'nnwnnnwwn','T':'nnnnwnwwn',
    'U':'wwnnnnnnw','V':'nwwnnnnnw','W':'wwwnnnnnn','X':'nwnnwnnnw',
    'Y':'wwnnwnnnn','Z':'nwwnwnnnn',
    '+':'nwnnnnwnw','-':'nwnnnnnnw','.':'wwnnnnnnn',
    ' ':'nwnnwnnnn','*':'nwnnwnnnw',
    '/':'nwnnnnwnn', // Code 39 special
  };

  function drawCode39(canvas, text, fgColor) {
    const ctx = canvas.getContext('2d');
    const encoded = '*' + text + '*';
    const narrow = 1.4;
    const wide = narrow * 3;
    const gap = narrow; // inter-char gap (white)
    let totalWidth = 0;
    for (const ch of encoded) {
      const pattern = C39[ch];
      if (!pattern) continue;
      for (const w of pattern) totalWidth += (w === 'w' ? wide : narrow);
      totalWidth += gap;
    }
    totalWidth -= gap;

    const h = canvas.height;
    const scaleX = canvas.width / totalWidth;
    ctx.clearRect(0, 0, canvas.width, h);

    let x = 0;
    for (let ci = 0; ci < encoded.length; ci++) {
      const pattern = C39[encoded[ci]];
      if (!pattern) continue;
      for (let i = 0; i < pattern.length; i++) {
        const w = (pattern[i] === 'w' ? wide : narrow) * scaleX;
        if (i % 2 === 0) { // even = bar
          ctx.fillStyle = fgColor;
          ctx.fillRect(Math.round(x), 0, Math.ceil(w), h);
        }
        x += w;
      }
      if (ci < encoded.length - 1) x += gap * scaleX;
    }
  }

  function updateBarcode() {
    drawCode39(barcodeCanvas, carrierId || '/XXXXXXX', '#1a1a1a');
  }
  updateBarcode();

  // ── Icon → PNG (for pkpass logo) ──────────────────────────────────
  async function renderIconToPng(iconId, bgColor, fgColor) {
    const icon = ICONS.find(i => i.id === iconId);
    if (!icon) return null;
    const size = 58;
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    const ctx = c.getContext('2d');
    // filled circle background
    ctx.fillStyle = bgColor;
    ctx.beginPath();
    ctx.arc(size/2, size/2, size/2, 0, Math.PI*2);
    ctx.fill();
    // draw SVG icon via Image + Blob
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${fgColor}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="${icon.path}"/></svg>`;
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    await new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => { ctx.drawImage(img, 7, 7, size - 14, size - 14); resolve(); };
      img.onerror = reject;
      img.src = url;
    });
    URL.revokeObjectURL(url);
    // return base64 PNG without data: prefix
    return c.toDataURL('image/png').split(',')[1];
  }

  // ── Icon picker ────────────────────────────────────────────────────
  function makeSvg(pathData, size = 20, color = 'currentColor') {
    return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="${pathData}"/></svg>`;
  }

  const iconTrigger     = document.getElementById('icon-trigger');
  const iconTriggerPrev = document.getElementById('icon-trigger-preview');

  const iconPanel       = document.getElementById('icon-panel');
  const iconSearchInput = /** @type {HTMLInputElement} */ (document.getElementById('icon-search'));
  const iconGrid        = document.getElementById('icon-grid');

  function updateTriggerDisplay() {
    const icon = ICONS.find(i => i.id === selectedIconId);
    if (!icon) return;
    iconTriggerPrev.innerHTML = makeSvg(icon.path, 16);
  }

  function renderIconGrid(filter = '') {
    iconGrid.innerHTML = '';
    const q = filter.toLowerCase();
    const filtered = ICONS.filter(i =>
      !q || i.label.includes(q) || i.id.includes(q)
    );
    filtered.forEach(icon => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ip-icon-btn' + (icon.id === selectedIconId ? ' ip-icon-btn--active' : '');
      btn.title = icon.label;
      btn.dataset.id = icon.id;
      btn.innerHTML = makeSvg(icon.path, 20);
      btn.addEventListener('click', () => {
        selectedIconId = icon.id;
        iconGrid.querySelectorAll('.ip-icon-btn').forEach(b => b.classList.remove('ip-icon-btn--active'));
        btn.classList.add('ip-icon-btn--active');
        updateCardIcon();
        updateTriggerDisplay();
        iconPanel.hidden = true;
      });
      iconGrid.appendChild(btn);
    });
  }

  function updateCardIcon() {
    const icon = ICONS.find(i => i.id === selectedIconId);
    if (!icon) return;
    cardIconEl.innerHTML = makeSvg(icon.path, 14, 'currentColor');
  }

  // Toggle panel
  iconTrigger.addEventListener('click', () => {
    iconPanel.hidden = !iconPanel.hidden;
    if (!iconPanel.hidden) {
      iconSearchInput.value = '';
      renderIconGrid();
      iconSearchInput.focus();
    }
  });

  // Close panel on outside click
  document.addEventListener('click', e => {
    if (!iconTrigger.contains(e.target) && !iconPanel.contains(e.target)) {
      iconPanel.hidden = true;
    }
  });

  // Search filter
  iconSearchInput.addEventListener('input', () => renderIconGrid(iconSearchInput.value));

  renderIconGrid();
  updateCardIcon();
  updateTriggerDisplay();

  // ── Logo text (card title) ─────────────────────────────────────────
  logoTextInput.addEventListener('input', () => {
    cardLogoText.textContent = logoTextInput.value || COPY.logoTextPH;
  });

  // ── Secondary / Auxiliary field preview update ─────────────────────
  const ALIGN_CSS = { left: 'flex-start', center: 'center', right: 'flex-end' };

  const LABEL_ELS = { sec1: sec1LabelEl, sec2: sec2LabelEl, aux1: aux1LabelEl, aux2: aux2LabelEl };
  const VALUE_ELS = { sec1: sec1ValueEl, sec2: sec2ValueEl, aux1: aux1ValueEl, aux2: aux2ValueEl };

  function applyFieldAlign(fieldId) {
    const aLabel = fieldAlign[fieldId].label;
    const aValue = fieldAlign[fieldId].value;
    const lEl = LABEL_ELS[fieldId];
    const vEl = VALUE_ELS[fieldId];
    if (lEl) { lEl.style.alignSelf = ALIGN_CSS[aLabel]; lEl.style.textAlign = aLabel; }
    if (vEl) { vEl.style.alignSelf = ALIGN_CSS[aValue]; vEl.style.textAlign = aValue; }
  }

  function updateSecPreview() {
    sec1LabelEl.textContent = sec1LabelInput.value.trim() || COPY.sec1LabelPH.split('（')[0].trim();
    sec1ValueEl.textContent = sec1ValueInput.value.trim() || COPY.sec1ValuePH.split('（')[0].trim();
    sec2LabelEl.textContent = sec2LabelInput.value.trim() || COPY.sec2LabelPH.split('（')[0].trim();
    sec2ValueEl.textContent = sec2ValueInput.value.trim() || COPY.sec2ValuePH.split('（')[0].trim();
  }

  [sec1LabelInput, sec1ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));
  [sec2LabelInput, sec2ValueInput].forEach(el => el.addEventListener('input', updateSecPreview));

  function updateAuxPreview() {
    const l1 = aux1LabelInput.value.trim();
    const v1 = aux1ValueInput.value.trim();
    const l2 = aux2LabelInput.value.trim();
    const v2 = aux2ValueInput.value.trim();
    const has1 = l1 || v1;
    const has2 = l2 || v2;
    auxRow.style.display = (has1 || has2) ? 'flex' : 'none';
    aux1Wrap.style.display = has1 ? 'flex' : 'none';
    aux2Wrap.style.display = has2 ? 'flex' : 'none';
    aux1LabelEl.textContent = l1;
    aux1ValueEl.textContent = v1;
    aux2LabelEl.textContent = l2;
    aux2ValueEl.textContent = v2;
  }

  [aux1LabelInput, aux1ValueInput, aux2LabelInput, aux2ValueInput].forEach(el => {
    el.addEventListener('input', updateAuxPreview);
  });

  // ── Alignment buttons (inline, per subfield) ──────────────────────
  document.querySelectorAll('.ip-align-inline').forEach(group => {
    const fieldId   = group.dataset.field;
    const subfield  = group.dataset.subfield; // 'label' | 'value'
    group.querySelectorAll('.ip-aln').forEach(btn => {
      btn.addEventListener('click', () => {
        fieldAlign[fieldId][subfield] = btn.dataset.align;
        group.querySelectorAll('.ip-aln').forEach(b => b.classList.remove('ip-aln--active'));
        btn.classList.add('ip-aln--active');
        applyFieldAlign(fieldId);
      });
    });
  });

  applyFieldAlign('sec1');
  applyFieldAlign('sec2');
  applyFieldAlign('aux1');
  applyFieldAlign('aux2');

  // ── Carrier validation ─────────────────────────────────────────────
  function isValidCarrier(v) {
    return /^\/[A-Z0-9+\-.]{7}$/.test(v);
  }

  carrierInput.addEventListener('input', () => {
    const raw = carrierInput.value;
    carrierId = raw.length > 0 ? (raw[0] === '/' ? '/' + raw.slice(1).toUpperCase() : raw.toUpperCase()) : '';
    carrierInput.value = carrierId;
    cardNumber.textContent = carrierId || '––';
    barcodeAlt.textContent = carrierId || '––';
    carrierError.textContent = (carrierId && !isValidCarrier(carrierId)) ? COPY.errorInvalid : '';
    cta.disabled = !isValidCarrier(carrierId);
    updateBarcode();
  });

  // ── Gradient theme picker (select) ────────────────────────────────
  const gradientSelect = /** @type {HTMLSelectElement} */ (document.getElementById('gradient-select'));
  let selectedGradientId = 'midnight';

  function applyGradientTheme(theme) {
    selectedGradientId = theme.id;
    if (theme.css) {
      cardBg.style.background = theme.css;
      if (theme.from) {
        currentBgColor = theme.from;
        bgColorInput.value = theme.from;
        bgColorHex.textContent = theme.from;
      }
      if (theme.fg) {
        currentFgColor = theme.fg;
        fgColorInput.value = theme.fg;
        fgColorHex.textContent = theme.fg;
        cardContent.style.color = theme.fg;
        updateBarcode();
      }
    } else {
      cardBg.style.background = currentBgColor;
    }
    gradientSelect.value = theme.id;
  }

  // Populate select options
  GRADIENTS.forEach(theme => {
    const opt = document.createElement('option');
    opt.value = theme.id;
    opt.textContent = theme.label;
    gradientSelect.appendChild(opt);
  });
  gradientSelect.value = selectedGradientId;
  gradientSelect.addEventListener('change', () => {
    const theme = GRADIENTS.find(g => g.id === gradientSelect.value);
    if (theme) applyGradientTheme(theme);
  });
  // Apply default on init
  applyGradientTheme(GRADIENTS.find(g => g.id === selectedGradientId));

  // ── Background image upload ────────────────────────────────────────
  function setBgControlsDisabled(disabled) {
    gradientField.classList.toggle('ip-field--disabled', disabled);
    bgColorField.classList.toggle('ip-field--disabled', disabled);
    gradientSelect.disabled = disabled;
    bgColorInput.disabled   = disabled;
  }

  function applyBgImage(dataUrl) {
    currentBgImage = dataUrl;
    cardStrip.style.backgroundImage = `url(${dataUrl})`;
    cardStrip.hidden = false;
    bgPreviewImg.src = dataUrl;
    bgPreviewWrap.hidden = false;
    setBgControlsDisabled(true);
  }

  function clearBgImage() {
    currentBgImage = null;
    cardStrip.style.backgroundImage = '';
    cardStrip.hidden = true;
    bgPreviewWrap.hidden = true;
    bgPreviewImg.src = '';
    bgImageInput.value = '';
    setBgControlsDisabled(false);
  }

  bgImageInput.addEventListener('change', () => {
    const file = bgImageInput.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => applyBgImage(/** @type {string} */ (e.target.result));
    reader.readAsDataURL(file);
  });

  bgClearBtn.addEventListener('click', clearBgImage);

  // ── Pass style ──────────────────────────────────────────────────────
  function applyPassStyle(style) {
    currentPassStyle = style;
    const supportsStrip = style !== 'generic';
    card.classList.toggle('ip-card--no-strip', !supportsStrip);
    // generic passes use thumbnail.png instead of background.png — image upload stays enabled
    bgUploadText.textContent = supportsStrip ? COPY.bgImageHint : COPY.bgImageDisabledHint;
  }

  passStyleSelect.value = currentPassStyle;
  passStyleSelect.addEventListener('change', () => {
    applyPassStyle(passStyleSelect.value);
  });

  // ── Background color ───────────────────────────────────────────────
  bgColorInput.addEventListener('input', () => {
    currentBgColor = bgColorInput.value;
    bgColorHex.textContent = currentBgColor;
    selectedGradientId = 'none';
    cardBg.style.background = currentBgColor;
    gradientSelect.value = 'none';
  });

  // ── Foreground color ───────────────────────────────────────────────
  fgColorInput.addEventListener('input', () => {
    currentFgColor = fgColorInput.value;
    fgColorHex.textContent = currentFgColor;
    cardContent.style.color = currentFgColor;
    updateBarcode();
  });
  cardContent.style.color = currentFgColor;

  // ── 3D tilt (mouse on desktop, gyroscope on mobile) ────────────────
  const card = document.getElementById('wallet-card');
  let tiltEnabled = false;

  function applyTilt(rx, ry) {
    card.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
    const glareX = 50 + ry * 2;
    const glareY = 50 - rx * 2;
    cardGlare.style.background = `radial-gradient(circle at ${glareX}% ${glareY}%, rgba(255,255,255,0.22) 0%, transparent 65%)`;
  }

  function resetTilt() {
    card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)';
    cardGlare.style.background = 'none';
  }

  cardScene.addEventListener('mousemove', e => {
    const rect = cardScene.getBoundingClientRect();
    const rx = ((e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2)) * -10;
    const ry = ((e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2)) * 10;
    applyTilt(rx, ry);
  });
  cardScene.addEventListener('mouseleave', resetTilt);

  function attachGyro() {
    tiltEnabled = true;
    if (tiltHint) tiltHint.style.display = 'block';
    window.addEventListener('deviceorientation', e => {
      if (!tiltEnabled) return;
      const rx = Math.max(-15, Math.min(15, (e.beta ?? 0) - 45)) * 0.5;
      const ry = Math.max(-15, Math.min(15, e.gamma ?? 0)) * 0.5;
      applyTilt(rx, ry);
    });
  }

  function requestGyro() {
    if (typeof DeviceOrientationEvent === 'undefined') return;
    if (typeof DeviceOrientationEvent.requestPermission === 'function') {
      DeviceOrientationEvent.requestPermission()
        .then(state => { if (state === 'granted') attachGyro(); })
        .catch(() => {});
    } else {
      attachGyro();
    }
  }

  const isIOS = /iphone|ipad/i.test(navigator.userAgent);
  const isMobile = /iphone|ipad|android/i.test(navigator.userAgent);

  if (isMobile) card.addEventListener('click', requestGyro, { once: true });
  if (!isIOS) iosNote.textContent = COPY.iosOnly;

  // ── Generate pass ──────────────────────────────────────────────────
  cta.addEventListener('click', async () => {
    if (!isValidCarrier(carrierId)) return;

    const originalText = cta.textContent;
    cta.textContent = COPY.adding;
    cta.disabled = true;

    try {
      // Render selected icon to PNG (58x58 @2x on coloured circle background)
      const iconPng = await renderIconToPng(selectedIconId, currentBgColor, currentFgColor);

      const ALIGN_MAP = { left: 'PKTextAlignmentLeft', center: 'PKTextAlignmentCenter', right: 'PKTextAlignmentRight' };

      const secFields = [
        { key: 'sec1', label: sec1LabelInput.value.trim() || ' ', value: sec1ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec1.value] },
        { key: 'sec2', label: sec2LabelInput.value.trim() || ' ', value: sec2ValueInput.value.trim() || ' ', textAlignment: ALIGN_MAP[fieldAlign.sec2.value] },
      ];

      const auxFields = [];
      const l1 = aux1LabelInput.value.trim(), v1 = aux1ValueInput.value.trim();
      const l2 = aux2LabelInput.value.trim(), v2 = aux2ValueInput.value.trim();
      if (l1 || v1) auxFields.push({ key: 'aux1', label: l1 || ' ', value: v1 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux1.value] });
      if (l2 || v2) auxFields.push({ key: 'aux2', label: l2 || ' ', value: v2 || ' ', textAlignment: ALIGN_MAP[fieldAlign.aux2.value] });

      const res = await fetch('/api/generate-pass', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Milifix-Request': '1' },
        body: JSON.stringify({
          carrierId,
          passStyle: currentPassStyle,
          backgroundColor: currentBgColor,
          foregroundColor: currentFgColor,
          labelColor: currentFgColor,
          logoText: logoTextInput.value.trim() || COPY.logoTextPH,
          secFields,
          iconPng,
          auxFields,
          backgroundPng: currentBgImage && currentPassStyle !== 'generic'
            ? currentBgImage.replace(/^data:[^;]+;base64,/, '')
            : null,
          thumbnailPng: currentBgImage && currentPassStyle === 'generic'
            ? currentBgImage.replace(/^data:[^;]+;base64,/, '')
            : null,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        carrierError.textContent = err.error ?? COPY.errorServer;
        return;
      }

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `invoice-${carrierId}.pkpass`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch {
      carrierError.textContent = COPY.errorServer;
    } finally {
      cta.textContent = originalText;
      cta.disabled = !isValidCarrier(carrierId);
    }
  });
</script>

<style>
  /* ── Layout ───────────────────────────────────────────────────────── */
  .ip-main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    padding: 0 clamp(1.25rem, 5vw, 4rem);
    padding-top: 6rem;
    color: var(--text);
    font-family: 'Space Grotesk', system-ui, sans-serif;
  }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  .ip-hero {
    max-width: 680px;
    margin: 0 auto 5rem;
    text-align: center;
  }

  .ip-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.25rem;
  }

  .ip-h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .ip-h1-a { display: block; }
  .ip-h1-b { display: block; color: var(--accent); }

  .ip-hero-desc {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  /* ── Steps ────────────────────────────────────────────────────────── */
  .ip-steps {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ip-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg2);
    border: 1px solid var(--line2);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .ip-step-num {
    width: 1.25rem;
    height: 1.25rem;
    background: var(--accent);
    color: var(--on-accent);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  /* ── Workspace ────────────────────────────────────────────────────── */
  .ip-workspace {
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: row;
    gap: 3rem;
    align-items: flex-start;
  }

  /* Controls: 左欄，撐滿剩餘空間，最小寬度保護 */
  .ip-controls {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Preview: 右欄，固定 260px，不縮不長 */
  .ip-preview-wrap {
    flex: 0 0 260px;
    width: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: sticky;
    top: 7rem;
  }

  /* Tablet ≤ 760px：preview 縮小 */
  @media (max-width: 760px) {
    .ip-workspace { gap: 1.75rem; }
    .ip-preview-wrap { flex: 0 0 180px; width: 180px; }
  }

  /* Mobile ≤ 540px：堆疊，preview 在上、縮至 160px 置中 */
  @media (max-width: 540px) {
    .ip-workspace {
      flex-direction: column;
      gap: 1.75rem;
    }
    .ip-preview-wrap {
      flex: unset;
      width: 160px;
      position: static;
      align-self: center;
      order: -1;
    }
  }

  /* ── Controls ─────────────────────────────────────────────────────── */
  .ip-field { display: flex; flex-direction: column; gap: 0.5rem; }
