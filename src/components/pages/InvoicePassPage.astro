  // ── Code 39 barcode renderer ───────────────────────────────────────
  // Each char encoded as 5 bars + 4 spaces (9 elements), narrow=1 wide=3
  const C39 = {
    '0':'nnnwwnwnn','1':'wnnwnnnnw','2':'nnwwnnnnw','3':'wnwwnnnnn',
    '4':'nnnwwnnnw','5':'wnnwwnnnn','6':'nnwwwnnnn','7':'nnnwnnwnw',
    'A':'wnnnnwnnw','B':'nnwnnwnnw','C':'wnwnnwnnn','D':'nnnnwwnnw',
    'E':'wnnnwwnnn','F':'nnwnwwnnn','G':'nnnnnwwnw','H':'wnnnnwwnn',
    'I':'nnwnnwwnn','J':'nnnnwwwnn','K':'wnnnnnnww','L':'nnwnnnnww',
    'M':'wnwnnnnwn','N':'nnnnwnnww','O':'wnnnwnnwn','P':'nnwnwnnwn',
    'Q':'nnnnnnwww','R':'wnnnnnwwn','S':'nnwnnnwwn','T':'nnnnwnwwn',
    'U':'wwnnnnnnw','V':'nwwnnnnnw','W':'wwwnnnnnn','X':'nwnnwnnnw',
    'Y':'wwnnwnnnn','Z':'nwwnwnnnn',
    '+':'nwnnnnwnw','-':'nwnnnnnnw','.':'wwnnnnnnn',
    ' ':'nwnnwnnnn','*':'nwnnwnnnw',
    '/':'nwnnnnwnn', // Code 39 special
  };

  function drawCode39(canvas, text, fgColor) {
    const ctx = canvas.getContext('2d');
    const encoded = '*' + text + '*';
    const narrow = 1.4;
    const wide = narrow * 3;
    const gap = narrow; // inter-char gap (white)
    let totalWidth = 0;
    for (const ch of encoded) {
      const pattern = C39[ch];
      if (!pattern) continue;
      for (const w of pattern) totalWidth += (w === 'w' ? wide : narrow);
      totalWidth += gap;
    }
    totalWidth -= gap;

    const h = canvas.height;
    const scaleX = canvas.width / totalWidth;
    ctx.clearRect(0, 0, canvas.width, h);

    let x = 0;
    for (let ci = 0; ci < encoded.length; ci++) {
      const pattern = C39[encoded[ci]];
      if (!pattern) continue;
      for (let i = 0; i < pattern.length; i++) {
        const w = (pattern[i] === 'w' ? wide : narrow) * scaleX;
        if (i % 2 === 0) { // even = bar
          ctx.fillStyle = fgColor;
          ctx.fillRect(Math.round(x), 0, Math.ceil(w), h);
        }
        x += w;
      }
      if (ci < encoded.length - 1) x += gap * scaleX;
    }
  }

  function updateBarcode() {
    drawCode39(barcodeCanvas, carrierId || '/XXXXXXX', '#1a1a1a');
  }
  updateBarcode();

  // ── Icon → PNG (for pkpass logo) ──────────────────────────────────
  async function renderIconToPng(iconId, bgColor, fgColor) {
    const icon = ICONS.find(i => i.id === iconId);
    if (!icon) return null;
    const size = 58;
    const c = document.createElement('canvas');
    c.width = size; c.height = size;
    const ctx = c.getContext('2d');
    // filled circle background
    ctx.fillStyle = bgColor;
    ctx.beginPath();
    ctx.arc(size/2, size/2, size/2, 0, Math.PI*2);
    ctx.fill();
    // draw SVG icon via Image + Blob
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="${fgColor}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="${icon.path}"/></svg>`;
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    await new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => { ctx.drawImage(img, 7, 7, size - 14, size - 14); resolve(); };
      img.onerror = reject;
      img.src = url;
    });
    URL.revokeObjectURL(url);
    // return base64 PNG without data: prefix
    return c.toDataURL('image/png').split(',')[1];
  }

  // ── Icon picker ────────────────────────────────────────────────────
