    font-size: 0.85rem;
    font-family: 'Space Mono', monospace;
    color: var(--muted);
  }

  /* ── Gradient theme picker ────────────────────────────────────────── */
  .ip-gradient-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.4rem;
  }

  .ip-gradient-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg2);
    border: 1.5px solid var(--line2);
    border-radius: 0.6rem;
    padding: 0.45rem 0.3rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .ip-gradient-btn:hover {
    border-color: var(--accent);
    background: var(--bg3, var(--bg2));
  }

  .ip-gradient-btn--active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .ip-gradient-swatch {
    width: 100%;
    aspect-ratio: 2 / 1;
    border-radius: 0.35rem;
    display: block;
    flex-shrink: 0;
    box-sizing: border-box;
  }

  .ip-gradient-label {
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ── CTA ──────────────────────────────────────────────────────────── */
  .ip-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--accent);
    color: var(--on-accent);
    border: none;
    border-radius: 0.7rem;
    padding: 0.9rem 1.5rem;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    width: 100%;
  }

  .ip-cta:hover:not(:disabled) { transform: translateY(-1px); opacity: 0.92; }
  .ip-cta:disabled { opacity: 0.4; cursor: not-allowed; }

  .ip-ios-note {
    font-size: 0.72rem;
    color: var(--muted-dim);
    text-align: center;
    min-height: 1rem;
    margin: 0;
  }

  /* ── Card preview ─────────────────────────────────────────────────── */
  .ip-preview-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  /* Card scene: perspective container — width controlled by grid column */
  .ip-card-scene {
    width: 100%;
    perspective: 1000px;
    cursor: pointer;
  }

  /* Generic pass: width ≈ 375pt, height ≈ 550pt → ratio ~375:550 ≈ 15:22 */
  .ip-card {
    width: 100%;
    aspect-ratio: 375 / 550;
    border-radius: 1.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.07);
    transform-style: preserve-3d;
    transition: transform 0.12s ease-out, box-shadow 0.12s;
    will-change: transform;
  }

  .ip-card:hover {
    box-shadow: 0 32px 80px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.12);
  }

  .ip-card-bg {
    position: absolute;
    inset: 0;
    transition: background 0.4s ease;
  }

  .ip-card-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    transition: background 0.1s;
  }

  /* Content: column layout matching real Wallet generic pass */
  .ip-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    padding: 1rem 1.1rem 0.8rem;
    color: #ffffff;
    transition: color 0.2s;
    gap: 0;
  }

  /* Row: shared row styles */
  .ip-card-row {
    display: flex;
    align-items: flex-start;
  }

  /* Row 1: logoText + headerField */
  .ip-card-row--header {
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .ip-card-logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .ip-card-icon {
    display: flex;
    align-items: center;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .ip-card-logo-text {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    opacity: 0.9;
  }

  /* Row 2: primary — 固定高度，不撐滿 */
  .ip-card-row--primary {
    flex-direction: column;
    justify-content: flex-start;
    margin-bottom: 0.65rem;
  }

  /* Row 3: secondary (2 cols) */
  .ip-card-row--secondary {
    justify-content: space-between;
    margin-bottom: 0.4rem;
  }

  /* Row 4: auxiliary */
  .ip-card-row--aux {
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  /* Spacer — pushes barcode to bottom */
  .ip-card-spacer { flex: 1; }

  /* Row 5: barcode — fixed at bottom */
  .ip-card-row--barcode {
    margin-top: auto;
  }

  /* Field: label + value stacked */
  .ip-card-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1 1 0;
    min-width: 0;
  }

  .ip-card-flabel {
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.55;
    font-weight: 500;
  }

  .ip-card-fvalue {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    opacity: 0.9;
  }

  .ip-card-fvalue--lg {
    font-size: 1.35rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.06em;
    font-weight: 700;
    opacity: 1;
  }

  .ip-card-fvalue--sm {
    font-size: 0.65rem;
    opacity: 0.85;
  }

  /* Barcode area */
  .ip-barcode-wrap {
    width: 100%;
    background: rgba(255,255,255,0.95);
    border-radius: 0.5rem;
    padding: 0.5rem 0.6rem 0.3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .ip-barcode {
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    display: block;
  }

  .ip-barcode-alt {
    font-size: 0.55rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.08em;
    color: #222;
    opacity: 0.8;
  }

  .ip-tilt-hint {
    font-size: 0.72rem;
    color: var(--muted-dim);
    text-align: center;
    margin: 0;
  }

  /* ── Footer ───────────────────────────────────────────────────────── */
  .ip-footer {
    margin-top: auto;
    padding: 3rem 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: var(--muted-dim);
    border-top: 1px solid var(--line);
    max-width: 1100px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .ip-back {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ip-back:hover { color: var(--text); }
</style>

</body>
</html>
