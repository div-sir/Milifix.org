---
import { getPrograms, type CmsProgramType } from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import TravelSubnav from '../travel/TravelSubnav.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import { programSlugPath } from '../../i18n/routes';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = ui(lang).travel;

const programs = await getPrograms();
const types: CmsProgramType[] = ['lounge-network', 'hotel-program', 'airline-alliance'];
const grouped = Object.fromEntries(
  types.map((type) => [type, programs.filter((p) => p.programType === type)])
);
---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{t.programs} — Milifix</title>
  <meta name="description" content={t.programsDesc} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <header class="travel-hero">
      <span class="travel-hero__tag">{t.programs}</span>
      <h1 class="travel-hero__title">{t.programs}</h1>
      <p class="travel-hero__desc">{t.programsDesc}</p>
    </header>

    <TravelSubnav lang={lang} current="programs" />

    {types.map((type) => {
      const items = grouped[type];
      if (!items?.length) return null;
      return (
        <section class="travel-section">
          <h2 class="travel-section__title">{t.programTypeNames[type]}</h2>
          <div class="travel-grid">
            {items.map((p) => (
              <a class="travel-card" href={programSlugPath(lang, p.slug)}>
                {p.logo?.url && (
                  <img class="travel-card__image travel-card__image--logo" src={p.logo.url} alt={p.name} loading="lazy" />
                )}
                <span class="travel-card__overline">
                  {t.programTypeNames[p.programType]}
                </span>
                <span class="travel-card__title">{p.name}</span>
                <span class="travel-card__subtitle">{p.summary.slice(0, 80)}…</span>
                {p.highlights.length > 0 && (
                  <span class="travel-card__tags">
                    {p.highlights.slice(0, 2).map((h) => (
                      <span class="travel-tag">{h.text.slice(0, 25)}</span>
                    ))}
                  </span>
                )}
              </a>
            ))}
          </div>
        </section>
      );
    })}

    {programs.length === 0 && (
      <div class="travel-empty"><p>{t.noResults}</p></div>
    )}
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    initPortfolioCursor();
  </script>
</body>
</html>
