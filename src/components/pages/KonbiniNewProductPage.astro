---
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import KonbiniNewProductForm from './KonbiniNewProductForm.astro';
import KonbiniReportButton from '../KonbiniReportButton.astro';
import type { Lang } from '../../i18n/types';
import { konbini } from '../../i18n/konbini';
import { konbiniPath, konbiniNewProductPath } from '../../i18n/routes';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/konbini.css';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = konbini(lang);
const n = t.newProduct;
---

<BaseLayout
  lang={lang}
  title={`${n.pageTitle} — ${t.navLabel}`}
  description={t.metaDesc}
  canonicalPath={konbiniNewProductPath(lang)}
  noindex={true}
>
  <AmbientBackdrop />
  <SiteNav lang={lang} variant="project" pathname={Astro.url.pathname} projectHref={konbiniPath(lang)} projectLabel={t.navLabel} />
  <PageTransition />

  <main class="konbini konbini-detail" id="main-content" tabindex="-1">
    <a class="konbini-back" href={konbiniPath(lang)}>← {t.backToIndex}</a>
    <h1 class="konbini-detail__name">{n.pageTitle}</h1>
    <p class="konbini-detail__desc">{n.intro}</p>
    <KonbiniNewProductForm lang={lang} />
  </main>

  <KonbiniReportButton lang={lang} />
</BaseLayout>
