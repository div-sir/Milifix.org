---
import { getLounges, getPrograms } from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import TravelSubnav from '../travel/TravelSubnav.astro';
import LoungeCard from '../travel/LoungeCard.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui(lang).travel;

const [lounges, allPrograms] = await Promise.all([getLounges(), getPrograms()]);
const airports = [...new Set(lounges.map((l) => l.airportCode))].sort();
---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{t.loungeListTitle} — Milifix</title>
  <meta name="description" content={t.loungeListDesc} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <header class="travel-hero">
      <span class="travel-hero__tag">{t.sectionLounges}</span>
      <h1 class="travel-hero__title">{t.loungeListTitle}</h1>
      <p class="travel-hero__desc">{t.loungeListDesc}</p>
    </header>

    <TravelSubnav lang={lang} current="lounges" />

    <section class="travel-section">
      {airports.length > 1 && (
        <div class="travel-filter">
          <select
            class="travel-filter__select"
            id="airport-filter"
            aria-label={t.filterByAirport}
          >
            <option value="">{t.allAirports}</option>
            {airports.map((a) => (
              <option value={a}>{a}</option>
            ))}
          </select>
        </div>
      )}

      {lounges.length > 0 ? (
        <div class="travel-grid" id="lounge-grid">
          {lounges.map((lounge) => (
            <div data-airport={lounge.airportCode}>
              <LoungeCard lang={lang} lounge={lounge} programs={allPrograms} />
            </div>
          ))}
        </div>
      ) : (
        <div class="travel-empty"><p>{t.noResults}</p></div>
      )}
    </section>
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>

  <script>
    const select = document.getElementById('airport-filter') as HTMLSelectElement | null;
    const grid = document.getElementById('lounge-grid');
    if (select && grid) {
      select.addEventListener('change', () => {
        const airport = select.value;
        for (const el of grid.children) {
          const item = el as HTMLElement;
          item.style.display =
            !airport || item.dataset.airport === airport ? '' : 'none';
        }
      });
    }
  </script>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    initPortfolioCursor();
  </script>
</body>
</html>
