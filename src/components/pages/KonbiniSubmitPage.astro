---
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../i18n/types';
import { konbini } from '../../i18n/konbini';
import { konbiniPath } from '../../i18n/routes';
import { loadKonbiniProducts } from '../../lib/konbini';
import { chainName } from '../../lib/konbini-view';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/konbini.css';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = konbini(lang);
const s = t.submit;

// 用 PUBLIC_ 前綴才會注入到瀏覽器端。未設定時僅顯示「尚未開放」訊息。
const clientId = import.meta.env.PUBLIC_GOOGLE_OAUTH_CLIENT_ID ?? '';
const configured = clientId.length > 0;

const products = await loadKonbiniProducts();
const productOptions = products
  .map((p) => ({ slug: p.slug, label: `${chainName(p.chain)} · ${p.name}` }))
  .sort((a, b) => a.label.localeCompare(b.label));
---

<BaseLayout
  lang={lang}
  title={`${s.pageTitle} — ${t.navLabel}`}
  description={t.metaDesc}
  canonicalPath={`${konbiniPath(lang)}/submit`}
  noindex={true}
>
  <AmbientBackdrop />
  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />
  <PageTransition />

  <main class="konbini konbini-submit" id="main-content" tabindex="-1">
    <a class="konbini-back" href={konbiniPath(lang)}>← {t.backToIndex}</a>
    <h1 class="konbini-detail__name">{s.pageTitle}</h1>
    <p class="konbini-detail__desc">{s.intro}</p>

    {
      !configured ? (
        <p class="konbini-empty">{s.notConfigured}</p>
      ) : (
        <form
          class="konbini-form"
          id="konbini-form"
          data-client-id={clientId}
          data-msg-signin={s.errorSignIn}
          data-msg-success={s.success}
          data-msg-error={s.errorGeneric}
          data-msg-toomany={s.photoTooMany}
          data-max-photos="3"
        >
          <div id="konbini-gsi" class="konbini-form__gsi" data-prompt={s.signInPrompt} />
          <p class="konbini-form__signed" id="konbini-signed" hidden>
            {s.signedInAs} <span id="konbini-user"></span>
          </p>

          <label class="konbini-form__row">
            <span>{s.fieldProduct}</span>
            <select name="productSlug" id="konbini-product" required>
              {productOptions.map((o) => (
                <option value={o.slug}>{o.label}</option>
              ))}
            </select>
          </label>

          <fieldset class="konbini-form__row konbini-form__rating">
            <legend>{s.fieldRating}</legend>
            {[1, 2, 3, 4, 5].map((n) => (
              <label class="konbini-form__star">
                <input type="radio" name="rating" value={n} required />
                <span>{'★'.repeat(n)}</span>
              </label>
            ))}
          </fieldset>

          <label class="konbini-form__row">
            <span>{s.fieldTitle} <em>({s.optional})</em></span>
            <input type="text" name="title" maxlength="80" />
          </label>

          <label class="konbini-form__row">
            <span>{s.fieldBody} <em>({s.optional})</em></span>
            <textarea name="body" rows="4" maxlength="1000"></textarea>
          </label>

          <div class="konbini-form__inline">
            <label class="konbini-form__row">
              <span>{s.fieldPrice} <em>({s.optional})</em></span>
              <input type="number" name="price" min="0" max="100000" step="1" />
            </label>
            <label class="konbini-form__row">
              <span>{t.filterCountry} <em>({s.optional})</em></span>
              <select name="country">
                <option value="">—</option>
                <option value="taiwan">{t.countryNames.taiwan}</option>
                <option value="japan">{t.countryNames.japan}</option>
              </select>
            </label>
          </div>

          <label class="konbini-form__row">
            <span>{s.fieldStore} <em>({s.optional})</em></span>
            <input type="text" name="store" maxlength="60" />
          </label>

          <label class="konbini-form__row">
            <span>{s.fieldDisplayName} <em>({s.optional})</em></span>
            <input type="text" name="authorName" maxlength="40" />
          </label>

          <div class="konbini-form__row">
            <span>{s.fieldPhotos} <em>({s.optional})</em></span>
            <input type="file" id="konbini-photos" accept="image/*" multiple />
            <small class="konbini-form__note">{s.photoHint}</small>
            <div class="konbini-form__previews" id="konbini-previews"></div>
          </div>

          <p class="konbini-form__note">{s.moderationNote}</p>
          <button type="submit" class="konbini-form__submit" id="konbini-send" disabled>
            {s.send}
          </button>
          <p class="konbini-form__status" id="konbini-status" role="status" aria-live="polite"></p>
        </form>
      )
    }
  </main>

  {configured && <script is:inline src="https://accounts.google.com/gsi/client" async></script>}

  <script is:inline define:vars={{ sendLabel: s.send, sendingLabel: s.sending }}>
    (function () {
      var form = document.getElementById('konbini-form');
      if (!form) return;
      var clientId = form.getAttribute('data-client-id');
      var statusEl = document.getElementById('konbini-status');
      var sendBtn = document.getElementById('konbini-send');
      var maxPhotos = parseInt(form.getAttribute('data-max-photos'), 10) || 3;
      var tooManyMsg = form.getAttribute('data-msg-toomany');
      var idToken = null;
      var photos = []; // base64 data URLs（已縮圖）

      // ── 照片：選檔後以 canvas 縮圖到最長邊 1600px、JPEG q0.85 ──
      var MAX_EDGE = 1600;
      function downscale(file) {
        return new Promise(function (resolve) {
          var img = new Image();
          var url = URL.createObjectURL(file);
          img.onload = function () {
            var w = img.width, h = img.height;
            var scale = Math.min(1, MAX_EDGE / Math.max(w, h));
            var cw = Math.round(w * scale), ch = Math.round(h * scale);
            var canvas = document.createElement('canvas');
            canvas.width = cw; canvas.height = ch;
            canvas.getContext('2d').drawImage(img, 0, 0, cw, ch);
            URL.revokeObjectURL(url);
            resolve(canvas.toDataURL('image/jpeg', 0.85));
          };
          img.onerror = function () { URL.revokeObjectURL(url); resolve(null); };
          img.src = url;
        });
      }
      var photoInput = document.getElementById('konbini-photos');
      var previews = document.getElementById('konbini-previews');
      if (photoInput) {
        photoInput.addEventListener('change', function () {
          var files = [].slice.call(photoInput.files || []);
          if (files.length > maxPhotos) {
            if (statusEl) statusEl.textContent = tooManyMsg;
            photoInput.value = '';
            return;
          }
          if (statusEl) statusEl.textContent = '';
          photos = [];
          if (previews) previews.innerHTML = '';
          Promise.all(files.map(downscale)).then(function (results) {
            results.forEach(function (dataUrl) {
              if (!dataUrl) return;
              photos.push(dataUrl);
              if (previews) {
                var im = document.createElement('img');
                im.src = dataUrl;
                im.className = 'konbini-form__thumb';
                im.width = 64; im.height = 64;
                previews.appendChild(im);
              }
            });
          });
        });
      }

      // 從 ?product=slug 預選商品
      try {
        var pre = new URLSearchParams(location.search).get('product');
        if (pre) {
          var sel = document.getElementById('konbini-product');
          if (sel && [].some.call(sel.options, function (o) { return o.value === pre; })) {
            sel.value = pre;
          }
        }
      } catch (e) {}

      function onCredential(resp) {
        idToken = resp && resp.credential;
        if (!idToken) return;
        var signed = document.getElementById('konbini-signed');
        if (signed) signed.hidden = false;
        if (sendBtn) sendBtn.disabled = false;
        try {
          var payload = JSON.parse(atob(idToken.split('.')[1]));
          var u = document.getElementById('konbini-user');
          if (u) u.textContent = payload.name || payload.email || '';
        } catch (e) {}
      }

      function initGsi() {
        if (!window.google || !google.accounts || !google.accounts.id) return false;
        google.accounts.id.initialize({ client_id: clientId, callback: onCredential });
        var target = document.getElementById('konbini-gsi');
        if (target) google.accounts.id.renderButton(target, { theme: 'outline', size: 'large' });
        return true;
      }
      if (!initGsi()) {
        var tries = 0;
        var iv = setInterval(function () {
          if (initGsi() || ++tries > 40) clearInterval(iv);
        }, 150);
      }

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        if (!idToken) {
          if (statusEl) statusEl.textContent = form.getAttribute('data-msg-signin');
          return;
        }
        var fd = new FormData(form);
        var payload = {
          idToken: idToken,
          productSlug: fd.get('productSlug'),
          rating: fd.get('rating'),
          title: fd.get('title'),
          body: fd.get('body'),
          price: fd.get('price'),
          currency: fd.get('country') === 'japan' ? 'JPY' : 'TWD',
          store: fd.get('store'),
          country: fd.get('country'),
          authorName: fd.get('authorName'),
          photos: photos,
        };
        if (sendBtn) { sendBtn.disabled = true; sendBtn.textContent = sendingLabel; }
        if (statusEl) statusEl.textContent = '';
        fetch('/api/konbini-submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (r) { return r.ok; })
          .then(function (ok) {
            if (ok) {
              form.reset();
              if (statusEl) statusEl.textContent = form.getAttribute('data-msg-success');
            } else {
              if (statusEl) statusEl.textContent = form.getAttribute('data-msg-error');
            }
          })
          .catch(function () {
            if (statusEl) statusEl.textContent = form.getAttribute('data-msg-error');
          })
          .finally(function () {
            if (sendBtn) { sendBtn.disabled = false; sendBtn.textContent = sendLabel; }
          });
      });
    })();
  </script>
</BaseLayout>
