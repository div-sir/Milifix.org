---
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../i18n/types';
import { konbini } from '../../i18n/konbini';
import { konbiniPath, konbiniProductPath } from '../../i18n/routes';
import { loadKonbiniProduct, averageRating } from '../../lib/konbini';
import { chainName, priceLabel, starString } from '../../lib/konbini-view';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/konbini.css';

interface Props {
  lang: Lang;
  slug: string;
}
const { lang, slug } = Astro.props;
const t = konbini(lang);
const r = t.rate;

const product = await loadKonbiniProduct(slug);
const reviews = product?.reviews ?? [];
const avg = averageRating(reviews);

// 用 PUBLIC_ 前綴才會注入到瀏覽器端。未設定時只顯示「尚未開放」訊息。
const clientId = import.meta.env.PUBLIC_GOOGLE_OAUTH_CLIENT_ID ?? '';
const configured = clientId.length > 0;
---

<BaseLayout
  lang={lang}
  title={product ? `${product.name} — ${t.navLabel}` : t.metaTitle}
  description={product?.description ?? t.metaDesc}
  canonicalPath={konbiniProductPath(lang, slug)}
>
  <AmbientBackdrop />
  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />
  <PageTransition />

  <main class="konbini konbini-detail" id="main-content" tabindex="-1">
    <a class="konbini-back" href={konbiniPath(lang)}>← {t.backToIndex}</a>

    {
      !product ? (
        <p class="konbini-empty">{t.noProducts}</p>
      ) : (
        <article>
          <header class={`konbini-detail__head konbini-accent--${product.country}`}>
            <div class="konbini-detail__cover" aria-hidden="true">
              <span class="konbini-card__cover-category">{t.categoryNames[product.category]}</span>
            </div>
            <div class="konbini-detail__meta">
              <p class="konbini-detail__chain">
                {chainName(product.chain)} · {t.countryNames[product.country]} · {t.categoryNames[product.category]}
              </p>
              <h1 class="konbini-detail__name">{product.name}</h1>
              {reviews.length > 0 ? (
                <p class="konbini-detail__rating">
                  <strong class="konbini-card__rating-value">{avg.toFixed(1)}</strong>
                  <span class="konbini-stars" aria-hidden="true">{starString(avg)}</span>
                  <span>{reviews.length} {t.reviewsUnit}</span>
                </p>
              ) : (
                <p class="konbini-detail__rating konbini-detail__rating--empty">{t.noReviews}</p>
              )}
              {product.price != null && (
                <p class="konbini-detail__price">{t.priceLabel}：{priceLabel(product.price, product.currency, t)}</p>
              )}
              {product.description && <p class="konbini-detail__desc">{product.description}</p>}
            </div>
          </header>

          {
            configured ? (
              <section class="konbini-rate" aria-labelledby="konbini-rate-heading">
                <h2 id="konbini-rate-heading" class="konbini-rate__heading">{r.heading}</h2>

                <div class="konbini-rate__gate" id="konbini-rate-gate">
                  <div id="konbini-gsi" class="konbini-form__gsi" />
                  <p class="konbini-rate__reason">{r.signInReason}</p>
                </div>

                <form
                  class="konbini-form konbini-rate__form"
                  id="konbini-form"
                  hidden
                  data-client-id={clientId}
                  data-product-slug={product.slug}
                  data-msg-signin={r.errorSignIn}
                  data-msg-success={r.success}
                  data-msg-success-updated={r.successUpdated}
                  data-msg-error={r.errorGeneric}
                  data-msg-toomany={r.photoTooMany}
                  data-max-photos="3"
                >
                  <p class="konbini-form__signed">{r.signedInAs} <span id="konbini-user" /></p>

                  <div class="konbini-form__row">
                    <span>{t.ratingLabel}：<strong id="konbini-rating-value">3</strong> / 5</span>
                    <input
                      type="range"
                      name="rating"
                      min="1"
                      max="5"
                      step="1"
                      value="3"
                      class="konbini-rate__slider"
                      id="konbini-rating-input"
                    />
                    <div class="konbini-stars konbini-rate__stars" id="konbini-rating-stars" aria-hidden="true">
                      ★★★☆☆
                    </div>
                  </div>

                  <label class="konbini-form__row">
                    <span>{r.fieldBody} <em>({r.optional})</em></span>
                    <textarea name="body" rows="3" maxlength="1000" />
                  </label>

                  <div class="konbini-form__row">
                    <span>{r.fieldPhotos} <em>({r.optional})</em></span>
                    <input type="file" id="konbini-photos" accept="image/*" multiple />
                    <small class="konbini-form__note">{r.photoHint}</small>
                    <div class="konbini-form__previews" id="konbini-previews" />
                  </div>

                  <p class="konbini-form__note">{r.moderationNote}</p>
                  <button type="submit" class="konbini-form__submit" id="konbini-send">{r.send}</button>
                  <p class="konbini-form__status" id="konbini-status" role="status" aria-live="polite" tabindex="-1" />
                </form>
              </section>
            ) : (
              <p class="konbini-empty">{r.notConfigured}</p>
            )
          }

          {reviews.length > 0 && (
            <section class="konbini-reviews" aria-label={t.reviewsUnit}>
              {reviews.map((rev) => (
                <article class="konbini-review">
                  <header class="konbini-review__head">
                    <span class="konbini-stars konbini-stars--sm" aria-label={`${t.ratingLabel} ${rev.rating} / 5`}>
                      {starString(rev.rating)}
                    </span>
                    {rev.title && <h3 class="konbini-review__title">{rev.title}</h3>}
                  </header>
                  {rev.body && <p class="konbini-review__body">{rev.body}</p>}
                  {rev.photos && rev.photos.length > 0 && (
                    <div class="konbini-review__photos">
                      {rev.photos.map(
                        (ph) =>
                          ph.image?.url && (
                            <img
                              src={ph.image.url}
                              alt={ph.image.alt ?? rev.title ?? product.name}
                              width="240"
                              height="180"
                              loading="lazy"
                              decoding="async"
                            />
                          ),
                      )}
                    </div>
                  )}
                  <footer class="konbini-review__foot">
                    {rev.store && <span>{t.storeLabel}：{rev.store}</span>}
                    {rev.price != null && <span>{priceLabel(rev.price, rev.currency, t)}</span>}
                    {rev.authorName && <span>{t.by} {rev.authorName}</span>}
                    {rev.submittedAt && <span>{rev.submittedAt}</span>}
                  </footer>
                </article>
              ))}
            </section>
          )}
        </article>
      )
    }
  </main>

  {configured && <script is:inline src="https://accounts.google.com/gsi/client" async></script>}

  <script is:inline define:vars={{ sendLabel: r.send, sendingLabel: r.sending, removeLabel: t.removePhoto }}>
    (function () {
      var form = document.getElementById('konbini-form');
      if (!form) return;
      var clientId = form.getAttribute('data-client-id');
      var productSlug = form.getAttribute('data-product-slug');
      var gate = document.getElementById('konbini-rate-gate');
      var statusEl = document.getElementById('konbini-status');
      var sendBtn = document.getElementById('konbini-send');
      var maxPhotos = parseInt(form.getAttribute('data-max-photos'), 10) || 3;
      var tooManyMsg = form.getAttribute('data-msg-toomany');
      var idToken = null;
      var photos = []; // base64 data URLs（已縮圖），與 selectedFiles 一一對應
      var selectedFiles = []; // 目前選取的 File；移除縮圖時要跟 photos 同步剔除

      function prefersReducedMotion() {
        return !!(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches);
      }

      // ── 送出前的原生驗證：checkValidity() 沒過就標紅並交給瀏覽器原生
      // 提示（reportValidity），不送出；:user-invalid 支援的瀏覽器會自動
      // 加樣式，這裡另外加 is-invalid class 當作舊瀏覽器的 fallback。 ──
      var validatableFields = Array.prototype.slice.call(form.querySelectorAll('input, select, textarea'));
      validatableFields.forEach(function (el) {
        el.addEventListener('input', function () { el.classList.remove('is-invalid'); });
        el.addEventListener('change', function () { el.classList.remove('is-invalid'); });
      });

      // ── 評分滑桿：即時更新數字與星號顯示 ──
      var ratingInput = document.getElementById('konbini-rating-input');
      var ratingValue = document.getElementById('konbini-rating-value');
      var ratingStars = document.getElementById('konbini-rating-stars');
      function renderRating() {
        var n = parseInt(ratingInput.value, 10) || 0;
        if (ratingValue) ratingValue.textContent = String(n);
        if (ratingStars) ratingStars.textContent = '★★★★★☆☆☆☆☆'.slice(5 - n, 10 - n);
      }
      if (ratingInput) {
        ratingInput.addEventListener('input', renderRating);
        renderRating();
      }

      // ── 照片：選檔後以 canvas 縮圖到最長邊 1600px、JPEG q0.85 ──
      var MAX_EDGE = 1600;
      function downscale(file) {
        return new Promise(function (resolve) {
          var img = new Image();
          var url = URL.createObjectURL(file);
          img.onload = function () {
            var w = img.width, h = img.height;
            var scale = Math.min(1, MAX_EDGE / Math.max(w, h));
            var cw = Math.round(w * scale), ch = Math.round(h * scale);
            var canvas = document.createElement('canvas');
            canvas.width = cw; canvas.height = ch;
            canvas.getContext('2d').drawImage(img, 0, 0, cw, ch);
            URL.revokeObjectURL(url);
            resolve(canvas.toDataURL('image/jpeg', 0.85));
          };
          img.onerror = function () { URL.revokeObjectURL(url); resolve(null); };
          img.src = url;
        });
      }
      var photoInput = document.getElementById('konbini-photos');
      var previews = document.getElementById('konbini-previews');

      // 用 DataTransfer 重建 input.files，讓移除某張縮圖後 input 內容跟著
      // 同步（原生 FileList 不能直接砍元素）。
      function rebuildPhotoInputFiles() {
        if (typeof DataTransfer === 'undefined' || !photoInput) return;
        var dt = new DataTransfer();
        selectedFiles.forEach(function (f) { dt.items.add(f); });
        photoInput.files = dt.files;
      }

      function renderPhotoPreviews() {
        if (!previews) return;
        previews.innerHTML = '';
        photos.forEach(function (dataUrl, index) {
          var wrap = document.createElement('div');
          wrap.className = 'konbini-form__thumb-wrap';
          var im = document.createElement('img');
          im.src = dataUrl;
          im.alt = '';
          im.className = 'konbini-form__thumb';
          im.width = 64; im.height = 64;
          var removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'konbini-form__thumb-remove';
          removeBtn.setAttribute('aria-label', removeLabel);
          removeBtn.textContent = '×';
          removeBtn.addEventListener('click', function () {
            photos.splice(index, 1);
            selectedFiles.splice(index, 1);
            rebuildPhotoInputFiles();
            renderPhotoPreviews();
          });
          wrap.appendChild(im);
          wrap.appendChild(removeBtn);
          previews.appendChild(wrap);
        });
      }

      if (photoInput) {
        photoInput.addEventListener('change', function () {
          var files = [].slice.call(photoInput.files || []);
          if (files.length > maxPhotos) {
            if (statusEl) statusEl.textContent = tooManyMsg;
            photoInput.value = '';
            return;
          }
          if (statusEl) statusEl.textContent = '';
          selectedFiles = files;
          photos = [];
          Promise.all(files.map(downscale)).then(function (results) {
            photos = [];
            var keptFiles = [];
            results.forEach(function (dataUrl, i) {
              if (!dataUrl) return;
              photos.push(dataUrl);
              keptFiles.push(selectedFiles[i]);
            });
            selectedFiles = keptFiles;
            renderPhotoPreviews();
          });
        });
      }

      // ── 登入前只顯示 Google 按鈕；登入後才揭露評分表單 ──
      // idToken 額外存進 sessionStorage：同一分頁內切換語系／換頁都是整頁
      // 導覽，純記憶體變數會被重置，若不快取就得每次重新登入一次。
      var TOKEN_KEY = 'konbini-id-token';

      function showSignedIn(token) {
        idToken = token;
        if (gate) gate.hidden = true;
        form.hidden = false;
        try {
          var payload = JSON.parse(atob(token.split('.')[1]));
          var u = document.getElementById('konbini-user');
          if (u) u.textContent = payload.name || payload.email || '';
        } catch (e) {}
      }

      function tryRestoreSession() {
        try {
          var cached = sessionStorage.getItem(TOKEN_KEY);
          if (!cached) return;
          var payload = JSON.parse(atob(cached.split('.')[1]));
          if (!payload.exp || payload.exp * 1000 <= Date.now()) {
            sessionStorage.removeItem(TOKEN_KEY);
            return;
          }
          showSignedIn(cached);
        } catch (e) {}
      }
      tryRestoreSession();

      function onCredential(resp) {
        var token = resp && resp.credential;
        if (!token) return;
        try { sessionStorage.setItem(TOKEN_KEY, token); } catch (e) {}
        showSignedIn(token);
      }

      function initGsi() {
        if (!window.google || !google.accounts || !google.accounts.id) return false;
        google.accounts.id.initialize({ client_id: clientId, callback: onCredential });
        var target = document.getElementById('konbini-gsi');
        if (target) google.accounts.id.renderButton(target, { theme: 'outline', size: 'large' });
        return true;
      }
      if (!initGsi()) {
        var tries = 0;
        var iv = setInterval(function () {
          if (initGsi() || ++tries > 40) clearInterval(iv);
        }, 150);
      }

      // 把狀態訊息（成功／錯誤）捲進畫面並交焦點過去，尊重減少動態偏好；
      // 表單可能已經捲出畫面外（尤其手機），不主動捲過去使用者容易漏看。
      function announceStatus(text) {
        if (!statusEl) return;
        statusEl.textContent = text;
        var reduced = prefersReducedMotion();
        statusEl.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'center' });
        statusEl.focus();
      }

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        validatableFields.forEach(function (el) { el.classList.remove('is-invalid'); });
        if (!form.checkValidity()) {
          validatableFields.forEach(function (el) {
            if (el.willValidate && !el.checkValidity()) el.classList.add('is-invalid');
          });
          form.reportValidity();
          return;
        }
        if (!idToken) {
          announceStatus(form.getAttribute('data-msg-signin'));
          return;
        }
        var payload = {
          idToken: idToken,
          productSlug: productSlug,
          rating: ratingInput ? ratingInput.value : 3,
          body: new FormData(form).get('body'),
          photos: photos,
        };
        if (sendBtn) { sendBtn.disabled = true; sendBtn.textContent = sendingLabel; }
        if (statusEl) statusEl.textContent = '';
        var responseOk = false;
        fetch('/api/konbini-submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            responseOk = res.ok;
            if (res.status === 401) {
              // 快取的 token 過期／失效：清掉快取、讓登入按鈕重新出現，
              // 但表單維持可見、內容不清空，重新登入後可以直接再送出。
              try { sessionStorage.removeItem(TOKEN_KEY); } catch (e) {}
              idToken = null;
              if (gate) gate.hidden = false;
            }
            return res.json();
          })
          .then(function (data) {
            if (responseOk) {
              announceStatus(
                data && data.updated
                  ? form.getAttribute('data-msg-success-updated')
                  : form.getAttribute('data-msg-success'),
              );
            } else {
              announceStatus(form.getAttribute('data-msg-error'));
            }
          })
          .catch(function () {
            announceStatus(form.getAttribute('data-msg-error'));
          })
          .finally(function () {
            if (sendBtn) { sendBtn.disabled = false; sendBtn.textContent = sendLabel; }
          });
      });
    })();
  </script>
</BaseLayout>
