---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <title>{t.htmlTitle}</title>
  <meta name="description" content={t.metaDesc} />
  <link rel="alternate" hreflang="en" href={langUrls.en} />
  <link rel="alternate" hreflang="zh-Hant" href={langUrls.zh} />
  <link rel="alternate" hreflang="ja" href={langUrls.ja} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sans: 'Space Grotesk', sans-serif;
      --mono: 'Space Mono', monospace;
      --lv-accent: #39C5BB;
      --lv-accent-dim: rgba(57, 197, 187, 0.12);
      --lv-accent-border: rgba(57, 197, 187, 0.28);
      --lv-card: color-mix(in srgb, var(--bg2) 80%, var(--bg3));
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      line-height: 1.7;
      cursor: none;
    }

    #cursor {
      width: 8px; height: 8px; background: var(--lv-accent);
      border-radius: 50%; position: fixed; pointer-events: none;
      z-index: 9999; transform: translate(-50%, -50%);
      transition: width 0.2s, height 0.2s;
    }
    #cursor-ring {
      width: 32px; height: 32px; border: 1px solid rgba(57,197,187,0.4);
      border-radius: 50%; position: fixed; pointer-events: none;
      z-index: 9998; transform: translate(-50%, -50%);
      transition: transform 0.12s ease-out, width 0.25s, height 0.25s;
    }
    body:has(a:hover) #cursor { width: 12px; height: 12px; }
    body:has(a:hover) #cursor-ring { width: 48px; height: 48px; }

    @media (max-width: 768px) {
      body { cursor: auto !important; }
      #cursor, #cursor-ring { display: none !important; }
    }

    .divider { border: none; border-top: 1px solid var(--line); margin: 0 24px; }

    /* ── Hero ── */
    .lv-hero {
      position: relative;
      text-align: center;
      padding: 130px 24px 110px;
      overflow: hidden;
    }

    /* Animated radial glow behind hero */
    .lv-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 75% 60% at 50% 0%, rgba(57,197,187,0.14) 0%, transparent 70%);
      animation: lv-glow-pulse 5s ease-in-out infinite alternate;
      pointer-events: none;
    }

    @keyframes lv-glow-pulse {
      from { opacity: 0.7; transform: scaleX(1) scaleY(1); }
      to   { opacity: 1;   transform: scaleX(1.08) scaleY(1.12); }
    }

    /* Floating orbs */
    .lv-hero__orb {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(57,197,187,0.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .lv-hero__orb--a {
      width: 320px; height: 320px;
      top: -80px; left: calc(50% - 400px);
      animation: lv-orb-a 8s ease-in-out infinite alternate;
    }
    .lv-hero__orb--b {
      width: 240px; height: 240px;
      top: 20px; right: calc(50% - 380px);
      animation: lv-orb-b 10s ease-in-out infinite alternate;
    }

    @keyframes lv-orb-a {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(20px, 30px) scale(1.1); }
    }
    @keyframes lv-orb-b {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(-15px, 20px) scale(0.92); }
    }

    /* Animated grid lines overlay */
    .lv-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(57,197,187,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(57,197,187,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 0%, transparent 75%);
      pointer-events: none;
      animation: lv-grid-drift 12s ease-in-out infinite alternate;
    }

    @keyframes lv-grid-drift {
      from { background-position: 0 0; }
      to   { background-position: 15px 15px; }
    }

    .lv-hero__inner {
      position: relative;
      z-index: 1;
    }

    .lv-hero h1 {
      font-size: clamp(2.6rem, 7vw, 4.8rem);
      font-weight: 800; letter-spacing: 0.02em; line-height: 1.28;
      margin-bottom: 28px;
      animation: lv-hero-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes lv-hero-in {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .lv-hero h1 em {
      font-style: normal;
      color: var(--lv-accent);
      position: relative;
    }

    /* Underline accent on em */
    .lv-hero h1 em::after {
      content: '';
      position: absolute;
      bottom: -4px; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--lv-accent), rgba(57,197,187,0));
      border-radius: 2px;
      animation: lv-underline-in 1.2s 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes lv-underline-in {
      from { transform: scaleX(0); transform-origin: left; }
      to   { transform: scaleX(1); transform-origin: left; }
    }

    .lv-hero__desc {
      max-width: 520px; margin: 0 auto;
      font-size: 1.1rem; color: var(--muted); line-height: 1.75;
      animation: lv-hero-in 0.9s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    /* ── Section ── */
    .lv-section { padding: 96px 24px; max-width: 1100px; margin: 0 auto; }
    .lv-section-label {
      font-family: var(--mono); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--lv-accent); margin-bottom: 12px;
    }
    .lv-section-title {
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      font-weight: 800; letter-spacing: -0.02em; line-height: 1.18; margin-bottom: 16px;
    }
    .lv-section-sub { color: var(--muted); max-width: 500px; margin-bottom: 56px; font-size: 1rem; line-height: 1.7; }

    /* ── Feature rows ── */
    .lv-feature-grid { display: flex; flex-direction: column; gap: 2px; }

    .lv-card {
      display: grid;
      grid-template-columns: 64px 220px 1fr;
      align-items: center;
      gap: 0;
      border: 1px solid var(--line2);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color 0.22s, background 0.22s;
      background: var(--lv-card);
    }

    .lv-card:first-child { border-radius: 16px 16px 6px 6px; }
    .lv-card:last-child  { border-radius: 6px 6px 16px 16px; }
    .lv-card:not(:first-child):not(:last-child) { border-radius: 6px; }

    .lv-card:hover {
      border-color: var(--lv-accent-border);
      background: color-mix(in srgb, var(--lv-card) 85%, rgba(57,197,187,0.06));
    }

    .lv-card__icon {
      width: 64px; height: 64px;
      display: flex; align-items: center; justify-content: center;
      color: var(--lv-accent);
      flex-shrink: 0;
      border-right: 1px solid var(--line2);
    }

    .lv-card__title {
      padding: 20px 24px;
      font-size: 0.95rem; font-weight: 700; letter-spacing: -0.01em;
      border-right: 1px solid var(--line2);
      height: 100%;
      display: flex; align-items: center;
    }

    .lv-card__body {
      padding: 16px 28px;
      color: var(--muted); font-size: 0.9rem; line-height: 1.65;
    }

    @media (max-width: 680px) {
      .lv-card {
        grid-template-columns: 52px 1fr;
        grid-template-rows: auto auto;
      }
      .lv-card__icon { width: 52px; height: 52px; border-right: none; border-bottom: 1px solid var(--line2); }
      .lv-card__title { padding: 14px 16px; border-right: none; border-bottom: none; height: auto; }
      .lv-card__body { grid-column: 1 / -1; padding: 0 16px 16px; border-top: 1px solid var(--line2); }
    }

    /* ── Steps ── */
    .lv-steps { display: flex; flex-direction: column; gap: 0; }
    .lv-step { display: grid; grid-template-columns: 52px 1fr; gap: 20px; position: relative; padding-bottom: 44px; }
    .lv-step:last-child { padding-bottom: 0; }
    .lv-step__num {
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--lv-accent-dim); border: 2px solid var(--lv-accent);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--mono); font-size: 0.95rem; font-weight: 700; color: var(--lv-accent);
      flex-shrink: 0;
    }
    .lv-step__line {
      position: absolute; left: 26px; top: 52px; bottom: 0;
      width: 2px; background: var(--lv-accent-border);
    }
    .lv-step:last-child .lv-step__line { display: none; }
    .lv-step__content { padding-top: 10px; }
    .lv-step__content h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 6px; letter-spacing: -0.01em; }
    .lv-step__content p { color: var(--muted); font-size: 0.92rem; line-height: 1.68; }

    /* ── FAQ ── */
    .lv-faq { display: flex; flex-direction: column; gap: 12px; }
    details {
      background: var(--lv-card); border: 1px solid var(--line2);
      border-radius: 16px; overflow: hidden; transition: border-color 0.2s;
    }
    details[open] { border-color: var(--lv-accent-border); }
    summary {
      padding: 20px 24px; font-weight: 600; font-size: 0.95rem;
      cursor: pointer; list-style: none;
      display: flex; justify-content: space-between; align-items: center; gap: 16px;
    }
    summary::-webkit-details-marker { display: none; }
    summary::after {
      content: "+"; color: var(--lv-accent);
      font-size: 1.3rem; font-weight: 300; flex-shrink: 0; line-height: 1;
      font-family: var(--mono);
    }
    details[open] summary::after { content: "−"; }
    .lv-faq-body { padding: 0 24px 20px; color: var(--muted); font-size: 0.92rem; line-height: 1.72; }

    /* ── Contact (smaller) ── */
    .lv-contact {
      background: var(--lv-card); border: 1px solid var(--lv-accent-border);
      border-radius: 20px; padding: 36px 40px; text-align: center;
    }
    .lv-contact h2 { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 8px; }
    .lv-contact p { color: var(--muted); margin-bottom: 24px; font-size: 0.95rem; }
    .lv-contact-email {
      display: inline-block;
      background: var(--lv-accent-dim); border: 1px solid var(--lv-accent-border);
      color: var(--lv-accent); font-family: var(--mono);
      font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em;
      padding: 10px 24px; border-radius: 100px; text-decoration: none;
      transition: background 0.2s;
    }
    .lv-contact-email:hover { background: rgba(57,197,187,0.2); }

    /* ── Footer ── */
    .lv-footer {
      text-align: center; padding: 36px 24px;
      color: var(--muted-dim); font-family: var(--mono);
      font-size: 0.75rem; letter-spacing: 0.06em;
      border-top: 1px solid var(--line);
    }

    @media (max-width: 640px) {
      .lv-hero { padding: 88px 24px 72px; }
      .lv-section { padding: 72px 24px; }
      .lv-contact { padding: 28px 20px; }
      .lv-hero__orb { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      .lv-hero::before, .lv-hero::after,
      .lv-hero__orb, .lv-hero h1, .lv-hero__desc,
      .lv-hero h1 em::after { animation: none !important; }
    }
  </style>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav variant="platform" lang={lang} pathname={pathname} />

  <PortfolioChrome
    lang={lang}
    pathname={pathname}
    dockSections={t.dockSections}
    dockHomeHref={lang === 'en' ? '/' : `/${lang}/`}
    dockHomeLabel="Milifix"
    dockHomeIcon="home"
    dockOrder="sections-first"
  />

  <!-- Hero -->
  <div class="lv-hero">
    <div class="lv-hero__orb lv-hero__orb--a"></div>
    <div class="lv-hero__orb lv-hero__orb--b"></div>
    <div class="lv-hero__inner">
      <h1><em>{t.h1a}</em><br>{t.h1b}</h1>
      <p class="lv-hero__desc">{t.heroDesc}</p>
    </div>
  </div>

  <hr class="divider" />

  <!-- Features -->
  <section class="lv-section" id="lv-features">
    <p class="lv-section-label">{t.featLabel}</p>
    <h2 class="lv-section-title">{t.featTitle}</h2>
    <p class="lv-section-sub">{t.featSub}</p>
    <div class="lv-feature-grid">
      {t.features.map((f) => (
        <div class="lv-card">
          <div class="lv-card__icon" set:html={ICONS[f.icon as keyof typeof ICONS]} />
          <div class="lv-card__title">{f.title}</div>
          <div class="lv-card__body">{f.body}</div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <!-- How it works -->
  <section class="lv-section" id="lv-steps">
    <p class="lv-section-label">{t.stepsLabel}</p>
    <h2 class="lv-section-title">{t.stepsTitle}</h2>
    <p class="lv-section-sub">{t.stepsSub}</p>
    <div class="lv-steps">
      {t.steps.map((s, i) => (
        <div class="lv-step">
          <div class="lv-step__num">{String(i + 1).padStart(2, '0')}</div>
          <div class="lv-step__line"></div>
          <div class="lv-step__content">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <!-- FAQ -->
  <section class="lv-section" id="support">
    <p class="lv-section-label">{t.faqLabel}</p>
    <h2 class="lv-section-title">{t.faqTitle}</h2>
    <p class="lv-section-sub">{t.faqSub}</p>
    <div class="lv-faq">
      {t.faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <div class="lv-faq-body">{f.a}</div>
        </details>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <!-- Contact -->
  <section class="lv-section">
    <div class="lv-contact">
      <h2>{t.contactTitle}</h2>
      <p>{t.contactDesc}</p>
      <a class="lv-contact-email" href="mailto:steven33152239@gmail.com">
        steven33152239@gmail.com
      </a>
    </div>
  </section>

  <footer class="lv-footer">{t.footer}</footer>

  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    import { initTheme } from '../../scripts/theme-init';
    initTheme();
    initPortfolioCursor();
  </script>
</body>
</html>
