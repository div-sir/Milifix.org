---
import { getLounges, getAirlines, getCreditCards, getPrograms } from '../../lib/cms';
import type { CmsLounge, CmsAirline, CmsCreditCard, CmsProgram } from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import LoungeCard from '../travel/LoungeCard.astro';
import AirlineCard from '../travel/AirlineCard.astro';
import CreditCardCard from '../travel/CreditCardCard.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import TravelBottomNav from '../travel/TravelBottomNav.astro';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import { travelPath } from '../../i18n/routes';
import { getProgramTierInfo } from '../../data/program-tiers';

interface Props { lang: Lang; program: CmsProgram; }
const { lang, program } = Astro.props;
const t = ui(lang).travel;

// 貴賓室網路歸「貴賓室」區塊；飯店／航空聯盟歸「飯店與航空聯盟」區塊
const isLoungeNetwork = program.programType === 'lounge-network';
const backSection = isLoungeNetwork ? 'lounges' : 'programs';
const sectionContext = isLoungeNetwork ? t.sectionLounges : t.programs;

// 整個計畫的說明與各會籍等級（本地參考資料，覆寫 CMS 的分等級名稱）
const tierInfo = getProgramTierInfo(lang, program.slug);
const displayName = tierInfo?.displayName ?? program.name;
const introText = tierInfo?.intro ?? program.summary;

const [allLounges, allPrograms] = await Promise.all([getLounges(), getPrograms()]);
const programNameKeywords = program.name
  .replace(/（.*?）/g, '')
  .replace(/\(.*?\)/g, '')
  .split(/[\/\s]+/)
  .filter((w) => w.length > 2);

const relatedLounges = allLounges.filter((l) =>
  programNameKeywords.some((kw) => (l.network ?? '').includes(kw)),
);

// Group lounges by airport
const loungesByAirport = new Map<string, CmsLounge[]>();
for (const l of relatedLounges) {
  const key = `${l.airport} (${l.airportCode})`;
  if (!loungesByAirport.has(key)) loungesByAirport.set(key, []);
  loungesByAirport.get(key)!.push(l);
}

// Find airlines belonging to this alliance (for airline-alliance type)
const allAirlines = await getAirlines();
const allianceSlugMap: Record<string, string> = {
  'star-alliance': 'star-alliance',
  'oneworld': 'oneworld',
  'skyteam': 'skyteam',
};
const relatedAirlines = program.programType === 'airline-alliance'
  ? allAirlines.filter((a) => a.alliance === (allianceSlugMap[program.slug] ?? ''))
  : [];

// Find cards that have this program linked in benefits
const allCards = await getCreditCards();
function isPopulatedProgram(v: unknown): v is CmsProgram {
  return typeof v === 'object' && v !== null && 'slug' in v;
}
const relatedCards = allCards.filter((card) =>
  card.benefits.some((b) =>
    (b.program ?? []).some((p) =>
      isPopulatedProgram(p) ? p.slug === program.slug : p === program.id,
    ),
  ),
);
---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{program.name} — {sectionContext} — Milifix</title>
  <meta name="description" content={program.summary} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <article class="travel-detail">
      <a class="travel-detail__back" href={`${travelPath(lang)}#${backSection}`}>{t.backToTravel}</a>

      <header class="travel-detail__header">
        <p class="travel-detail__overline">
          {t.programTypeNames[program.programType]}
        </p>
        <h1 class="travel-detail__title">{displayName}</h1>
        <p class="travel-detail__desc">{introText}</p>
        {tierInfo?.note && <p class="program-note">{tierInfo.note}</p>}
      </header>

      {program.logo?.url && (
        <img class="travel-detail__image travel-detail__image--contain" src={program.logo.url} alt={program.name} />
      )}

      {program.website && (
        <div class="travel-info" style="margin-bottom: 2rem;">
          <span class="travel-info__label">{t.website}</span>
          <span class="travel-info__value">
            <a href={program.website} target="_blank" rel="noopener noreferrer" style="color: var(--travel-accent); text-decoration: none;">
              {program.website.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗
            </a>
          </span>
        </div>
      )}

      {tierInfo?.tiers && tierInfo.tiers.length > 0 && (
        <section class="program-tiers" style="margin-top: 2.5rem;">
          <h2 class="travel-related__title">{t.membershipTiers}</h2>
          <div class="program-tiers__list">
            {tierInfo.tiers.map((tier) => (
              <div class:list={['program-tier', tier.granted && 'is-granted']}>
                <div class="program-tier__head">
                  <span class="program-tier__name">{tier.name}</span>
                  {tier.granted && <span class="program-tier__badge">{t.tierGranted}</span>}
                  {tier.qualify && <span class="program-tier__qualify">{tier.qualify}</span>}
                </div>
                <ul class="program-tier__services">
                  {tier.services.map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}

      {tierInfo?.perks && tierInfo.perks.length > 0 && (
        <section class="program-tiers" style="margin-top: 2.5rem;">
          <h2 class="travel-related__title">{t.includedBenefits}</h2>
          <div class="program-tier program-tier--flat">
            <ul class="program-tier__services">
              {tierInfo.perks.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {loungesByAirport.size > 0 && (
        <section class="travel-related" style="margin-top: 2.5rem;">
          <h2 class="travel-related__title">{t.sectionLounges}</h2>
          {[...loungesByAirport.entries()].map(([airport, lounges]) => (
            <div style="margin-bottom: 1.5rem;">
              <h3 style="font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: color-mix(in srgb, var(--text) 50%, transparent); margin-bottom: 0.75rem;">
                {airport}
              </h3>
              <div class="travel-grid">
                {lounges.map((l) => (
                  <LoungeCard lang={lang} lounge={l} programs={allPrograms} />
                ))}
              </div>
            </div>
          ))}
        </section>
      )}

      {relatedAirlines.length > 0 && (
        <section class="travel-related" style="margin-top: 2.5rem;">
          <h2 class="travel-related__title">{t.sectionAirlines}</h2>
          <div class="travel-grid">
            {relatedAirlines.map((a) => (
              <AirlineCard lang={lang} airline={a} />
            ))}
          </div>
        </section>
      )}

      {relatedCards.length > 0 && (
        <section class="travel-related" style="margin-top: 2.5rem;">
          <h2 class="travel-related__title">{t.relatedCards}</h2>
          <div class="travel-grid">
            {relatedCards.map((c) => (
              <CreditCardCard lang={lang} card={c} />
            ))}
          </div>
        </section>
      )}
    </article>
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    initPortfolioCursor();
  </script>
  <TravelBottomNav lang={lang} current={backSection} />
</body>
</html>
