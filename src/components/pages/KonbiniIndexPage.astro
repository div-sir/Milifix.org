---
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import KonbiniNewProductForm from './KonbiniNewProductForm.astro';
import type { Lang } from '../../i18n/types';
import { konbini } from '../../i18n/konbini';
import { konbiniPath, konbiniProductPath } from '../../i18n/routes';
import { loadKonbiniProducts, averageRating } from '../../lib/konbini';
import { chainName, priceLabel, starString } from '../../lib/konbini-view';
import type { KonbiniCountry } from '../../lib/cms';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/konbini.css';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = konbini(lang);

const products = await loadKonbiniProducts();

const cards = products.map((p) => {
  const reviews = p.reviews ?? [];
  return {
    slug: p.slug,
    name: p.name,
    country: p.country,
    category: p.category,
    chain: chainName(p.chain),
    avg: averageRating(reviews),
    count: reviews.length,
    price: priceLabel(p.price, p.currency, t),
  };
});

// 「店家評分」分頁：先按國家分區（台灣／日本各自不同主題色），
// 再按連鎖店分組，讓「網站收錄了哪些店家」一眼看清楚。
const COUNTRY_ORDER: KonbiniCountry[] = ['taiwan', 'japan'];
const countryGroups = COUNTRY_ORDER.map((country) => {
  const inCountry = cards.filter((c) => c.country === country);
  const chainMap = new Map<string, typeof cards>();
  for (const c of inCountry) {
    const list = chainMap.get(c.chain) ?? [];
    list.push(c);
    chainMap.set(c.chain, list);
  }
  const chains = [...chainMap.entries()]
    .sort((a, b) => a[0].localeCompare(b[0]))
    .map(([name, items]) => ({ name, items }));
  return { country, chains };
}).filter((g) => g.chains.length > 0);
---

<BaseLayout
  lang={lang}
  title={t.metaTitle}
  description={t.metaDesc}
  canonicalPath={konbiniPath(lang)}
>
  <AmbientBackdrop />
  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />
  <PageTransition />

  <main class="konbini" id="main-content" tabindex="-1">
    <header class="konbini-hero">
      <p class="konbini-hero__tag">{t.heroTag}</p>
      <h1 class="konbini-hero__title">{t.heroTitle}</h1>
      <p class="konbini-hero__desc">{t.heroDesc}</p>
    </header>

    <div class="konbini-tabs" role="tablist" aria-label={t.navLabel}>
      <button class="konbini-tab is-active" data-tab="stores" type="button" role="tab" aria-selected="true">
        {t.tabStores}
      </button>
      <button class="konbini-tab" data-tab="add" type="button" role="tab" aria-selected="false">
        {t.tabAdd}
      </button>
    </div>

    <div class="konbini-tabpanel" data-panel="stores">
      {
        countryGroups.length === 0 ? (
          <p class="konbini-empty">{t.noProducts}</p>
        ) : (
          <>
            {countryGroups.length > 1 && (
              <div class="konbini-country-tabs" role="tablist" aria-label={t.filterCountry}>
                {countryGroups.map((g, i) => (
                  <button
                    type="button"
                    class={`konbini-country-tab konbini-country-tab--${g.country} ${i === 0 ? 'is-active' : ''}`}
                    data-country-tab={g.country}
                    role="tab"
                    aria-selected={i === 0 ? 'true' : 'false'}
                  >
                    {t.countryNames[g.country]}
                  </button>
                ))}
              </div>
            )}
            {countryGroups.map((g, gi) => (
              <section
                class={`konbini-country konbini-country--${g.country}`}
                data-country-panel={g.country}
                hidden={countryGroups.length > 1 && gi !== 0}
              >
                <h2 class="konbini-country__title">{t.countryNames[g.country]}</h2>
                {g.chains.length > 1 && (
                  <div class="konbini-chain-tabs" role="tablist" aria-label={t.filterChain}>
                    {g.chains.map((chain, ci) => (
                      <button
                        type="button"
                        class={`konbini-chain-tab ${ci === 0 ? 'is-active' : ''}`}
                        data-chain-tab={chain.name}
                        role="tab"
                        aria-selected={ci === 0 ? 'true' : 'false'}
                      >
                        {chain.name}
                      </button>
                    ))}
                  </div>
                )}
                {g.chains.map((chain, ci) => (
                  <div
                    class="konbini-chain-group"
                    data-chain-panel={chain.name}
                    hidden={g.chains.length > 1 && ci !== 0}
                  >
                    <h3 class="konbini-chain-group__title">{chain.name}</h3>
                    <ul class="konbini-grid">
                      {chain.items.map((c) => (
                        <li class="konbini-card">
                          <a class="konbini-card__link" href={konbiniProductPath(lang, c.slug)}>
                            <div class={`konbini-card__cover konbini-card__cover--${c.category}`} aria-hidden="true">
                              <span class="konbini-card__cover-label">{c.name}</span>
                            </div>
                            <div class="konbini-card__body">
                              <h4 class="konbini-card__name">{c.name}</h4>
                              <p class="konbini-card__meta">
                                <span class="konbini-stars" aria-label={`${t.ratingLabel} ${c.avg.toFixed(1)} / 5`}>
                                  {starString(c.avg)}
                                </span>
                                <span class="konbini-card__count">
                                  {c.count > 0 ? `${c.avg.toFixed(1)} · ${c.count} ${t.reviewsUnit}` : t.noReviews}
                                </span>
                              </p>
                              {c.price && <p class="konbini-card__price">{c.price}</p>}
                            </div>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </section>
            ))}
          </>
        )
      }
    </div>

    <div class="konbini-tabpanel" data-panel="add" hidden>
      <p class="konbini-tabpanel__intro">{t.heroHint}</p>
      <KonbiniNewProductForm lang={lang} />
    </div>
  </main>

  <script is:inline>
    (function () {
      var tabs = document.querySelectorAll('.konbini-tab');
      var panels = document.querySelectorAll('.konbini-tabpanel');
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (t) {
            t.classList.remove('is-active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('is-active');
          tab.setAttribute('aria-selected', 'true');
          var target = tab.getAttribute('data-tab');
          panels.forEach(function (p) {
            p.hidden = p.getAttribute('data-panel') !== target;
          });
        });
      });

      // ── 國家切換：店家評分分頁內，切換只看台灣或只看日本 ──
      var countryTabs = document.querySelectorAll('.konbini-country-tab');
      var countrySections = document.querySelectorAll('[data-country-panel]');
      countryTabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          countryTabs.forEach(function (t) {
            t.classList.remove('is-active');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.add('is-active');
          tab.setAttribute('aria-selected', 'true');
          var target = tab.getAttribute('data-country-tab');
          countrySections.forEach(function (s) {
            s.hidden = s.getAttribute('data-country-panel') !== target;
          });
        });
      });

      // ── 連鎖店切換：每個國家區塊各自的連鎖店標籤，一次只看一家 ──
      countrySections.forEach(function (section) {
        var chainTabs = section.querySelectorAll('.konbini-chain-tab');
        var chainGroups = section.querySelectorAll('[data-chain-panel]');
        chainTabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            chainTabs.forEach(function (t) {
              t.classList.remove('is-active');
              t.setAttribute('aria-selected', 'false');
            });
            tab.classList.add('is-active');
            tab.setAttribute('aria-selected', 'true');
            var target = tab.getAttribute('data-chain-tab');
            chainGroups.forEach(function (g) {
              g.hidden = g.getAttribute('data-chain-panel') !== target;
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>
