---
import type { CmsAirline, CmsLounge, CmsProgram } from '../../lib/cms';
import { getPrograms, getCreditCards } from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import RealisticCreditCard from '../travel/RealisticCreditCard.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import TravelBottomNav from '../travel/TravelBottomNav.astro';
import CompareModal from '../travel/CompareModal.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Lang } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import {
  travelPath,
  loungeSlugPath,
  programSlugPath,
} from '../../i18n/routes';
import type { CmsCreditCard, CmsBenefitType } from '../../lib/cms';

interface Props {
  lang: Lang;
  card: CmsCreditCard;
}

const { lang, card } = Astro.props;
const t = ui(lang).travel;

// 全部卡片資料供比較 Modal 使用
const allCards = await getCreditCards();

const feeDisplay =
  card.annualFee === 0
    ? t.annualFeeWaived
    : `NT$ ${card.annualFee.toLocaleString()}`;

function isPopulated(v: unknown): v is { id: string; slug: string; name: string; iataCode?: string; airportCode?: string } {
  return typeof v === 'object' && v !== null && 'slug' in v;
}

function isPopulatedProgram(v: unknown): v is CmsProgram {
  return typeof v === 'object' && v !== null && 'slug' in v;
}

// Fallback: auto-detect programs from text when CMS relationship isn't set yet
const allPrograms = await getPrograms();
const programKeywords: Record<string, string[]> = {
  'priority-pass': ['Priority Pass'],
  'loungekey': ['LoungeKey'],
  'dragon-pass': ['Dragon Pass', '龍騰'],
  'plaza-premium': ['Plaza Premium', '環亞'],
  'amex-centurion-network': ['Centurion Network', 'Centurion Lounge', 'AMEX Centurion'],
  'amex-fhr': ['FHR', 'Fine Hotels'],
  'marriott-bonvoy': ['萬豪金卡', '萬豪旅享家', 'Marriott'],
  'hilton-honors': ['希爾頓金卡', '希爾頓榮譽', 'Hilton'],
  'star-alliance': ['Star Alliance', '星空聯盟'],
  'oneworld': ['oneworld', '寰宇一家'],
  'skyteam': ['SkyTeam', '天合聯盟'],
};
function autoDetectPrograms(text: string): CmsProgram[] {
  const found: CmsProgram[] = [];
  for (const [slug, kws] of Object.entries(programKeywords)) {
    if (kws.some((kw) => text.includes(kw))) {
      const p = allPrograms.find((pr) => pr.slug === slug);
      if (p) found.push(p);
    }
  }
  return found;
}

function getBenefitPrograms(b: typeof card.benefits[number]): CmsProgram[] {
  const explicit = (b.program ?? []).filter(isPopulatedProgram);
  if (explicit.length > 0) return explicit;
  return autoDetectPrograms(b.title + ' ' + (b.description ?? ''));
}

// Group benefits by type
const typeOrder: CmsBenefitType[] = [
  'miles', 'lounge', 'upgrade', 'priority-boarding', 'baggage', 'insurance',
  'airport-transfer', 'airline-membership', 'flight-discount', 'duty-free-discount',
  'cashback', 'hotel', 'airport-parking', 'other',
];
const benefitsByType = typeOrder
  .map((type) => ({
    type,
    label: t.benefitTypes[type] ?? type,
    items: card.benefits.filter((b) => b.benefitType === type),
  }))
  .filter((g) => g.items.length > 0);

// ── 相關連結（去重）：把這張卡連到的航空 / 貴賓室 / 計畫彙整成總覽 ──
function dedupeBySlug<T extends { slug: string }>(items: T[]): T[] {
  const seen = new Set<string>();
  return items.filter((it) => (seen.has(it.slug) ? false : (seen.add(it.slug), true)));
}

const relatedAirlines = dedupeBySlug(
  card.benefits.map((b) => b.airline).filter((a): a is CmsAirline => isPopulated(a))
);
const relatedLounges = dedupeBySlug(
  card.benefits.map((b) => b.lounge).filter((l): l is CmsLounge => isPopulated(l))
);
const relatedPrograms = dedupeBySlug(card.benefits.flatMap(getBenefitPrograms));
const hasRelated = relatedAirlines.length > 0 || relatedLounges.length > 0 || relatedPrograms.length > 0;

// ── 結構化資料（JSON-LD）供搜尋引擎理解這是一張信用卡商品 ──
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreditCard',
  name: `${card.bank} ${card.name}`,
  ...(card.description ? { description: card.description } : {}),
  url: new URL(Astro.url.pathname, Astro.site).href,
  ...(card.officialUrl ? { sameAs: card.officialUrl } : {}),
  provider: { '@type': 'BankOrCreditUnion', name: card.bank },
  feesAndCommissionsSpecification:
    card.annualFee === 0
      ? (lang === 'zh' ? '免年費' : 'No annual fee')
      : `NT$ ${card.annualFee.toLocaleString()}${card.annualFeeNote ? `（${card.annualFeeNote}）` : ''}`,
  ...(card.benefits.length
    ? { amenityFeature: card.benefits.map((b) => ({ '@type': 'LocationFeatureSpecification', name: b.title, value: true })) }
    : {}),
};
---

<BaseLayout
  lang={lang}
  title={`${card.name} — ${t.sectionCards} — Milifix`}
  description={card.description}
  canonicalPath={Astro.url.pathname}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <article class="travel-detail">
      <a class="travel-detail__back" href={`${travelPath(lang)}#cards`}>{t.backToTravel}</a>

      <header class="travel-detail__header">
        <p class="travel-detail__overline">{card.bank} · {card.cardNetwork.toUpperCase()}</p>
        <h1 class="travel-detail__title">{card.name}</h1>
        <p class="travel-detail__desc">
          {t.annualFee}：{feeDisplay}
          {card.annualFeeNote && <span class="travel-detail__fee-note">（{card.annualFeeNote}）</span>}
          {card.annualFeeWaivable === 'no' && <span class="travel-detail__fee-note">（{t.annualFeeNotWaivable}）</span>}
        </p>
      </header>

      <div class="travel-detail__card3d">
        <RealisticCreditCard lang={lang} card={card} link={false} />
      </div>

      <div class="travel-detail__compare-action">
        <button type="button" class="travel-detail__compare-btn" id="detail-compare-btn" data-slug={card.slug}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span id="detail-compare-label">{lang === 'zh' ? '加入比較' : 'Add to compare'}</span>
        </button>
      </div>

      <div class="travel-detail__meta-grid">
        {card.supplementaryCardFee != null && (
          <div class="travel-info">
            <span class="travel-info__label">{t.supplementaryCard}</span>
            <span class="travel-info__value">
              {card.supplementaryCardFee === 0 ? t.supplementaryCardFree : `NT$ ${card.supplementaryCardFee.toLocaleString()}`}
              {card.supplementaryCardMax != null && (lang === 'zh' ? `（最多 ${card.supplementaryCardMax} 張）` : ` (max ${card.supplementaryCardMax})`)}
            </span>
          </div>
        )}
        {card.signUpBonus && (
          <div class="travel-info">
            <span class="travel-info__label">{t.signUpBonus}</span>
            <span class="travel-info__value">{card.signUpBonus}</span>
          </div>
        )}
        {card.renewalBonus && (
          <div class="travel-info">
            <span class="travel-info__label">{t.renewalBonus}</span>
            <span class="travel-info__value">{card.renewalBonus}</span>
          </div>
        )}
      </div>

      {card.tags.length > 0 && (
        <div class="travel-card__tags" style="margin-bottom: 2rem;">
          {card.tags.map((tag) => (
            <a class="travel-tag travel-tag--clickable" href={`${travelPath(lang)}#cards`}>
              {tag.tag}
            </a>
          ))}
        </div>
      )}

      {card.officialUrl && (
        <div class="travel-info" style="margin-bottom: 1.5rem;">
          <span class="travel-info__label">{t.website}</span>
          <span class="travel-info__value">
            <a href={card.officialUrl} target="_blank" rel="noopener noreferrer" style="color: var(--travel-accent); text-decoration: none;">
              {lang === 'zh' ? `${card.bank}官方卡片介紹` : 'Official card page'} ↗
            </a>
          </span>
        </div>
      )}

      {card.description && (
        <p class="travel-detail__summary">{card.description}</p>
      )}

      {benefitsByType.length > 0 && (
        <section class="travel-benefits">
          <h2 class="travel-benefits__title">{t.benefits}</h2>

          {benefitsByType.map((group) => (
            <div class="card-benefit-group">
              <h3 class="card-benefit-group__title">
                <span class="travel-tag">{group.label}</span>
              </h3>
              <ul class="card-benefit-list">
                {group.items.map((b) => {
                  const airline = isPopulated(b.airline) ? b.airline : null;
                  const lounge = isPopulated(b.lounge) ? b.lounge : null;
                  const programs = getBenefitPrograms(b);

                  const fmtWan = (n: number) => n >= 10000000 ? `NT$ ${(n / 10000000).toLocaleString()} ${lang === 'zh' ? '萬' : 'M'}` : `NT$ ${n.toLocaleString()}`;
                  const insFields = b.benefitType === 'insurance' ? [
                    b.insuranceTravel ? { l: t.insuranceTravel, v: fmtWan(b.insuranceTravel) } : null,
                    b.insuranceOverseas ? { l: t.insuranceOverseas, v: fmtWan(b.insuranceOverseas) } : null,
                    b.insuranceFlightDelay ? { l: t.insuranceFlightDelay, v: `NT$ ${b.insuranceFlightDelay.toLocaleString()}` } : null,
                    b.insuranceBaggageLost ? { l: t.insuranceBaggageLost, v: `NT$ ${b.insuranceBaggageLost.toLocaleString()}` } : null,
                    b.insuranceTripCancel ? { l: t.insuranceTripCancel, v: `NT$ ${b.insuranceTripCancel.toLocaleString()}` } : null,
                  ].filter(Boolean) as { l: string; v: string }[] : [];

                  return (
                    <li class="card-benefit-item">
                      <span class="card-benefit-item__title">{b.title}</span>
                      {b.description && (
                        <span class="card-benefit-item__desc">{b.description}</span>
                      )}
                      {b.conditions && (
                        <span class="card-benefit-item__cond">{t.conditions}{lang === 'zh' ? '：' : ': '}{b.conditions}</span>
                      )}
                      {b.guestPolicy && (
                        <span class="card-benefit-item__cond">{t.guestPolicy}{lang === 'zh' ? '：' : ': '}{b.guestPolicy}</span>
                      )}

                      {insFields.length > 0 && (
                        <dl class="card-benefit-item__insurance">
                          {insFields.map((f) => (
                            <Fragment>
                              <dt>{f.l}</dt>
                              <dd>{f.v}</dd>
                            </Fragment>
                          ))}
                        </dl>
                      )}

                      {(airline || lounge || programs.length > 0) && (
                        <div class="card-benefit-item__links">
                          {airline && (
                            <span class="travel-tag">
                              {airline.name} ({(airline as CmsAirline).iataCode})
                            </span>
                          )}
                          {lounge && (
                            <a class="travel-tag travel-tag--clickable travel-tag--network" href={loungeSlugPath(lang, lounge.slug)}>
                              {lounge.name}
                            </a>
                          )}
                          {programs.map((p) => (
                            <a class="travel-tag travel-tag--clickable travel-tag--alliance" href={programSlugPath(lang, p.slug)}>
                              {p.name}
                            </a>
                          ))}
                        </div>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </section>
      )}

      {hasRelated && (
        <section class="travel-related">
          <h2 class="travel-benefits__title">{lang === 'zh' ? '相關連結' : 'Related'}</h2>
          {relatedAirlines.length > 0 && (
            <div class="travel-related__group">
              <span class="travel-related__label">{lang === 'zh' ? '航空公司' : 'Airlines'}</span>
              <div class="travel-related__items">
                {relatedAirlines.map((a) => (
                  <span class="travel-tag">
                    {a.name}{a.iataCode ? ` (${a.iataCode})` : ''}
                  </span>
                ))}
              </div>
            </div>
          )}
          {relatedLounges.length > 0 && (
            <div class="travel-related__group">
              <span class="travel-related__label">{lang === 'zh' ? '機場貴賓室' : 'Lounges'}</span>
              <div class="travel-related__items">
                {relatedLounges.map((l) => (
                  <a class="travel-tag travel-tag--clickable travel-tag--network" href={loungeSlugPath(lang, l.slug)}>
                    {l.name}
                  </a>
                ))}
              </div>
            </div>
          )}
          {relatedPrograms.length > 0 && (
            <div class="travel-related__group">
              <span class="travel-related__label">{lang === 'zh' ? '旅遊計畫' : 'Programs'}</span>
              <div class="travel-related__items">
                {relatedPrograms.map((p) => (
                  <a class="travel-tag travel-tag--clickable travel-tag--alliance" href={programSlugPath(lang, p.slug)}>
                    {p.name}
                  </a>
                ))}
              </div>
            </div>
          )}
        </section>
      )}
    </article>
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>

  <!-- 比較 Modal（與首頁共用元件；在本頁直接開啟，不再跳回首頁）-->
  <CompareModal lang={lang} cards={allCards} />

  <script is:inline define:vars={{ cardSlug: card.slug, lang }}>
    // 「加入比較」按鈕：透過事件與 CompareModal 元件溝通（選取狀態由元件統一管理）
    (function () {
      var isZh = lang === 'zh';
      var btn = document.getElementById('detail-compare-btn');
      var label = document.getElementById('detail-compare-label');
      if (!btn) return;

      function setState(inSet) {
        btn.classList.toggle('is-selected', inSet);
        var svg = btn.querySelector('svg');
        if (svg) svg.innerHTML = inSet
          ? '<polyline points="20 6 9 17 4 12"/>'
          : '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>';
        if (label) label.textContent = inSet
          ? (isZh ? '已加入比較' : 'In compare')
          : (isZh ? '加入比較' : 'Add to compare');
      }

      btn.addEventListener('click', function () {
        window.dispatchEvent(new CustomEvent('compare:toggle', { detail: { slug: cardSlug } }));
      });

      // CompareModal 初始化與每次變更都會發出 compare:changed → 同步本卡按鈕狀態
      window.addEventListener('compare:changed', function (e) {
        var slugs = (e.detail && e.detail.slugs) || [];
        setState(slugs.indexOf(cardSlug) !== -1);
      });
    })();
  </script>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    import { initCardTilt } from '../../scripts/card-tilt';
    initPortfolioCursor();
    initCardTilt();
  </script>
  <TravelBottomNav lang={lang} current="cards" />
</BaseLayout>
