---
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import { spacePath } from '../../i18n/routes';
import { getCollection } from 'astro:content';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import PageTransition from '../PageTransition.astro';
import PortfolioChrome from '../PortfolioChrome.astro';
import SiteNav from '../SiteNav.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import { SPACE_IDS, type SpaceId } from '../../data/spaces';
import { getLocalizedSpace } from '../../i18n/space-locale';
interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const labels = ui(lang);

const allWorks = await getCollection('works');
const totalWorks = allWorks.length;
const creators = SPACE_IDS.map((id: SpaceId, i) => {
  const def = getLocalizedSpace(id, lang);
  return {
    name: def.platformName,
    tagline: def.tagline,
    href: spacePath(lang, id),
    workCount: allWorks.filter((w) => w.data.space === id).length,
    idx: i,
  };
});

const P = labels.platform;

const dockSections = [
  { id: 'platform-intro', label: P.dockIntro },
  { id: 'creators', label: P.dockSpaces },
];
---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{labels.metaTitlePlatform}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('portfolio-theme');
          document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --mono: 'Space Mono', monospace;
        --sans: 'Space Grotesk', sans-serif;
        --accent2: #8fa8e8;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        cursor: none;
        min-height: 100vh;
      }

      #cursor {
        width: 8px; height: 8px;
        background: var(--accent);
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        transition: width 0.2s, height 0.2s;
      }
      #cursor-ring {
        width: 32px; height: 32px;
        border: 1px solid var(--cursor-ring);
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9998;
        transform: translate(-50%, -50%);
        transition: transform 0.12s ease-out, width 0.25s, height 0.25s, border-color 0.2s;
      }
      body:has(a:hover) #cursor { width: 12px; height: 12px; }
      body:has(a:hover) #cursor-ring {
        width: 48px; height: 48px;
        border-color: var(--cursor-ring-hover);
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 1;
        opacity: 0.55;
        animation: gridBreathe 5s ease-in-out infinite;
      }

      @keyframes gridBreathe {
        0%, 100% { opacity: 0.48; }
        50% { opacity: 0.82; }
      }

      html[data-theme='light'] body::before {
        opacity: 0.32;
      }
      html[data-theme='light'] body.portfolio-atmo::before {
        animation: gridBreatheLight 5s ease-in-out infinite;
      }
      @keyframes gridBreatheLight {
        0%, 100% { opacity: 0.28; }
        50% { opacity: 0.45; }
      }

      main {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        padding: 120px 32px 80px;
        max-width: 1120px;
        margin: 0 auto;
      }

      .platform-section {
        scroll-margin-top: 112px;
        scroll-margin-bottom: 5rem;
      }

      /* 確保首屏只會看到封面內容：
         main 具有 padding-top（桌機/手機都約 120px），因此用同等尺度扣掉，避免創作者列表露出。 */
      #platform-intro.platform-hero {
        /* 不做垂直置中，避免某些視窗高度下內容被推到視窗外。 */
        min-height: calc(100svh - 120px);
        position: relative;
        display: flex;
        align-items: stretch;
        padding:
          clamp(1.75rem, 4.5vw, 3rem)
          0
          calc(4.5rem + env(safe-area-inset-bottom, 0px));
      }

      /* 首屏：內容直接疊在全站網格／背景上，無卡片底色或邊框 */
      .hero.hero--platform {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        grid-template-rows: auto auto 1fr auto;
        gap: clamp(1.1rem, 2.8vw, 2rem);
        min-height: 100%;
        align-content: start;
        padding: 0;
        border: none;
        background: none;
        box-shadow: none;
        border-radius: 0;
      }

      .hero.hero--platform .hero-tag {
        width: fit-content;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.22em;
        color: color-mix(in srgb, var(--accent) 85%, var(--text));
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--line2));
        background: color-mix(in srgb, var(--bg) 65%, transparent);
        backdrop-filter: blur(6px);
      }
      .hero.hero--platform .hero-tag::before {
        content: '';
        display: block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 50%, transparent);
      }

      .hero.hero--platform .hero-title {
        font-family: var(--mono);
        font-size: clamp(54px, 11vw, 138px);
        font-weight: 700;
        line-height: 0.92;
        letter-spacing: -0.03em;
        color: var(--text);
        margin: 0;
        text-wrap: balance;
      }

      .hero.hero--platform .hero-line {
        display: block;
      }

      .hero.hero--platform .hero-line--fill[data-scramble-text] {
        position: relative;
        z-index: 1;
        text-shadow:
          0 0 26px color-mix(in srgb, var(--accent) 32%, transparent),
          0 0 72px color-mix(in srgb, var(--accent) 15%, transparent);
      }

      .hero.hero--platform .hero-bottom {
        display: grid;
        align-content: start;
        gap: 1.1rem;
        max-width: 40rem;
      }

      .hero.hero--platform .hero-desc {
        font-size: clamp(15px, 1.7vw, 18px);
        color: var(--muted);
        line-height: 1.85;
        max-width: 38rem;
        letter-spacing: 0.02em;
        margin: 0;
      }

      .hero.hero--platform .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.72rem;
      }

      .hero.hero--platform .hero-cta a {
        text-decoration: none;
      }

      .hero.hero--platform .hero-cta-primary,
      .hero.hero--platform .hero-cta-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.65rem;
        padding: 0.58rem 1rem;
        border-radius: 999px;
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        transition: transform 0.25s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }

      .hero.hero--platform .hero-cta-primary {
        color: var(--bg);
        background: linear-gradient(100deg, color-mix(in srgb, var(--accent) 88%, #ffffff 12%), color-mix(in srgb, var(--accent2) 78%, #ffffff 22%));
        box-shadow: 0 14px 28px -18px color-mix(in srgb, var(--accent) 75%, transparent);
      }

      .hero.hero--platform .hero-cta-secondary {
        color: var(--text);
        border: 1px solid color-mix(in srgb, var(--line2) 70%, var(--accent) 30%);
        background: color-mix(in srgb, var(--bg) 72%, transparent);
      }

      .hero.hero--platform .hero-cta-primary:hover,
      .hero.hero--platform .hero-cta-secondary:hover {
        transform: translateY(-2px);
      }

      .hero.hero--platform .hero-cta-primary:hover {
        box-shadow: 0 18px 34px -20px color-mix(in srgb, var(--accent) 82%, transparent);
      }

      .hero.hero--platform .hero-cta-secondary:hover {
        border-color: color-mix(in srgb, var(--accent) 58%, var(--line2));
      }

      .hero.hero--platform .hero-foot {
        margin-top: auto;
        display: flex;
        width: 100%;
        align-items: center;
        justify-content: flex-start;
        gap: 1.1rem;
        padding-top: clamp(1rem, 2.3vw, 1.4rem);
      }
      .hero.hero--platform .hero-foot-meta {
        display: inline-flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.4rem 0.7rem;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--muted-dim) 62%, var(--accent) 38%);
      }
      .hero.hero--platform .hero-foot-sep {
        opacity: 0.4;
      }
      .hero.hero--platform .hero-foot-scroll {
        font-family: var(--mono);
        font-size: 12px;
        letter-spacing: 0.16em;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 2.5rem;
        padding: 0.56rem 1rem;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--line2) 70%, var(--accent) 30%);
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        transition: transform 0.22s ease, border-color 0.22s ease, color 0.22s ease;
      }
      .hero.hero--platform .hero-foot-scroll::after {
        content: '';
        width: 9px;
        height: 9px;
        border-right: 1px solid currentColor;
        border-bottom: 1px solid currentColor;
        transform: rotate(45deg) translateY(-1px);
      }
      .hero.hero--platform .hero-foot-scroll:hover {
        color: var(--accent);
        border-color: color-mix(in srgb, var(--accent) 62%, var(--line2));
        transform: translateY(-1px);
      }
      .hero.hero--platform .hero-foot-fx {
        flex: 1;
        min-width: 0;
        margin-left: auto;
      }
      .hero.hero--platform .hero-foot-fx__viewport {
        overflow: hidden;
        mask-image: linear-gradient(90deg, transparent, #000 14%, #000 86%, transparent);
      }
      .hero.hero--platform .hero-foot-fx__track {
        display: inline-flex;
        align-items: center;
        gap: 1.15rem;
        white-space: nowrap;
        animation: hero-foot-marquee 16s linear infinite;
      }
      .hero.hero--platform .hero-foot-fx__item {
        font-family: var(--mono);
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--muted-dim) 55%, var(--accent) 45%);
      }
      .hero.hero--platform .hero-foot-fx__item::after {
        content: '•';
        margin-left: 1.15rem;
        opacity: 0.45;
      }
      @keyframes hero-foot-marquee {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
      }

      .platform-hero__frame {
        position: relative;
        padding: clamp(1.75rem, 4.5vw, 3rem) clamp(1.35rem, 3.5vw, 2.65rem);
        border-radius: 20px;
        border: 1px solid color-mix(in srgb, var(--line2) 88%, var(--accent) 12%);
        background: linear-gradient(
          155deg,
          color-mix(in srgb, var(--bg2) 72%, transparent) 0%,
          color-mix(in srgb, var(--bg) 48%, transparent) 48%,
          color-mix(in srgb, var(--bg3) 22%, transparent) 100%
        );
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--accent) 6%, transparent),
          0 28px 56px -28px var(--shadow-card),
          inset 0 1px 0 color-mix(in srgb, #ffffff 5%, transparent);
        overflow: hidden;
      }

      html[data-theme='light'] .platform-hero__frame {
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--accent) 8%, transparent),
          0 22px 48px -26px var(--shadow-card),
          inset 0 1px 0 color-mix(in srgb, #ffffff 65%, transparent);
      }

      .platform-hero__frame::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(
          120% 80% at 12% -10%,
          color-mix(in srgb, var(--accent) 14%, transparent),
          transparent 55%
        );
        pointer-events: none;
        z-index: 0;
      }

      .platform-hero__corner {
        position: absolute;
        width: 28px;
        height: 28px;
        pointer-events: none;
        z-index: 1;
        border-color: color-mix(in srgb, var(--accent) 45%, var(--line2));
        opacity: 0.85;
      }

      .platform-hero__corner--tl {
        top: 14px;
        left: 14px;
        border-top: 2px solid;
        border-left: 2px solid;
        border-radius: 4px 0 0 0;
      }

      .platform-hero__corner--br {
        right: 14px;
        bottom: 14px;
        border-bottom: 2px solid;
        border-right: 2px solid;
        border-radius: 0 0 4px 0;
      }

      .platform-hero__inner {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-rows: auto auto auto;
        gap: clamp(0.9rem, 2.2vw, 1.5rem);
        align-content: start;
      }

      .platform-hero__meta {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: clamp(1rem, 2.5vw, 1.35rem);
        font-family: var(--mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--muted-dim) 55%, var(--accent) 45%);
      }

      .platform-hero__meta-idx {
        color: var(--accent);
        letter-spacing: 0.18em;
      }

      .platform-hero__meta-sep {
        opacity: 0.45;
        letter-spacing: 0;
      }
      .platform-section + .platform-section {
        /* 只保留「首屏不露出列表」所需的最小緩衝，避免中段過大空白 */
        margin-top: clamp(1.6rem, 8vh, 3.2rem);
      }

      /* 封面主標：放大 + 純色填字（scramble 由腳本處理），避免透明填充問題 */
      #platform-title {
        position: relative;
        font-family: var(--mono);
        font-size: clamp(52px, 12.5vw, 108px);
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.035em;
        margin: 0 0 clamp(1rem, 2.5vw, 1.35rem);
        padding-bottom: 0.42em;
        color: var(--text);
        max-width: 100%;
      }
      #platform-title::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: min(14rem, 52%);
        height: 3px;
        border-radius: 3px;
        background: linear-gradient(
          90deg,
          color-mix(in srgb, var(--accent) 70%, transparent),
          transparent
        );
        opacity: 0.9;
        transform-origin: left center;
        animation: platform-hero-title-line 3.2s ease-in-out infinite;
      }
      .platform-hero-title__text {
        display: inline-block;
        color: var(--text);
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
        animation: platform-hero-title-glow 4s ease-in-out infinite;
      }
      @keyframes platform-hero-title-glow {
        0%,
        100% {
          text-shadow:
            0 0 20px color-mix(in srgb, var(--accent) 28%, transparent),
            0 0 55px color-mix(in srgb, var(--accent) 12%, transparent);
        }
        50% {
          text-shadow:
            0 0 32px color-mix(in srgb, var(--accent) 45%, transparent),
            0 0 85px color-mix(in srgb, var(--accent) 22%, transparent),
            0 0 120px color-mix(in srgb, #ffffff 12%, transparent);
        }
      }
      @keyframes platform-hero-title-line {
        0%,
        100% {
          transform: scaleX(0.35);
          opacity: 0.55;
        }
        50% {
          transform: scaleX(1);
          opacity: 1;
        }
      }
      .hero-kicker {
        font-family: var(--mono);
        font-size: clamp(10px, 2.2vw, 12px);
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        margin: 0 0 clamp(0.85rem, 2vw, 1.1rem);
        max-width: 28rem;
        color: color-mix(in srgb, var(--muted-dim) 38%, var(--accent) 62%);
        text-shadow: 0 0 14px color-mix(in srgb, var(--accent) 35%, transparent);
        animation: platform-hero-kicker 5s ease-in-out infinite;
      }
      .hero-kicker {
        display: flex;
        align-items: center;
        gap: 0.7rem;
      }
      .hero-kicker::before {
        content: '';
        width: 10px;
        height: 10px;
        border-radius: 2px;
        border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--line2));
        transform: rotate(45deg);
        box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 32%, transparent);
        flex-shrink: 0;
      }
      @keyframes platform-hero-kicker {
        0%,
        100% {
          opacity: 0.92;
          letter-spacing: 0.2em;
        }
        50% {
          opacity: 1;
          letter-spacing: 0.24em;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .platform-hero-title__text,
        .hero-kicker,
        #platform-title::after {
          animation: none !important;
        }
        .hero.hero--platform .hero-foot-fx__track {
          animation: none !important;
        }
        #platform-title::after {
          transform: scaleX(1);
          opacity: 0.75;
        }
      }

      @media (max-width: 768px) {
        .hero.hero--platform .hero-cta {
          gap: 0.55rem;
        }
        .hero.hero--platform .hero-foot {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.7rem;
        }
        .hero.hero--platform .hero-foot-fx {
          margin-left: 0;
        }
        .hero.hero--platform .hero-foot-fx {
          width: 100%;
        }

        .hero.hero--platform .hero-cta-primary,
        .hero.hero--platform .hero-cta-secondary {
          width: 100%;
        }

        .platform-hero__frame {
          padding: 1.35rem 1.1rem 1.5rem;
          border-radius: 16px;
        }
        .platform-hero__corner {
          width: 22px;
          height: 22px;
        }
        .platform-hero__corner--tl {
          top: 10px;
          left: 10px;
        }
        .platform-hero__corner--br {
          right: 10px;
          bottom: 10px;
        }
      }
      .hero-desc {
        font-size: 17px;
        color: var(--muted);
        line-height: 1.82;
        max-width: 36rem;
        margin: 0;
        letter-spacing: 0.02em;
        position: relative;
        padding-left: 18px;
      }
      .hero-desc::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.1em;
        bottom: 0.1em;
        width: 2px;
        border-radius: 2px;
        background: linear-gradient(
          to bottom,
          color-mix(in srgb, var(--accent) 55%, transparent),
          transparent
        );
        opacity: 0.85;
      }
      .platform-hero-spotlight {
        margin-bottom: 28px;
        max-width: 36rem;
        /* 移除副標的底色/框框：把 SpotlightCard 變成透明排版容器 */
        padding: 0 !important;
        border: none !important;
        border-radius: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
        overflow: visible;
      }
      .platform-hero-spotlight::before {
        /* 關掉 SpotlightCard 的動態亮斑背景 */
        opacity: 0 !important;
      }

      [data-onscroll-reveal] {
        opacity: 0;
        will-change: opacity, transform;
      }

      .section-label {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        color: color-mix(in srgb, var(--muted) 78%, var(--text));
        text-transform: uppercase;
        margin-bottom: 28px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--line2);
      }

      .creator-rows {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .creator-row {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 36px 40px;
        border: 1px solid var(--line);
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        transition: border-color 0.35s ease, box-shadow 0.45s ease;
      }
      .creator-row:hover {
        border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 12%, transparent), 0 12px 40px var(--shadow-card);
      }
      .creator-row__fill {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 22%, transparent) 0%, color-mix(in srgb, var(--accent) 10%, transparent) 55%, transparent 100%);
        clip-path: inset(0 100% 0 0);
        transition: clip-path 0.55s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 0;
        pointer-events: none;
      }
      .creator-row:hover .creator-row__fill {
        clip-path: inset(0 0 0 0);
      }
      .creator-row__left {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: baseline;
        gap: 28px;
        flex-wrap: wrap;
      }
      .creator-row__idx {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        color: var(--muted-dim);
      }
      .creator-row__name {
        font-family: var(--mono);
        font-size: clamp(20px, 4vw, 28px);
        font-weight: 700;
        letter-spacing: 0.14em;
        color: var(--text);
      }
      .creator-row__right {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        text-align: right;
      }
      .creator-row__tagline {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.62;
        max-width: 22rem;
      }
      .creator-row__cta {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.22em;
        color: var(--accent);
        text-transform: uppercase;
      }
      .creator-row:hover .creator-row__cta {
        color: var(--bg);
      }
      .creator-row:hover .creator-row__name {
        color: var(--bg);
      }
      .creator-row:hover .creator-row__idx {
        color: color-mix(in srgb, var(--bg) 55%, var(--text));
      }
      .creator-row:hover .creator-row__tagline {
        color: color-mix(in srgb, var(--bg) 65%, var(--text));
      }

      footer {
        position: relative;
        z-index: 2;
        padding: 40px 48px;
        border-top: 1px solid var(--line);
      }
      .footer-copy {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        color: var(--muted-dim);
        opacity: 0.75;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px 14px;
      }
      .footer-copy a {
        color: var(--accent);
        text-decoration: none;
        opacity: 0.9;
        transition: opacity 0.2s;
      }
      .footer-copy a:hover {
        opacity: 1;
        text-decoration: underline;
        text-underline-offset: 4px;
      }
      .footer-copy__sep {
        opacity: 0.45;
        user-select: none;
      }

      @media (max-width: 768px) {
        main { padding: 110px 16px 64px; }
        .platform-section {
          scroll-margin-top: 100px;
        }
        #platform-intro.platform-hero {
          min-height: calc(100svh - 110px);
          padding-bottom: calc(3.8rem + env(safe-area-inset-bottom, 0px));
        }
        footer { padding: 32px 24px; }
        .platform-section + .platform-section {
          margin-top: clamp(1.3rem, 6.5vh, 2.4rem);
        }
        .creator-row {
          flex-direction: column;
          align-items: flex-start;
          padding: 28px 22px;
        }
        .creator-row__right { align-items: flex-start; text-align: left; }
      }

      /* 淺色主題：創作空間列預設字色加強（idx／tagline 原本偏淡） */
      html[data-theme='light'] .creator-row__idx {
        color: color-mix(in srgb, var(--muted-dim) 45%, var(--text));
      }
      html[data-theme='light'] .creator-row__tagline {
        color: color-mix(in srgb, var(--text) 42%, var(--muted));
      }
      html[data-theme='light'] .creator-row {
        border-color: color-mix(in srgb, var(--line) 70%, var(--text) 30%);
        background: color-mix(in srgb, var(--bg) 96%, var(--text) 4%);
      }
      html[data-theme='light'] .section-label {
        color: color-mix(in srgb, var(--muted) 48%, var(--text));
        border-bottom-color: color-mix(in srgb, var(--line2) 75%, var(--text) 25%);
      }
    </style>
  </head>
  <body class="portfolio-atmo">
    <AmbientBackdrop />
    <PageTransition />

    <div id="cursor"></div>
    <div id="cursor-ring"></div>

    <SiteNav
      variant="platform"
      lang={lang}
      pathname={Astro.url.pathname}
    />

    <PortfolioChrome
      lang={lang}
      pathname={Astro.url.pathname}
      dockSections={dockSections}
      dockSectionLinkMode="scroll"
    />

    <main id="main-content" tabindex="-1">
      <section id="platform-intro" class="platform-section platform-hero" aria-label={P.dockIntro}>
        <div class="hero hero--platform">
          <div class="hero-tag">{P.heroTag}</div>
          <h1 class="hero-title" aria-label={P.heroTitle}>
            <span class="hero-line hero-line--fill" data-scramble-text={P.heroTitle}>
              {P.heroTitle}
            </span>
          </h1>
          <div class="hero-bottom">
            <p class="hero-desc">{P.heroDesc}</p>
            <div class="hero-cta">
              <a class="hero-cta-primary" href="#creators">{P.sectionCreators}</a>
              <a class="hero-cta-secondary" href="/lab">{labels.nav.lab}</a>
            </div>
          </div>
          <div class="hero-foot" aria-label="cover details">
            <div class="hero-foot-meta">
              <span>{String(creators.length).padStart(2, '0')} {P.sectionCreators}</span>
              <span class="hero-foot-sep" aria-hidden="true">·</span>
              <span>{String(totalWorks).padStart(2, '0')} {P.worksUnit}</span>
            </div>
            <a class="hero-foot-scroll" href="#creators-content">{P.enter}</a>
            <div class="hero-foot-fx" aria-label="animated cover details">
              <div class="hero-foot-fx__viewport">
                <div class="hero-foot-fx__track">
                  {creators.map((c) => <span class="hero-foot-fx__item">{c.name}</span>)}
                  <span class="hero-foot-fx__item">Milifix Archive</span>
                  {creators.map((c) => <span class="hero-foot-fx__item">{c.name}</span>)}
                  <span class="hero-foot-fx__item">Milifix Archive</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="creators" class="platform-section platform-section--spaces" aria-label={P.dockSpaces}>
        <p class="section-label" data-anime-splittext="chars-inview">{P.sectionCreators}</p>
        <div id="creators-content" class="creator-rows">
          {creators.map((c) => (
            <a class="creator-row" href={c.href}>
              <span class="creator-row__fill" aria-hidden="true"></span>
              <div class="creator-row__left">
                <span class="creator-row__idx">
                  /{String(c.idx + 1).padStart(2, '0')} · {String(c.workCount).padStart(2, '0')}{' '}
                  {P.worksUnit}
                </span>
                <span class="creator-row__name" data-anime-splittext="chars-inview">{c.name}</span>
              </div>
              <div class="creator-row__right">
                <span class="creator-row__tagline">{c.tagline}</span>
                <span class="creator-row__cta">{P.enter}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p class="footer-copy">
        <span>{P.footer}</span>
        <span class="footer-copy__sep" aria-hidden="true">·</span>
        <a href="/lab">{labels.nav.lab}</a>
      </p>
    </footer>

    <script>
      import { initAnimeOnScrollReveals } from '../../scripts/init-anime-onscroll-reveals';
      import { initAnimeSplitText } from '../../scripts/init-anime-splittext';
      import { initPlatformHeroScramble } from '../../scripts/platform-hero-scramble';
      import { initPortfolioCursor } from '../../scripts/portfolio-cursor';

      initPortfolioCursor();
      initPlatformHeroScramble();
      initAnimeSplitText();
      initAnimeOnScrollReveals();
    </script>
  </body>
</html>
