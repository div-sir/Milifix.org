---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageTransition from '../PageTransition.astro';
import DaySection from '../trips/DaySection.astro';
import type { DayLabels } from '../trips/DaySection.astro';
import type { Lang } from '../../i18n/types';
import { reportsPath, homePath } from '../../i18n/routes';
import { ui } from '../../i18n/ui';
import type { TripReport, TripStop, TransportSegment } from '../../data/trips/types';
import '@fontsource-variable/fraunces';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import '../../styles/trip-report.css';
import '../../styles/dock-nav.css';
import '../../styles/trip-report-immersive.css';

interface Props {
  lang: Lang;
  trip: TripReport;
}

const { lang, trip } = Astro.props;
const N = ui(lang).nav;

const KIND_LABELS_ZH: DayLabels['kindLabels'] = {
  airport: '機場',
  station: '車站',
  sight: '名勝',
  shrine: '神社',
  castle: '城郭',
  garden: '庭園',
  viewpoint: '展望',
  facility: '設施',
  area: '地區',
};

// 沿用 DaySection 的交通方式圖示對照，讓 HUD 上的移動方式與詳細行程資料一致。
const MODE_ICON: Record<TransportSegment['mode'], string> = {
  flight: '✈️',
  shinkansen: '🚄',
  'night-train': '🌙',
  train: '🚃',
  tram: '🚋',
  monorail: '🚝',
  ferry: '⛴️',
  bus: '🚌',
  walk: '🚶',
};

const labels: DayLabels = {
  dayWord: 'Day',
  timeline: '時間節點',
  activities: '行程',
  costs: '費用紀錄',
  tips: '容易忽略的',
  links: '實用連結',
  photos: '影像',
  passBadge: 'PASS',
  stopsHeading: '沿途景點',
  dossier: '行程手記',
  kindLabels: KIND_LABELS_ZH,
};

const reportsIndexPath = reportsPath();
const metaTitle = `${trip.title}${trip.subtitle ? ` — ${trip.subtitle}` : ''} — Milifix`;

// ── 沈浸式錨點：由完整行程資料生成，鏡頭捲到哪就飛到哪 ──────
interface ImmersiveAnchor {
  lng: number;
  lat: number;
  zoom: number;
  pitch: number;
  bearing: number;
  pos: 'bottom-left' | 'bottom-right' | 'top-left' | 'top-right';
  tag: string;
  title: string;
  desc: string;
  note?: string;
  photoSrc?: string;
  photoAlt?: string;
  day?: number;
  dayIntro?: boolean;
  transportIcon?: string;
  transportLabel?: string;
}

const POS_CYCLE = ['bottom-left', 'bottom-right', 'top-left', 'top-right'] as const;
let posIdx = 0;
const nextPos = (): ImmersiveAnchor['pos'] => POS_CYCLE[posIdx++ % POS_CYCLE.length];

const zoomForKind = (kind?: TripStop['kind']): number => {
  switch (kind) {
    case 'airport':
    case 'area':
      return 11;
    case 'station':
    case 'facility':
      return 12;
    case 'sight':
    case 'shrine':
    case 'castle':
    case 'garden':
    case 'viewpoint':
      return 13;
    default:
      return 12;
  }
};

const anchors: ImmersiveAnchor[] = [];

// 刊頭：行程總覽
anchors.push({
  lng: trip.mapDefault.center.lng,
  lat: trip.mapDefault.center.lat,
  zoom: trip.mapDefault.zoom,
  pitch: 0,
  bearing: 0,
  pos: 'bottom-left',
  tag: `${trip.country} · ${trip.year} · JR PASS ${trip.durationDays}D`,
  title: trip.title,
  desc: trip.summary,
});

// 核心票券
trip.essentials.forEach((e, i) => {
  anchors.push({
    lng: trip.mapDefault.center.lng,
    lat: trip.mapDefault.center.lat,
    zoom: trip.mapDefault.zoom + 0.15 * (i + 1),
    pitch: 8,
    bearing: i % 2 === 0 ? 8 : -8,
    pos: nextPos(),
    tag: '核心票券',
    title: e.title,
    desc: e.desc ?? '',
  });
});

// 逐日：日概覽 + 各停靠點
for (const day of trip.days) {
  const dayNum = String(day.day).padStart(2, '0');
  const avgLng = day.stops.reduce((s, p) => s + p.coords.lng, 0) / (day.stops.length || 1);
  const avgLat = day.stops.reduce((s, p) => s + p.coords.lat, 0) / (day.stops.length || 1);
  const dayDesc = day.activities.slice(0, 2).join('；');
  const tipNote = day.tips && day.tips.length > 0 ? day.tips[0] : undefined;

  anchors.push({
    lng: day.camera?.center?.lng ?? avgLng,
    lat: day.camera?.center?.lat ?? avgLat,
    zoom: day.camera?.zoom ?? 10.3,
    pitch: day.camera?.pitch ?? 12,
    bearing: day.camera?.bearing ?? (day.day % 2 === 0 ? 10 : -10),
    pos: nextPos(),
    tag: `DAY ${dayNum}${day.regionLabel ? ' · ' + day.regionLabel : ''}`,
    title: day.title,
    desc: dayDesc,
    note: tipNote,
    day: day.day,
    dayIntro: true,
  });

  day.stops.forEach((stop, i) => {
    const photo = stop.photos?.[0];
    // 抵達本站的交通段（同日相鄰景點或跨日銜接皆算在 day.segments 內），
    // 供 HUD 顯示「怎麼到這裡」。
    const arrivingSeg = (day.segments ?? []).find((sg) => sg.to === stop.id);
    anchors.push({
      lng: stop.coords.lng,
      lat: stop.coords.lat,
      zoom: zoomForKind(stop.kind),
      // 停靠點鏡頭刻意用較淺的傾角：高 pitch + 粗色路線在透視下會朝地平線
      // 方向被拉伸成長條「尖刺」，貼近單一景點時改以淺傾角只強調 marker。
      pitch: 24,
      bearing: (day.day % 2 === 0 ? -1 : 1) * 16,
      pos: nextPos(),
      tag: `DAY ${dayNum} · STOP ${String(i + 1).padStart(2, '0')}`,
      title: stop.name,
      desc: stop.desc ?? '',
      note: stop.note,
      photoSrc: photo?.src,
      photoAlt: photo?.alt ?? photo?.caption,
      day: day.day,
      transportIcon: arrivingSeg ? MODE_ICON[arrivingSeg.mode] : undefined,
      transportLabel: arrivingSeg?.label,
    });
  });
}

// ── 地圖資料（完整路線／全部停靠點，供沈浸式階段與偵測頁一起使用）──
const stopById = new Map<string, TripStop>();
for (const d of trip.days) for (const s of d.stops) if (!stopById.has(s.id)) stopById.set(s.id, s);
const allStops = [...stopById.values()];

let totalCost = 0;
for (const d of trip.days) for (const c of d.costs ?? []) if (typeof c.amountJpy === 'number') totalCost += c.amountJpy;

const stats = [
  { value: trip.durationDays, unit: '', label: '天數' },
  { value: allStops.length, unit: '', label: '停靠點' },
  { value: totalCost, unit: '¥', label: '已列額外費用', prefix: true },
];

const mapData = {
  mapDefault: trip.mapDefault,
  allStops: allStops.map((s) => ({ id: s.id, name: s.name, coords: s.coords, kind: s.kind })),
  days: trip.days.map((d) => ({
    day: d.day,
    title: d.title,
    stopIds: d.stops.map((s) => s.id),
    segments: (d.segments ?? []).map((s) => ({
      mode: s.mode,
      from: s.from,
      to: s.to,
      viaCoords: s.viaCoords ?? [],
    })),
  })),
  anchors,
};
---

<BaseLayout
  lang={lang}
  title={metaTitle}
  description={trip.summary}
  canonicalPath={Astro.url.pathname}
  hreflangAlternates={false}
  htmlDataTheme="dark"
>
  <PageTransition />

  <!-- ── 地圖載入進度（工業風）：地圖 ready 前顯示，完成後淡出＋場景進場 ── -->
  <div id="immersive-loader" class="immersive-loader" role="status" aria-live="polite">
    <div class="immersive-loader__corner immersive-loader__corner--tl" aria-hidden="true"></div>
    <div class="immersive-loader__corner immersive-loader__corner--tr" aria-hidden="true"></div>
    <div class="immersive-loader__corner immersive-loader__corner--bl" aria-hidden="true"></div>
    <div class="immersive-loader__corner immersive-loader__corner--br" aria-hidden="true"></div>
    <div class="immersive-loader__body">
      <p class="immersive-loader__label">INITIALIZING MAP</p>
      <div class="immersive-loader__bar">
        <div class="immersive-loader__bar-fill" id="immersive-loader-fill"></div>
        <div class="immersive-loader__bar-ticks" aria-hidden="true"></div>
      </div>
      <p class="immersive-loader__pct"><span id="immersive-loader-pct">0</span>%</p>
    </div>
  </div>

  <main
    id="main-content"
    class="immersive-main"
    tabindex="-1"
    data-lightbox-close="關閉"
    data-lightbox-prev="上一張"
    data-lightbox-next="下一張"
  >
    <h1 class="sr-only">{trip.title}</h1>
    <a class="immersive-back" href={reportsIndexPath}>← 返回報告書列表</a>

    <!-- ── 沈浸式階段：全螢幕地圖 + 浮動 HUD，捲動即飛鏡頭 ── -->
    <div class="immersive-stage">
      <div class="immersive-map-col">
        <div id="immersive-map" class="immersive-map"></div>

        <!-- 景深裝飾：經緯格線（背景層，填補畫面空白處）＋ 暗角漸層（強化立體縱深） -->
        <div class="immersive-grid immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-scanline" aria-hidden="true"></div>
        <div class="immersive-grain" aria-hidden="true"></div>
        <div class="immersive-vignette" aria-hidden="true"></div>

        <!-- HUD 裝飾框：外框、四角括號、頂部刻度、中央十字準星
             （分兩層視差深度：深層框線位移小＋隨游標做細微 3D 傾斜，中層刻度／準星／
             座標位移較大，搭配 HUD 文字的前景位移，營造真正的層次懸浮感） -->
        <div class="immersive-frame immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-corner immersive-corner--tl immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-corner immersive-corner--tr immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-corner immersive-corner--bl immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-corner immersive-corner--br immersive-parallax-deep" aria-hidden="true"></div>
        <div class="immersive-ticks immersive-parallax-mid" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="immersive-side-ticks immersive-side-ticks--left immersive-parallax-mid" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="immersive-side-ticks immersive-side-ticks--right immersive-parallax-mid" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="immersive-reticle immersive-parallax-mid" aria-hidden="true">
          <span class="immersive-reticle__h"></span>
          <span class="immersive-reticle__v"></span>
          <span class="immersive-reticle__ring"></span>
        </div>
        <!-- 經緯度讀數（左下）＋ 相機讀數（右下，對稱填補原本空白的右下角） -->
        <p class="immersive-coords immersive-parallax-mid" id="immersive-coords" aria-hidden="true"></p>
        <p class="immersive-cam immersive-parallax-mid" id="immersive-cam" aria-hidden="true"></p>
        <div class="immersive-scroll-hint immersive-parallax-mid" aria-hidden="true">SCROLL ↓</div>

        <!-- 僅顯示可驗證的狀態，不製造虛構速度或高度等遙測資料。 -->
        <div class="immersive-mission" aria-hidden="true">
          <span class="immersive-mission__pulse"></span>
          <span>ROUTE VERIFIED</span>
          <span class="immersive-mission__sep"></span>
          <span>JST · UTC+09</span>
          <span class="immersive-mission__sep"></span>
          <span>{trip.review?.reviewedAt.replaceAll('-', '.')}</span>
        </div>
        <div class="immersive-compass immersive-parallax-mid" aria-hidden="true">
          <span class="immersive-compass__north">N</span>
          <span class="immersive-compass__needle" id="immersive-compass-needle"></span>
          <span class="immersive-compass__bearing" id="immersive-compass-bearing">000°</span>
        </div>
        <div class="immersive-progress" aria-hidden="true">
          <div class="immersive-progress__copy">
            <span>ROUTE PROGRESS</span>
            <span id="immersive-progress-count">01 / {String(anchors.length).padStart(2, '0')}</span>
          </div>
          <div class="immersive-progress__rail"><span id="immersive-progress-fill"></span></div>
          <div class="immersive-progress__context">
            <span id="immersive-progress-day">OVERVIEW</span>
            <span id="immersive-progress-status">MAP SYNCHRONIZED</span>
          </div>
        </div>

        <!-- 當日行程刻度尺：僅列出目前所在日的停靠點，資訊隨游標相對位置浮動 -->
        <div class="immersive-day-ruler" id="immersive-day-ruler" aria-hidden="true">
          <p class="immersive-day-ruler__label" id="immersive-day-ruler-daylabel"></p>
          <div class="immersive-day-ruler__track" id="immersive-day-ruler-track"></div>
          <div class="immersive-day-ruler__cursor" id="immersive-day-ruler-cursor" hidden>
            <span class="immersive-day-ruler__cursor-name" id="immersive-day-ruler-cursor-name"></span>
          </div>
        </div>

        <!-- 分散式 HUD：標題、描述、交通與提醒各自佔用地圖留白區，不再擠成單一卡片。 -->
        <div id="immersive-hud" class="immersive-hud">
          <div id="immersive-hud-photo" class="immersive-hud__photo immersive-hud-fragment" hidden>
            <img id="immersive-hud-img" alt="" />
            <span id="immersive-hud-placeholder" class="immersive-hud__placeholder" aria-hidden="true">📷</span>
          </div>
          <div id="immersive-hud-title-cluster" class="immersive-hud__title-cluster immersive-hud-fragment">
            <div class="immersive-hud__eyebrow">
              <span aria-hidden="true"></span>
              <span id="immersive-hud-tag"></span>
            </div>
            <div id="immersive-hud-title" class="immersive-hud__title"></div>
          </div>
          <div id="immersive-hud-transport" class="immersive-hud__transport immersive-hud-fragment" hidden>
            <span id="immersive-hud-transport-icon" aria-hidden="true"></span>
            <span id="immersive-hud-transport-label"></span>
          </div>
          <div id="immersive-hud-desc" class="immersive-hud__desc immersive-hud-fragment"></div>
          <div id="immersive-hud-note" class="immersive-hud__note immersive-hud-fragment" hidden></div>
        </div>
      </div>

      <div class="immersive-track" id="immersive-track">
        {
          anchors.map((a, index) => (
            <div
              class="immersive-anchor"
              data-lng={a.lng}
              data-lat={a.lat}
              data-zoom={a.zoom}
              data-pitch={a.pitch}
              data-bearing={a.bearing}
              data-pos={a.pos}
              data-tag={a.tag}
              data-title={a.title}
              data-desc={a.desc}
              data-note={a.note ?? ''}
              data-photo={a.photoSrc ?? ''}
              data-photo-alt={a.photoAlt ?? ''}
              data-day={a.day ?? ''}
              data-day-intro={a.dayIntro ? '1' : ''}
              data-transport-icon={a.transportIcon ?? ''}
              data-transport-label={a.transportLabel ?? ''}
              data-index={index + 1}
            />
          ))
        }
      </div>
    </div>

    <!-- ── Day 導覽（跳到對應日的段落）── -->
    {
      trip.days.length > 1 && (
        <nav class="trip-daynav" aria-label="每日行程導覽">
          {trip.days.map((day) => (
            <button
              type="button"
              class="immersive-daynav__dot trip-daynav__dot"
              data-day={day.day}
              data-label={`Day ${day.day}`}
              aria-label={`Day ${day.day} · ${day.title}`}
            />
          ))}
        </nav>
      )
    }

    <!-- ── 詳細行程資料：延續沈浸式的深色主題，逐日完整內容 ── -->
    <section class="immersive-detail">
      <p class="immersive-detail__label">詳細行程資料</p>
      {
        trip.review && (
          <aside class="trip-review" aria-labelledby="trip-review-title">
            <div class="trip-review__head">
              <span class="trip-review__signal" aria-hidden="true"></span>
              <div>
                <p class="trip-review__kicker">CONTENT REVIEW · {trip.review.reviewedAt}</p>
                <h2 id="trip-review-title">{trip.review.status}</h2>
              </div>
            </div>
            <ul>
              {trip.review.notes.map((note) => <li>{note}</li>)}
            </ul>
          </aside>
        )
      }
      <div class="trip-stats immersive-detail__stats">
        {
          stats.map((s) => (
            <div class="trip-stats__item">
              <span class="trip-stats__value">
                {s.prefix && <span class="trip-stats__unit">{s.unit}</span>}
                <span data-count-to={s.value}>0</span>
              </span>
              <span class="trip-stats__label">{s.label}</span>
            </div>
          ))
        }
      </div>

      {
        trip.essentials.length > 0 && (
          <div class="trip-essentials-wrap">
            <h2 class="trip-section-label">核心票券與工具</h2>
            <div class="trip-essentials__grid">
              {trip.essentials.map((e) => (
                <article class="trip-essential">
                  <h3 class="trip-essential__title">{e.title}</h3>
                  {e.desc && <p class="trip-essential__desc">{e.desc}</p>}
                  {e.links && e.links.length > 0 && (
                    <div class="trip-essential__links">
                      {e.links.map((link) =>
                        link.url ? (
                          <a class="trip-link" href={link.url} target="_blank" rel="noopener noreferrer">
                            {link.label}
                            <span class="trip-link__ext" aria-hidden="true">
                              ↗
                            </span>
                          </a>
                        ) : (
                          <span class="trip-link trip-link--text">{link.label}</span>
                        )
                      )}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        )
      }

      <div class="trip-days">
        {trip.days.map((day) => <DaySection day={day} labels={labels} />)}
      </div>
    </section>
  </main>

  <footer class="trip-footer">{trip.title} · Milifix</footer>

  <!-- ── 底部氣泡導覽：回首頁／語言切換／深淺色切換（取代頂部導覽列） ── -->
  <nav class="dock-pill-nav dock-nav immersive-dock" aria-label={N.dockAria}>
    <div class="dock-pill-nav__shell">
      <ul class="dock-pill-nav__row">
        <li class="dock-pill-nav__cell">
          <a
            class="dock-pill-nav__pill dock-pill-nav__pill--home"
            href={homePath(lang)}
            aria-label={N.dockHome}
            title={N.dockHome}
          >
            <span class="dock-pill-nav__home-icon" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M3 10.5L12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-6H8v6H4a1 1 0 0 1-1-1v-9.5z"
                  stroke="currentColor"
                  stroke-width="1.65"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
        </li>

        <li class="dock-pill-nav__sep-cell" aria-hidden="true"><span class="dock-pill-nav__vsep" /></li>

        <li class="dock-pill-nav__cell">
          <button
            type="button"
            class="dock-pill-nav__pill dock-pill-nav__pill--icon"
            id="immersive-theme-toggle"
            aria-label={N.themeToLight}
            title={N.themeToLight}
            data-label-dark={N.themeToDark}
            data-label-light={N.themeToLight}
          >
            <span class="immersive-theme-swap" aria-hidden="true">
              <span class="immersive-theme-icon immersive-theme-icon--sun">
                <svg width="17" height="17" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.2" />
                  <path
                    d="M8 1.2v1.5M8 13.3v1.5M14.8 8h-1.5M2.7 8H1.2M12.5 3.5l-1.06 1.06M4.56 11.44l-1.06 1.06M12.5 12.5l-1.06-1.06M4.56 4.56L3.5 3.5"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"
                  />
                </svg>
              </span>
              <span class="immersive-theme-icon immersive-theme-icon--moon">
                <svg width="17" height="17" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path
                    d="M13.2 9.1A4.2 4.2 0 0 1 6.9 2.8 5 5 0 1 0 13.2 9.1z"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </span>
          </button>
        </li>

        <li class="dock-pill-nav__sep-cell" aria-hidden="true"><span class="dock-pill-nav__vsep" /></li>

        <li class="dock-pill-nav__cell">
          <button
            type="button"
            class="dock-pill-nav__pill dock-pill-nav__pill--top"
            id="immersive-scroll-top"
            aria-label={N.dockScrollTop}
            title={N.dockScrollTop}
          >
            <span class="dock-pill-nav__home-icon" aria-hidden="true">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M7 14.5L12 9l5 5.5"
                  stroke="currentColor"
                  stroke-width="1.65"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </button>
        </li>
      </ul>
    </div>
  </nav>

  <script is:inline type="application/json" id="immersive-map-data" set:html={JSON.stringify(mapData)}></script>

  <script>
    import { initAnimeOnScrollReveals } from '../../scripts/init-anime-onscroll-reveals';
    import { initTripReportImmersiveClient } from '../../scripts/trip-report-immersive-client';
    import { initTripPhotoLightbox } from '../../scripts/trip-photo-lightbox';
    import { toggleTheme } from '../../scripts/theme-init';

    initAnimeOnScrollReveals();
    initTripReportImmersiveClient();
    initTripPhotoLightbox();

    // 底部氣泡導覽的深淺色切換：此頁預設鎖定深色（htmlDataTheme="dark"），
    // 但仍提供切換開關讓使用者可自行改回淺色。
    const themeBtn = document.getElementById('immersive-theme-toggle');
    const labelDark = themeBtn?.getAttribute('data-label-dark') || '';
    const labelLight = themeBtn?.getAttribute('data-label-light') || '';
    const syncThemeButton = (): void => {
      const isLight = document.documentElement.dataset.theme === 'light';
      themeBtn?.setAttribute('aria-label', isLight ? labelDark : labelLight);
      themeBtn?.setAttribute('title', isLight ? labelDark : labelLight);
    };
    syncThemeButton();
    themeBtn?.addEventListener('click', (e) => {
      toggleTheme(e);
      syncThemeButton();
    });

    // 底部氣泡導覽的回頂部：整篇報告書（沈浸式階段 + 詳細行程資料）很長，
    // 提供快速回到刊頭的方式。
    document.getElementById('immersive-scroll-top')?.addEventListener('click', () => {
      const instant = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: instant ? 'auto' : 'smooth' });
      document.getElementById('main-content')?.focus({ preventScroll: true });
    });
  </script>
</BaseLayout>
