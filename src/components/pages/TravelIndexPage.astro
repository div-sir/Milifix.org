---
import {
  getCreditCards,
  getAirlines,
  getLounges,
  getPrograms,
} from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import RealisticCreditCard from '../travel/RealisticCreditCard.astro';
import LoungeCard from '../travel/LoungeCard.astro';
import AirlineDome from '../travel/AirlineDome.jsx';
import TravelBottomNav from '../travel/TravelBottomNav.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';
import { travelPath, programSlugPath } from '../../i18n/routes';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui(lang).travel;

const [cards, lounges, airlines, allPrograms] = await Promise.all([
  getCreditCards(),
  getLounges(),
  getAirlines(),
  getPrograms(),
]);

// ── Stats ──
const bankCount = new Set(cards.map((c) => c.bank)).size;
const stats = [
  { value: String(cards.length), label: lang === 'zh' ? '張信用卡' : 'Cards' },
  { value: String(bankCount), label: lang === 'zh' ? '家銀行' : 'Banks' },
  { value: String(airlines.length), label: lang === 'zh' ? '家航空' : 'Airlines' },
  { value: String(lounges.length), label: lang === 'zh' ? '間貴賓室' : 'Lounges' },
];

// ── Card filters data ──
const banks = [...new Set(cards.map((c) => c.bank))].sort();
const allBenefitTypes = Object.keys(t.benefitTypes).filter((bt) => bt !== 'other');
const maxFee = cards.length ? Math.max(...cards.map((c) => c.annualFee)) : 0;
const FEE_CAP = Math.ceil(maxFee / 10000) * 10000 || 30000;
// 對數分界：每階約 2.5~3x，貼合卡片年費分布。滑桿以 index 步進＝天然吸附
const FEE_LADDER = [0, 5000, 10000, 20000];
const FEE_BUCKETS = FEE_LADDER.filter((b) => b < FEE_CAP);
FEE_BUCKETS.push(FEE_CAP);
const FEE_LAST = FEE_BUCKETS.length - 1;

// 各權益類型對應的卡片數（用於 tag 顯示數量 / 灰掉無資料者）
const benefitCounts: Record<string, number> = {};
const bankCounts: Record<string, number> = {};
for (const c of cards) {
  for (const bt of new Set(c.benefits.map((b) => b.benefitType))) {
    benefitCounts[bt] = (benefitCounts[bt] ?? 0) + 1;
  }
  bankCounts[c.bank] = (bankCounts[c.bank] ?? 0) + 1;
}

// ── 各航空對應的卡片（給航空彈窗用）──
const cardPath = (slug: string) => `/${lang === 'en' ? '' : lang + '/'}travel/cards/${slug}`;
const airlineCards: Record<string, { name: string; bank: string; href: string }[]> = {};
for (const c of cards) {
  const slugs = new Set<string>();
  for (const b of c.benefits) {
    const al = b.airline;
    if (al && typeof al === 'object' && 'slug' in al) slugs.add(al.slug);
  }
  for (const s of slugs) {
    (airlineCards[s] ??= []).push({ name: c.name, bank: c.bank, href: cardPath(c.slug) });
  }
}
const airlinePath = (slug: string) => `/${lang === 'en' ? '' : lang + '/'}travel/airlines/${slug}`;
const airlinesData = airlines.map((a) => ({
  slug: a.slug,
  name: a.name,
  iataCode: a.iataCode,
  alliance: t.allianceNames[a.alliance] ?? a.alliance,
  isAlliance: a.alliance !== 'none',
  description: a.description ?? '',
  logo: a.logo?.url ?? `https://pics.avs.io/240/240/${a.iataCode}.png`,
  href: airlinePath(a.slug),
  cards: airlineCards[a.slug] ?? [],
}));

// ── Programs grouped by type ──
const programTypes = ['lounge-network', 'hotel-program', 'airline-alliance'] as const;
const programsByType = Object.fromEntries(
  programTypes.map((type) => [type, allPrograms.filter((p) => p.programType === type)])
);

---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{t.metaTitle} — Milifix</title>
  <meta name="description" content={t.heroDesc} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <!-- ── Hero ── -->
    <header class="travel-hero travel-hero--index">
      <span class="travel-hero__tag">{t.heroTag}</span>
      <h1 class="travel-hero__title">{t.heroTitle}</h1>
      <p class="travel-hero__desc">{t.heroDesc}</p>
      <div class="travel-stats">
        {stats.map((s) => (
          <div class="travel-stats__item">
            <span class="travel-stats__value">{s.value}</span>
            <span class="travel-stats__label">{s.label}</span>
          </div>
        ))}
      </div>
      <nav class="travel-hero__jump" aria-label={lang === 'zh' ? '區塊快速跳轉' : 'Jump to section'}>
        <button type="button" class="travel-hero__jump-btn" data-tab="cards">{t.sectionCards}</button>
        <button type="button" class="travel-hero__jump-btn" data-tab="airlines">{t.sectionAirlines}</button>
        <button type="button" class="travel-hero__jump-btn" data-tab="lounges">{t.sectionLounges}</button>
        <button type="button" class="travel-hero__jump-btn" data-tab="programs">{t.programs}</button>
      </nav>
    </header>

    <!-- ── 信用卡 ── -->
    {cards.length > 0 && (
      <section class="travel-section" id="cards">
        <div class="travel-section__header">
          <h2 class="travel-section__title">{t.sectionCards}</h2>
        </div>
        <div class="card-toolbar">
          <div class="card-toolbar__search">
            <svg class="card-toolbar__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input
              type="search"
              id="card-search"
              class="card-toolbar__search-input"
              placeholder={lang === 'zh' ? '搜尋卡名或銀行…' : 'Search card or bank…'}
              autocomplete="off"
              aria-label={lang === 'zh' ? '搜尋信用卡' : 'Search credit cards'}
            />
          </div>
          <div class="card-toolbar__sort">
            <label class="card-toolbar__sort-label" for="card-sort">{lang === 'zh' ? '排序' : 'Sort'}</label>
            <select id="card-sort" class="card-toolbar__sort-select">
              <option value="default">{lang === 'zh' ? '預設' : 'Default'}</option>
              <option value="fee-asc">{lang === 'zh' ? '年費 低→高' : 'Fee low→high'}</option>
              <option value="fee-desc">{lang === 'zh' ? '年費 高→低' : 'Fee high→low'}</option>
              <option value="name">{lang === 'zh' ? '卡名 A→Z' : 'Name A→Z'}</option>
              <option value="benefits">{lang === 'zh' ? '權益最多' : 'Most benefits'}</option>
            </select>
          </div>
        </div>
        <div class="card-filters" id="card-filters">
          <div class="card-filters__section">
            <span class="card-filters__label">{lang === 'zh' ? '銀行' : 'Bank'}</span>
            <div class="card-filters__group">
              {banks.map((b) => (
                <button type="button" class="card-filters__tag" data-filter="bank" data-value={b} aria-pressed="false">
                  {b}<span class="card-filters__tag-count">{bankCounts[b] ?? 0}</span>
                </button>
              ))}
            </div>
          </div>
          <div class="card-filters__section">
            <span class="card-filters__label">{lang === 'zh' ? '卡片特點' : 'Benefits'}</span>
            <div class="card-filters__group">
              {allBenefitTypes.map((bt) => {
                const n = benefitCounts[bt] ?? 0;
                if (n === 0) return null;
                return (
                  <button
                    type="button"
                    class="card-filters__tag"
                    data-filter="benefit"
                    data-value={bt}
                    aria-pressed="false"
                  >
                    {t.benefitTypes[bt] ?? bt}<span class="card-filters__tag-count">{n}</span>
                  </button>
                );
              })}
            </div>
          </div>
          <div class="card-filters__section card-filters__section--fee">
            <div class="fee-head">
              <span class="card-filters__label">{lang === 'zh' ? '年費區間' : 'Annual fee'}</span>
              <span class="fee-readout">
                <span class="fee-readout__range" id="fee-value">{lang === 'zh' ? '不限' : 'All'}</span>
                <span class="fee-readout__count" id="fee-match"></span>
              </span>
            </div>
            <div class="fee-slider" id="fee-slider">
              <div class="fee-slider__rail"></div>
              <div class="fee-slider__fill" id="fee-track"></div>
              <input
                type="range"
                class="fee-slider__input fee-slider__input--min"
                id="fee-slider-min"
                min="0"
                max={FEE_LAST}
                value="0"
                step="1"
                aria-label={lang === 'zh' ? '年費下限' : 'Minimum annual fee'}
              />
              <input
                type="range"
                class="fee-slider__input fee-slider__input--max"
                id="fee-slider-max"
                min="0"
                max={FEE_LAST}
                value={FEE_LAST}
                step="1"
                aria-label={lang === 'zh' ? '年費上限' : 'Maximum annual fee'}
              />
              <div class="fee-slider__ticks">
                {FEE_BUCKETS.map((v, i) => {
                  const pct = (i / FEE_LAST * 100).toFixed(2);
                  const label = v === 0
                    ? (lang === 'zh' ? '免費' : 'Free')
                    : i === FEE_LAST
                      ? (lang === 'zh' ? '不限' : '∞')
                      : v >= 1000 ? `$${v / 1000}K` : `$${v}`;
                  return (
                    <span class="fee-slider__tick" style={`left:${pct}%`}>
                      <span class="fee-slider__tick-dot"></span>
                      <span class="fee-slider__tick-label">{label}</span>
                    </span>
                  );
                })}
              </div>
            </div>
          </div>
          <div class="card-filters__result">
            <span class="card-filters__count" id="card-result-count">{cards.length}</span>
            <button type="button" class="card-filters__clear" id="card-clear" hidden>
              {lang === 'zh' ? '清除全部' : 'Clear all'}
            </button>
          </div>
        </div>
        <div class="travel-grid travel-grid--wallet" id="card-grid">
          {cards.map((card) => (
            <div
              data-bank={card.bank}
              data-name={`${card.bank} ${card.name}`.toLowerCase()}
              data-benefits={card.benefits.map((b) => b.benefitType).join(',')}
              data-benefit-count={new Set(card.benefits.map((b) => b.benefitType)).size}
              data-fee={card.annualFee}
              data-slug={card.slug}
            >
              <RealisticCreditCard lang={lang} card={card} />
            </div>
          ))}
        </div>
        <div class="travel-empty travel-empty--cards" id="card-empty" hidden>
          <p>{lang === 'zh' ? '找不到符合條件的卡片' : 'No cards match your filters'}</p>
          <button type="button" class="card-filters__clear" id="card-empty-clear">
            {lang === 'zh' ? '清除篩選' : 'Clear filters'}
          </button>
        </div>
      </section>
    )}

    <!-- ── 航空公司 ── -->
    {airlines.length > 0 && (
      <section class="travel-section travel-section--immersive" id="airlines">
        <div class="airline-dome-full">
          <nav class="airline-dome-seo" aria-label={t.sectionAirlines}>
            <ul>
              {airlines.map((a) => (
                <li><a href={airlinePath(a.slug)}>{a.name} ({a.iataCode})</a></li>
              ))}
            </ul>
          </nav>
          <AirlineDome
            client:visible
            airlines={airlines.map((a) => ({
              name: a.name,
              iataCode: a.iataCode,
              slug: a.slug,
              logo: a.logo,
              alliance: a.alliance,
              href: airlinePath(a.slug),
            }))}
            lang={lang}
          />
        </div>
      </section>
    )}

    <!-- ── 貴賓室 ── -->
    {lounges.length > 0 && (
      <section class="travel-section" id="lounges">
        <div class="travel-section__header">
          <h2 class="travel-section__title">{t.sectionLounges}</h2>
        </div>
        <div class="card-toolbar">
          <div class="card-toolbar__search">
            <svg class="card-toolbar__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="search" id="lounge-search" class="card-toolbar__search-input" autocomplete="off"
              placeholder={lang === 'zh' ? '搜尋貴賓室、機場或代碼…' : 'Search lounge, airport or code…'}
              aria-label={lang === 'zh' ? '搜尋貴賓室' : 'Search lounges'} />
          </div>
          <span class="card-filters__count" id="lounge-count">{lounges.length}</span>
        </div>
        {[...new Set(lounges.map((l) => l.airportCode).filter(Boolean))].length > 1 && (
          <div class="card-filters__group" style="margin-bottom: 1rem;">
            {[...new Set(lounges.map((l) => l.airportCode).filter(Boolean))].sort().map((code) => (
              <button type="button" class="card-filters__tag lounge-airport-pill" data-value={code} aria-pressed="false">{code}</button>
            ))}
          </div>
        )}
        <div class="travel-grid" id="lounge-grid">
          {lounges.map((lounge) => (
            <div
              data-search={`${lounge.name} ${lounge.airport} ${lounge.airportCode} ${lounge.terminal ?? ''}`.toLowerCase()}
              data-airport={lounge.airportCode}
            >
              <LoungeCard lang={lang} lounge={lounge} programs={allPrograms} />
            </div>
          ))}
        </div>
        <div class="travel-empty" id="lounge-empty" hidden>{t.noResults}</div>
      </section>
    )}

    <!-- ── 網路／計畫 ── -->
    {allPrograms.length > 0 && (
      <section class="travel-section" id="programs">
        <div class="travel-section__header">
          <h2 class="travel-section__title">{t.programs}</h2>
        </div>
        {programTypes.map((type) => {
          const items = programsByType[type];
          if (!items?.length) return null;
          return (
            <div style="margin-bottom: 0.75rem;">
              <h3 class="travel-section__subtitle">{t.programTypeNames[type]}</h3>
              <div class="travel-grid">
                {items.map((p) => (
                  <a class="travel-card" href={programSlugPath(lang, p.slug)}>
                    {p.logo?.url && (
                      <img class="travel-card__image travel-card__image--logo" src={p.logo.url} alt={p.name} loading="lazy" />
                    )}
                    <span class="travel-card__overline">{t.programTypeNames[p.programType]}</span>
                    <span class="travel-card__title">{p.name}</span>
                    <span class="travel-card__subtitle">{p.summary?.slice(0, 80)}…</span>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </section>
    )}

    <!-- ── 比較 Modal ── -->
    <div class="compare-modal" id="compare-modal" aria-hidden="true">
      <div class="compare-modal__backdrop" id="compare-modal-backdrop"></div>
      <div class="compare-modal__panel">
        <div class="compare-modal__header">
          <h2 class="compare-modal__title">
            {lang === 'zh' ? '卡片比較' : 'Compare Cards'}
            <span class="compare-modal__count" id="compare-count">0</span>
          </h2>
          <div class="compare-modal__actions">
            <button type="button" class="compare-modal__share" id="compare-share" aria-label={lang === 'zh' ? '複製比較連結' : 'Copy compare link'}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
              <span class="compare-modal__share-label">{lang === 'zh' ? '複製連結' : 'Share'}</span>
            </button>
            <button type="button" class="compare-modal__close" id="compare-modal-close" aria-label="Close">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        </div>
        <div class="compare-modal__body" id="compare-scroll">
          <div id="compare-content"></div>
          <div class="compare-empty" id="compare-empty">
            {lang === 'zh' ? '點選卡片上的 ＋ 加入比較（最多 4 張）' : 'Tap + on cards to compare (up to 4)'}
          </div>
        </div>
      </div>
    </div>

    <!-- ── 航空彈窗 ── -->
    <div class="airline-modal" id="airline-modal" aria-hidden="true">
      <div class="airline-modal__backdrop" id="airline-modal-backdrop"></div>
      <div class="airline-modal__panel" role="dialog" aria-modal="true" aria-labelledby="airline-modal-name">
        <button type="button" class="airline-modal__close" id="airline-modal-close" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="airline-modal__head">
          <img class="airline-modal__logo" id="airline-modal-logo" src="" alt="" />
          <div class="airline-modal__title-wrap">
            <span class="airline-modal__iata" id="airline-modal-iata"></span>
            <h2 class="airline-modal__name" id="airline-modal-name"></h2>
            <span class="airline-modal__alliance" id="airline-modal-alliance"></span>
          </div>
        </div>
        <p class="airline-modal__desc" id="airline-modal-desc"></p>
        <div class="airline-modal__cards" id="airline-modal-cards"></div>
        <a class="airline-modal__fullpage" id="airline-modal-link" href="#">
          <span>{lang === 'zh' ? '查看完整資料' : 'View full details'}</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

    <!-- 航空資料注入 -->
    <script is:inline define:vars={{ airlinesJson: JSON.stringify(airlinesData), lang }}>
      window.__airlines = JSON.parse(airlinesJson);
    </script>

    <!-- 卡片資料注入（供 JS 讀取） -->
    <script is:inline define:vars={{ cardsJson: JSON.stringify(cards.map((c) => ({
      slug: c.slug, name: c.name, bank: c.bank, annualFee: c.annualFee,
      annualFeeNote: c.annualFeeNote ?? '', cardNetwork: c.cardNetwork,
      annualFeeWaivable: c.annualFeeWaivable ?? 'unknown',
      supplementaryCardFee: c.supplementaryCardFee ?? null,
      supplementaryCardMax: c.supplementaryCardMax ?? null,
      signUpBonus: c.signUpBonus ?? '',
      renewalBonus: c.renewalBonus ?? '',
      benefits: c.benefits.map((b) => {
        const lo = b.lounge && typeof b.lounge === 'object' && 'slug' in b.lounge ? b.lounge : null;
        const progs = (b.program ?? []).filter((p) => typeof p === 'object' && p !== null && 'slug' in p) as { slug: string; name: string }[];
        return {
          type: b.benefitType, title: b.title, desc: b.description ?? '',
          conditions: b.conditions ?? '',
          guestPolicy: b.guestPolicy ?? '',
          insuranceTravel: b.insuranceTravel ?? null,
          insuranceOverseas: b.insuranceOverseas ?? null,
          insuranceFlightDelay: b.insuranceFlightDelay ?? null,
          insuranceBaggageDelay: b.insuranceBaggageDelay ?? null,
          insuranceBaggageLost: b.insuranceBaggageLost ?? null,
          insuranceTripCancel: b.insuranceTripCancel ?? null,
          lounge: lo ? { slug: lo.slug, name: lo.name } : null,
          programs: progs.map((p) => ({ slug: p.slug, name: p.name })),
        };
      }),
    }))), benefitLabels: JSON.stringify(Object.fromEntries(
      allBenefitTypes.map((bt) => [bt, t.benefitTypes[bt] ?? bt])
    )), compareLabels: JSON.stringify({
      annualFeeWaivable: t.annualFeeWaivable,
      annualFeeNotWaivable: t.annualFeeNotWaivable,
      supplementaryCard: t.supplementaryCard,
      supplementaryCardFree: t.supplementaryCardFree,
      signUpBonus: t.signUpBonus,
      renewalBonus: t.renewalBonus,
      insuranceTravel: t.insuranceTravel,
      insuranceOverseas: t.insuranceOverseas,
      insuranceFlightDelay: t.insuranceFlightDelay,
      insuranceBaggageDelay: t.insuranceBaggageDelay,
      insuranceBaggageLost: t.insuranceBaggageLost,
      insuranceTripCancel: t.insuranceTripCancel,
    }), basePath: travelPath(lang), lang }}>
      window.__compareCards = JSON.parse(cardsJson);
      window.__benefitLabels = JSON.parse(benefitLabels);
      window.__compareLabels = JSON.parse(compareLabels);
      window.__compareLang = lang;
      window.__travelBase = basePath;
    </script>

    {cards.length === 0 && lounges.length === 0 && airlines.length === 0 && (
      <div class="travel-empty"><p>{t.noResults}</p></div>
    )}
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>

  <script is:inline define:vars={{ feeCap: FEE_CAP, feeBuckets: FEE_BUCKETS }}>
    // Tag-based card filters + dual range fee slider + search + sort
    var grid = document.getElementById('card-grid');
    var tags = document.querySelectorAll('.card-filters__tag');
    var active = { bank: new Set(), benefit: new Set() };
    var sliderMin = document.getElementById('fee-slider-min');
    var sliderMax = document.getElementById('fee-slider-max');
    var feeTrack = document.getElementById('fee-track');
    var feeValueEl = document.getElementById('fee-value');
    var feeMatchEl = document.getElementById('fee-match');
    var searchInput = document.getElementById('card-search');
    var sortSelect = document.getElementById('card-sort');
    var clearBtn = document.getElementById('card-clear');
    var emptyClearBtn = document.getElementById('card-empty-clear');
    var resultCountEl = document.getElementById('card-result-count');
    var emptyEl = document.getElementById('card-empty');
    var feeLast = feeBuckets.length - 1;
    var feeMin = feeBuckets[0];
    var feeMax = feeBuckets[feeLast];
    var searchTerm = '';
    var isZh = (window.__compareLang || 'zh') === 'zh';
    var totalCards = grid ? grid.children.length : 0;

    var EXIT_MS = 550;

    function applyFilters() {
      if (!grid) return;
      var visibleIdx = 0;
      var visibleCount = 0;
      for (var i = 0; i < grid.children.length; i++) {
        var item = grid.children[i];
        var matchBank = active.bank.size === 0 || active.bank.has(item.dataset.bank || '');
        var matchBenefit = active.benefit.size === 0 || (item.dataset.benefits || '').split(',').some(function(b) { return active.benefit.has(b); });
        var fee = parseInt(item.dataset.fee || '0', 10);
        var matchFee = fee >= feeMin && (feeMax >= feeCap ? true : fee < feeMax);
        var matchSearch = searchTerm === '' || (item.dataset.name || '').indexOf(searchTerm) !== -1;
        var show = matchBank && matchBenefit && matchFee && matchSearch;
        var isHidden = item.classList.contains('card-hidden');
        var isExiting = item.classList.contains('card-exiting');

        if (show) visibleCount++;

        if (show && (isHidden || isExiting)) {
          item.classList.remove('card-hidden', 'card-exiting');
          item.classList.add('card-entering');
          item.style.setProperty('--stagger', String(visibleIdx));
          visibleIdx++;
          (function(el) {
            el.addEventListener('animationend', function handler() {
              el.classList.remove('card-entering');
              el.removeEventListener('animationend', handler);
            });
          })(item);
        } else if (show) {
          item.style.setProperty('--stagger', String(visibleIdx));
          visibleIdx++;
        } else if (!show && !isHidden && !isExiting) {
          item.classList.add('card-exiting');
          (function(el) {
            setTimeout(function() {
              if (el.classList.contains('card-exiting')) {
                el.classList.remove('card-exiting');
                el.classList.add('card-hidden');
              }
            }, EXIT_MS);
          })(item);
        }
      }

      if (resultCountEl) {
        resultCountEl.textContent = isZh
          ? (visibleCount + ' / ' + totalCards + ' 張')
          : (visibleCount + ' / ' + totalCards + ' cards');
      }
      var anyFilter = active.bank.size > 0 || active.benefit.size > 0 ||
        searchTerm !== '' || feeMin > 0 || feeMax < feeCap;
      if (clearBtn) clearBtn.hidden = !anyFilter;
      if (emptyEl) emptyEl.hidden = visibleCount !== 0;
      if (grid) grid.style.display = visibleCount === 0 ? 'none' : '';
    }

    function applySort() {
      if (!grid || !sortSelect) return;
      var mode = sortSelect.value;
      if (mode === 'default') return;
      var items = Array.prototype.slice.call(grid.children);
      items.sort(function(a, b) {
        if (mode === 'fee-asc') return (+a.dataset.fee || 0) - (+b.dataset.fee || 0);
        if (mode === 'fee-desc') return (+b.dataset.fee || 0) - (+a.dataset.fee || 0);
        if (mode === 'benefits') return (+b.dataset.benefitCount || 0) - (+a.dataset.benefitCount || 0);
        if (mode === 'name') return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        return 0;
      });
      items.forEach(function(el) { grid.appendChild(el); });
    }

    function clearAll() {
      active.bank.clear();
      active.benefit.clear();
      tags.forEach(function(tag) { tag.classList.remove('is-active'); tag.setAttribute('aria-pressed', 'false'); });
      searchTerm = '';
      if (searchInput) searchInput.value = '';
      if (sliderMin) sliderMin.value = '0';
      if (sliderMax) sliderMax.value = String(feeLast);
      refreshFeeUI();
      applyFilters();
    }

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        searchTerm = searchInput.value.trim().toLowerCase();
        applyFilters();
      });
    }
    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        applySort();
        applyFilters();
      });
    }
    if (clearBtn) clearBtn.addEventListener('click', clearAll);
    if (emptyClearBtn) emptyClearBtn.addEventListener('click', clearAll);

    tags.forEach(function(tag) {
      tag.addEventListener('click', function() {
        var filter = tag.dataset.filter;
        var value = tag.dataset.value;
        if (active[filter].has(value)) {
          active[filter].delete(value);
          tag.classList.remove('is-active');
          tag.setAttribute('aria-pressed', 'false');
        } else {
          active[filter].add(value);
          tag.classList.add('is-active');
          tag.setAttribute('aria-pressed', 'true');
        }
        tag.classList.add('is-bouncing');
        setTimeout(function() { tag.classList.remove('is-bouncing'); }, 300);
        applyFilters();
      });
    });

    // 對數區間滑桿：input 的 value 是 bucket index，feeMin/feeMax 為實際年費值
    function feeFmt(v) {
      if (v === 0) return isZh ? '免費' : 'Free';
      return v >= 1000 ? 'NT$' + (v / 1000) + 'K' : 'NT$' + v;
    }

    function feeLabel(loIdx, hiIdx) {
      if (loIdx === 0 && hiIdx === feeLast) return isZh ? '不限' : 'All';
      var loStr = feeFmt(feeBuckets[loIdx]);
      var hiStr = hiIdx === feeLast ? (isZh ? '不限' : '∞') : feeFmt(feeBuckets[hiIdx]);
      return loStr + ' – ' + hiStr;
    }

    function updateTrack() {
      if (!feeTrack) return;
      var loIdx = parseInt(sliderMin.value, 10);
      var hiIdx = parseInt(sliderMax.value, 10);
      if (loIdx > hiIdx) { var t = loIdx; loIdx = hiIdx; hiIdx = t; }
      feeTrack.style.left = (loIdx / feeLast * 100) + '%';
      feeTrack.style.right = (100 - hiIdx / feeLast * 100) + '%';
    }

    function countCardsInFeeRange(lo, hi) {
      if (!grid) return 0;
      var n = 0;
      for (var i = 0; i < grid.children.length; i++) {
        var fee = parseInt(grid.children[i].dataset.fee || '0', 10);
        if (fee >= lo && (hi >= feeCap ? true : fee < hi)) n++;
      }
      return n;
    }

    function readFeeIdx() {
      var loIdx = parseInt(sliderMin.value, 10);
      var hiIdx = parseInt(sliderMax.value, 10);
      if (loIdx > hiIdx) { var t = loIdx; loIdx = hiIdx; hiIdx = t; }
      return [loIdx, hiIdx];
    }

    function refreshFeeUI() {
      var idx = readFeeIdx();
      var loIdx = idx[0], hiIdx = idx[1];
      feeMin = feeBuckets[loIdx];
      feeMax = feeBuckets[hiIdx];
      if (feeValueEl) feeValueEl.textContent = feeLabel(loIdx, hiIdx);
      var inRange = countCardsInFeeRange(feeMin, feeMax);
      if (feeMatchEl) {
        feeMatchEl.textContent = inRange + (isZh ? ' 張' : '');
        feeMatchEl.style.display = (loIdx === 0 && hiIdx === feeLast) ? 'none' : '';
      }
      updateTrack();
    }

    function onSliderInput() { refreshFeeUI(); }

    function onSliderChange() {
      refreshFeeUI();
      applyFilters();
    }

    if (sliderMin && sliderMax) {
      sliderMin.addEventListener('input', onSliderInput);
      sliderMax.addEventListener('input', onSliderInput);
      sliderMin.addEventListener('change', onSliderChange);
      sliderMax.addEventListener('change', onSliderChange);
      refreshFeeUI();
    }

    // 初始化結果數量
    applyFilters();

    // ── 航空 / 貴賓室區塊：搜尋 + (航空)聯盟篩選 ──
    function initSearchGrid(gridId, inputId, countId, emptyId, pillSel, pillAttr) {
      var g = document.getElementById(gridId);
      if (!g) return;
      var input = document.getElementById(inputId);
      var countEl = document.getElementById(countId);
      var emptyEl2 = document.getElementById(emptyId);
      var pills2 = pillSel ? document.querySelectorAll(pillSel) : [];
      var active2 = {};
      var term = '';
      var total = g.children.length;
      function apply() {
        var visible = 0;
        for (var i = 0; i < g.children.length; i++) {
          var item = g.children[i];
          var ms = term === '' || (item.dataset.search || '').indexOf(term) !== -1;
          var keys = Object.keys(active2);
          var mp = keys.length === 0 || active2[item.dataset[pillAttr] || ''];
          var show = ms && !!mp;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (countEl) countEl.textContent = visible + ' / ' + total + (isZh ? ' 筆' : '');
        if (emptyEl2) emptyEl2.hidden = visible !== 0;
        g.style.display = visible === 0 ? 'none' : '';
      }
      if (input) input.addEventListener('input', function() { term = input.value.trim().toLowerCase(); apply(); });
      pills2.forEach(function(p) {
        p.addEventListener('click', function() {
          var v = p.dataset.value;
          if (active2[v]) { delete active2[v]; p.classList.remove('is-active'); p.setAttribute('aria-pressed', 'false'); }
          else { active2[v] = true; p.classList.add('is-active'); p.setAttribute('aria-pressed', 'true'); }
          apply();
        });
      });
      apply();
    }

    // airline search removed — airlines now use DomeGallery full-page
    initSearchGrid('lounge-grid', 'lounge-search', 'lounge-count', 'lounge-empty', '.lounge-airport-pill', 'airport');
  </script>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    import { initCardTilt } from '../../scripts/card-tilt';
    initPortfolioCursor();
    initCardTilt();

    // ── 頁內分頁：帶動畫的 tab 切換 ──
    const TAB_IDS = ['cards', 'airlines', 'lounges', 'programs'];
    const sections = TAB_IDS.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    const pills = document.querySelectorAll<HTMLElement>('.dock-nav__section');
    const jumpBtns = document.querySelectorAll<HTMLElement>('.travel-hero__jump-btn');
    let currentTab = '';

    const heroEl = document.querySelector<HTMLElement>('.travel-hero--index');
    const IMMERSIVE_TABS = ['airlines'];

    function showTab(id: string, pushHash = true, animate = true) {
      const prevIdx = TAB_IDS.indexOf(currentTab);
      const nextIdx = TAB_IDS.indexOf(id);
      const direction = nextIdx >= prevIdx ? 1 : -1;
      const immersive = IMMERSIVE_TABS.includes(id);

      if (heroEl) heroEl.style.display = immersive ? 'none' : '';
      document.body.classList.toggle('tab-immersive', immersive);

      for (const sec of sections) {
        if (sec.id === id) {
          sec.style.display = '';
          if (animate && currentTab) {
            sec.style.animation = 'none';
            sec.offsetHeight;
            sec.style.animation = `tabIn 0.35s cubic-bezier(0.22,1,0.32,1) both`;
            sec.style.setProperty('--tab-dir', String(direction));
          }
        } else {
          sec.style.display = 'none';
        }
      }
      currentTab = id;
      pills.forEach((pill) => {
        const pillId = pill.getAttribute('data-dock-scroll-id') || pill.getAttribute('href')?.replace('#', '');
        const on = pillId === id;
        pill.classList.toggle('dock-nav__section--active', on);
        if (on) pill.setAttribute('aria-current', 'location');
        else pill.removeAttribute('aria-current');
      });
      jumpBtns.forEach((btn) => {
        btn.classList.toggle('is-active', btn.dataset.tab === id);
      });
      if (pushHash) history.replaceState(null, '', `#${id}`);
      window.scrollTo({ top: 0 });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = pill.getAttribute('data-dock-scroll-id') || pill.getAttribute('href')?.replace('#', '');
        if (id && TAB_IDS.includes(id)) showTab(id);
      });
    });

    jumpBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.tab;
        if (id && TAB_IDS.includes(id)) showTab(id);
      });
    });

    const initHash = window.location.hash.slice(1);
    showTab(TAB_IDS.includes(initHash) ? initHash : 'cards', false, false);

    window.addEventListener('hashchange', () => {
      const h = window.location.hash.slice(1);
      if (TAB_IDS.includes(h)) showTab(h, false);
    });

    // ── 互動比較（Modal） ──
    const MAX_COMPARE = 4;
    const selected = new Set<string>();
    const compareModal = document.getElementById('compare-modal')!;
    const compareBtns = document.querySelectorAll<HTMLButtonElement>('.cc3d__compare-btn');
    const compareContent = document.getElementById('compare-content')!;
    const compareEmpty = document.getElementById('compare-empty')!;
    const compareCount = document.getElementById('compare-count')!;
    type CompBenefit = {
      type: string; title: string; desc: string; conditions: string;
      guestPolicy: string;
      insuranceTravel: number | null; insuranceOverseas: number | null;
      insuranceFlightDelay: number | null; insuranceBaggageDelay: number | null;
      insuranceBaggageLost: number | null; insuranceTripCancel: number | null;
      lounge: { slug: string; name: string } | null;
      programs: { slug: string; name: string }[];
    };
    const allCards: Array<{
      slug: string; name: string; bank: string; annualFee: number;
      annualFeeNote: string; cardNetwork: string;
      annualFeeWaivable: string; supplementaryCardFee: number | null;
      supplementaryCardMax: number | null; signUpBonus: string; renewalBonus: string;
      benefits: CompBenefit[];
    }> = (window as any).__compareCards ?? [];
    const benefitLabels: Record<string, string> = (window as any).__benefitLabels ?? {};
    const cmpL: Record<string, string> = (window as any).__compareLabels ?? {};
    const isZh = (window as any).__compareLang === 'zh';
    const travelBase: string = (window as any).__travelBase ?? '/zh/travel';
    const STORAGE_KEY = 'milifix-compare';

    // slug ↔ index 映射（讓 URL 更短：?compare=2.5.8）
    const slugToIdx: Record<string, number> = {};
    const idxToSlug: Record<number, string> = {};
    allCards.forEach((c, i) => { slugToIdx[c.slug] = i; idxToSlug[i] = c.slug; });

    function persistSelection() {
      const slugs = [...selected];
      const url = new URL(window.location.href);
      if (slugs.length) {
        const indices = slugs.map((s) => slugToIdx[s]).filter((i) => i !== undefined);
        url.searchParams.set('compare', indices.join('.'));
      } else {
        url.searchParams.delete('compare');
      }
      history.replaceState(null, '', url.toString());
      try {
        if (slugs.length) localStorage.setItem(STORAGE_KEY, slugs.join(','));
        else localStorage.removeItem(STORAGE_KEY);
      } catch (e) { /* localStorage 不可用時忽略 */ }
    }

    function restoreSelection(): boolean {
      const url = new URL(window.location.href);
      const param = url.searchParams.get('compare');
      let raw = param ?? '';
      let fromUrl = !!param;
      if (!raw) { try { raw = localStorage.getItem(STORAGE_KEY) ?? ''; } catch (e) { raw = ''; } }
      if (!raw) return false;
      const valid = new Set(allCards.map((c) => c.slug));
      const isIndices = /^[\d.]+$/.test(raw);
      const parts = raw.split(isIndices ? '.' : ',').filter(Boolean);
      parts.forEach((s) => {
        const slug = isIndices ? idxToSlug[parseInt(s, 10)] : s;
        if (slug && selected.size < MAX_COMPARE && valid.has(slug)) selected.add(slug);
      });
      return fromUrl && selected.size > 0;
    }

    // 比較按鈕：插入底部導覽列
    const dockRow = document.querySelector('.dock-pill-nav__row');
    const comparePillLi = document.createElement('li');
    comparePillLi.className = 'dock-pill-nav__cell';
    comparePillLi.setAttribute('role', 'none');
    comparePillLi.id = 'compare-dock-cell';
    comparePillLi.style.display = 'none';
    comparePillLi.innerHTML = `
      <button type="button" class="dock-pill-nav__pill dock-pill-nav__pill--compare" id="compare-dock-btn"
              aria-label="${isZh ? '開啟比較' : 'Open compare'}">
        <span class="dock-pill-nav__home-icon" aria-hidden="true">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        <span class="dock-compare-badge" id="compare-dock-badge">0</span>
      </button>`;

    // 插在 separator 之前（scroll-top 那組的前面）
    const seps = dockRow?.querySelectorAll('.dock-pill-nav__sep-cell');
    const lastSep = seps && seps.length > 0 ? seps[seps.length - 1] : null;
    if (lastSep) {
      dockRow!.insertBefore(comparePillLi, lastSep);
    } else if (dockRow) {
      dockRow.appendChild(comparePillLi);
    }
    const compareDockBtn = document.getElementById('compare-dock-btn');

    function updateBadge() {
      const n = selected.size;
      compareCount.textContent = String(n);
      const badge = document.getElementById('compare-dock-badge');
      if (badge) badge.textContent = String(n);
      comparePillLi.style.display = n > 0 ? '' : 'none';

      compareBtns.forEach((btn) => {
        const slug = btn.dataset.compareSlug!;
        const on = selected.has(slug);
        btn.classList.toggle('is-selected', on);
        btn.setAttribute('aria-label', on
          ? (isZh ? '移除比較' : 'Remove from compare')
          : (isZh ? '加入比較' : 'Add to compare'));
      });
    }

    function renderCompare() {
      persistSelection();
      const picks = allCards.filter((c) => selected.has(c.slug));
      compareEmpty.style.display = picks.length ? 'none' : '';

      if (!picks.length) {
        compareContent.innerHTML = '';
        updateBadge();
        return;
      }

      const cols = picks.length;
      function fmtNT(n: number) { return `NT$ ${n.toLocaleString()}`; }
      function fmtWan(n: number) { return n >= 10000000 ? `NT$ ${(n / 10000000).toLocaleString()} ${isZh ? '萬' : 'M'}` : fmtNT(n); }
      const STRIP_RE = /(?:貴賓室網路|飯店計畫|航空聯盟|機場貴賓室|旅遊保險|機場接送|航空會員|機票折扣|免稅折扣|機場停車)[：:]\s*/g;
      const PURGE_RE = /浦東機場推薦[^。]*[。]?/g;
      function cleanText(text: string): string {
        return text.replace(STRIP_RE, '').replace(PURGE_RE, '').trim();
      }
      function splitSentences(text: string): string[] {
        return text.split(/[。；]\s*/).map((s) => s.trim()).filter(Boolean);
      }
      function tagHtml(name: string, href: string): string {
        return `<a class="cg__tag" href="${href}">${esc(name)}</a>`;
      }
      function esc(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

      // ── Header (sticky) ──
      const headerHtml = `<div class="cg__header" style="--cg-cols:${cols}">
        ${picks.map((c) => `<div class="cg__card">
          <span class="cg__bank">${esc(c.bank)}</span>
          <span class="cg__name">${esc(c.name)}</span>
          <button type="button" class="cg__remove" data-remove-slug="${c.slug}">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            ${isZh ? '移除' : 'Remove'}
          </button>
        </div>`).join('')}
      </div>`;

      // ── Row helper ──
      type Row = { label: string; values: string[]; isList?: boolean };
      const sections: Array<{ title: string; rows: Row[] }> = [];

      function addRow(sec: typeof sections[number], label: string, values: string[], isList = false) {
        if (values.every((v) => v === '—')) return;
        sec.rows.push({ label, values, isList });
      }

      // ── Section: 基本資訊 ──
      const meta: typeof sections[number] = { title: isZh ? '基本資訊' : 'Basic Info', rows: [] };

      addRow(meta, isZh ? '卡片網路' : 'Network', picks.map((c) => c.cardNetwork.toUpperCase()));

      // 年費：金額 + 可否減免
      addRow(meta, isZh ? '年費' : 'Annual Fee', picks.map((c) => {
        const parts: string[] = [];
        parts.push(c.annualFee === 0 ? (isZh ? '免年費' : 'Waived') : fmtNT(c.annualFee));
        if (c.annualFeeWaivable === 'yes') parts.push(cmpL.annualFeeWaivable || '可減免');
        else if (c.annualFeeWaivable === 'no') parts.push(cmpL.annualFeeNotWaivable || '不可減免');
        return parts.join('<br>');
      }));

      // 年費備註：剔除附卡/附屬卡描述（有獨立列）＋ 剔除「不可減免」等（年費列已顯示）
      // (?:^|[，；;]) 確保「附卡」前是句首或分隔符，不會誤刪「正附卡合併消費」
      // [^，；。]* 只用中文標點斷句，不被 NT$1,800 的英文逗號截斷
      const NOTE_STRIP = /(?:^|[，,；;]\s*)(?:附卡|副卡|附屬卡)[^，；。]*(?=[，；。]|$)/g;
      const NOTE_STRIP_FEE = /(?:^|[，,；;]\s*)(?:正卡)?年費不可減免/g;
      addRow(meta, isZh ? '年費備註' : 'Fee Note', picks.map((c) => {
        if (!c.annualFeeNote) return '—';
        let note = c.annualFeeNote
          .replace(NOTE_STRIP, '')
          .replace(NOTE_STRIP_FEE, '')
          .replace(/^[，,；;\s。]+/, '').replace(/[，,；;\s]+$/, '');
        return note || '—';
      }));

      // 附卡：年費 + 最多幾張；從 annualFeeNote 提取附卡/附屬卡 max 數（若 CMS 欄位未填）
      addRow(meta, cmpL.supplementaryCard || '附卡', picks.map((c) => {
        if (c.supplementaryCardFee == null) return '—';
        const feeStr = c.supplementaryCardFee === 0 ? (cmpL.supplementaryCardFree || '免年費') : fmtNT(c.supplementaryCardFee);
        let maxStr = '';
        if (c.supplementaryCardMax != null) {
          maxStr = isZh ? `最多 ${c.supplementaryCardMax} 張` : `Max ${c.supplementaryCardMax}`;
        } else if (c.annualFeeNote) {
          const mx = c.annualFeeNote.match(/(?:附卡|副卡|附屬卡).*?(\d+)\s*張/);
          if (mx) maxStr = isZh ? `最多 ${mx[1]} 張` : `Max ${mx[1]}`;
        }
        return maxStr ? `${feeStr}<br>${maxStr}` : feeStr;
      }));

      if (meta.rows.length) sections.push(meta);

      // ── Section: 優惠 ──
      const promo: typeof sections[number] = { title: isZh ? '優惠' : 'Promos', rows: [] };
      addRow(promo, cmpL.signUpBonus || '首刷禮', picks.map((c) => c.signUpBonus || '—'));
      addRow(promo, cmpL.renewalBonus || '續卡禮', picks.map((c) => c.renewalBonus || '—'));
      if (promo.rows.length) sections.push(promo);

      // ── Sections: benefit types ──
      function benefitTags(b: CompBenefit): string {
        const tags: string[] = [];
        if (b.lounge) tags.push(tagHtml(b.lounge.name, `${travelBase}/lounges/${b.lounge.slug}`));
        for (const p of b.programs) tags.push(tagHtml(p.name, `${travelBase}/programs/${p.slug}`));
        return tags.length ? `<div class="cg__tags">${tags.join('')}</div>` : '';
      }

      function renderBenefitCell(items: CompBenefit[]): string {
        if (!items.length) return '—';
        const lines: string[] = [];
        const allTags: string[] = [];
        for (const b of items) {
          const title = cleanText(b.title);
          const desc = cleanText(b.desc);
          const cond = cleanText(b.conditions);
          // 把 desc 拆成多句
          if (desc && desc !== title) {
            const sentences = splitSentences(desc);
            if (sentences.length > 1) {
              lines.push(...sentences);
            } else {
              lines.push(`${title}：${sentences[0]}`);
            }
          } else {
            lines.push(title);
          }
          if (cond) {
            splitSentences(cond).forEach((s) => { if (!lines.includes(s)) lines.push(s); });
          }
          allTags.push(benefitTags(b));
        }
        const tagsHtml = allTags.filter(Boolean).join('');
        if (lines.length <= 1 && !tagsHtml) return lines[0] || '—';
        let html = `<ul class="cg__list">${lines.map((l) => `<li>${l}</li>`).join('')}</ul>`;
        if (tagsHtml) html += tagsHtml;
        return html;
      }

      const allTypes = [...new Set(picks.flatMap((c) => c.benefits.map((b) => b.type)))];
      for (const type of allTypes) {
        const label = benefitLabels[type] ?? type;
        if (type === 'insurance') {
          const fields = [
            { key: 'insuranceTravel', label: cmpL.insuranceTravel || '旅平險' },
            { key: 'insuranceOverseas', label: cmpL.insuranceOverseas || '海外意外險' },
            { key: 'insuranceFlightDelay', label: cmpL.insuranceFlightDelay || '班機延誤' },
            { key: 'insuranceBaggageLost', label: cmpL.insuranceBaggageLost || '行李遺失' },
            { key: 'insuranceTripCancel', label: cmpL.insuranceTripCancel || '行程取消' },
          ] as const;
          const values = picks.map((c) => {
            const ins = c.benefits.filter((b) => b.type === 'insurance');
            if (!ins.length) return '—';
            const parts: string[] = [];
            for (const f of fields) {
              const val = ins.reduce((mx, b) => Math.max(mx, (b as any)[f.key] ?? 0), 0);
              if (val > 0) parts.push(`${f.label} ${fmtWan(val)}`);
            }
            if (!parts.length) return ins.map((b) => cleanText(b.title)).join('<br>');
            return `<ul class="cg__list">${parts.map((p) => `<li>${p}</li>`).join('')}</ul>`;
          });
          if (!values.every((v) => v === '—')) {
            sections.push({ title: label, rows: [{ label, values, isList: true }] });
          }
          continue;
        }
        const values = picks.map((c) => renderBenefitCell(c.benefits.filter((b) => b.type === type)));
        if (!values.every((v) => v === '—')) {
          sections.push({ title: label, rows: [{ label, values, isList: true }] });
        }
      }

      // ── Build grid HTML ──
      let html = headerHtml;
      for (const sec of sections) {
        const singleRow = sec.rows.length === 1 && sec.rows[0].label === sec.title;
        html += `<div class="cg__section">`;
        html += `<div class="cg__section-title">${sec.title}</div>`;
        if (singleRow) {
          html += `<div class="cg__row cg__row--no-label" style="--cg-cols:${cols}">`;
          html += sec.rows[0].values.map((v) => `<div class="cg__cell">${v}</div>`).join('');
          html += `</div>`;
        } else {
          for (const row of sec.rows) {
            html += `<div class="cg__row" style="--cg-cols:${cols}">`;
            html += `<div class="cg__label">${row.label}</div>`;
            html += row.values.map((v) => `<div class="cg__cell">${v}</div>`).join('');
            html += `</div>`;
          }
        }
        html += `</div>`;
      }

      compareContent.innerHTML = html;

      // Bind remove buttons
      compareContent.querySelectorAll<HTMLButtonElement>('[data-remove-slug]').forEach((btn) => {
        btn.addEventListener('click', () => {
          selected.delete(btn.dataset.removeSlug!);
          renderCompare();
        });
      });

      updateBadge();
    }

    // 卡片上的 "+" 按鈕
    compareBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const slug = btn.dataset.compareSlug!;
        if (selected.has(slug)) {
          selected.delete(slug);
        } else {
          if (selected.size >= MAX_COMPARE) return;
          selected.add(slug);
        }
        renderCompare();
      });
    });

    let lastFocused: HTMLElement | null = null;
    const FOCUSABLE = 'a[href], button:not([disabled]), input, select, [tabindex]:not([tabindex="-1"])';

    function openModal() {
      lastFocused = document.activeElement as HTMLElement;
      compareModal.setAttribute('aria-hidden', 'false');
      compareModal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      renderCompare();
      const first = compareModal.querySelector<HTMLElement>('.compare-modal__close');
      first?.focus();
    }
    function closeModal() {
      compareModal.classList.remove('is-open');
      compareModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocused?.focus();
    }

    compareDockBtn?.addEventListener('click', openModal);
    document.getElementById('compare-modal-backdrop')?.addEventListener('click', closeModal);
    document.getElementById('compare-modal-close')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (!compareModal.classList.contains('is-open')) return;
      if (e.key === 'Escape') { closeModal(); return; }
      if (e.key === 'Tab') {
        const focusables = Array.from(compareModal.querySelectorAll<HTMLElement>(FOCUSABLE))
          .filter((el) => el.offsetParent !== null);
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // 複製分享連結
    const shareBtn = document.getElementById('compare-share');
    shareBtn?.addEventListener('click', async () => {
      persistSelection();
      const link = window.location.href;
      try {
        await navigator.clipboard.writeText(link);
      } catch (e) {
        const ta = document.createElement('textarea');
        ta.value = link;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (e2) { /* noop */ }
        document.body.removeChild(ta);
      }
      shareBtn.classList.add('is-copied');
      const label = shareBtn.querySelector('.compare-modal__share-label');
      const prev = label?.textContent ?? '';
      if (label) label.textContent = isZh ? '已複製!' : 'Copied!';
      setTimeout(() => {
        shareBtn.classList.remove('is-copied');
        if (label) label.textContent = prev;
      }, 1600);
    });

    // ?compare=open → 從卡片詳情頁導回，用 localStorage 還原並開啟
    const urlCheck = new URL(window.location.href);
    const compareParam = urlCheck.searchParams.get('compare');
    const isOpenTrigger = compareParam === 'open';
    if (isOpenTrigger) {
      urlCheck.searchParams.delete('compare');
      history.replaceState(null, '', urlCheck.toString());
    }
    const openedFromUrl = restoreSelection();
    updateBadge();
    if (openedFromUrl || (isOpenTrigger && selected.size > 0)) openModal();

    // ── 航空彈窗 ──
    const airlinesData: Array<{
      slug: string; name: string; iataCode: string; alliance: string;
      isAlliance: boolean; description: string; logo: string; href: string;
      cards: Array<{ name: string; bank: string; href: string }>;
    }> = (window as any).__airlines ?? [];
    const airlineModal = document.getElementById('airline-modal');
    let airlineLastFocused: HTMLElement | null = null;

    function openAirline(slug: string) {
      const a = airlinesData.find((x) => x.slug === slug);
      if (!a || !airlineModal) return;
      airlineLastFocused = document.activeElement as HTMLElement;
      (document.getElementById('airline-modal-logo') as HTMLImageElement).src = a.logo;
      (document.getElementById('airline-modal-logo') as HTMLImageElement).alt = a.name;
      document.getElementById('airline-modal-iata')!.textContent = a.iataCode;
      document.getElementById('airline-modal-name')!.textContent = a.name;
      const allianceEl = document.getElementById('airline-modal-alliance')!;
      allianceEl.textContent = a.alliance;
      allianceEl.style.display = a.isAlliance ? '' : 'none';
      const descEl = document.getElementById('airline-modal-desc')!;
      descEl.textContent = a.description;
      descEl.style.display = a.description ? '' : 'none';
      const cardsEl = document.getElementById('airline-modal-cards')!;
      if (a.cards.length) {
        cardsEl.innerHTML = `<span class="airline-modal__cards-label">${isZh ? '可累積哩程的卡片' : 'Cards earning these miles'}</span>` +
          a.cards.map((c) => `<a class="airline-modal__card" href="${c.href}"><span class="airline-modal__card-bank">${c.bank}</span><span class="airline-modal__card-name">${c.name}</span></a>`).join('');
      } else {
        cardsEl.innerHTML = `<span class="airline-modal__cards-empty">${isZh ? '目前無對應信用卡' : 'No matching cards yet'}</span>`;
      }
      (document.getElementById('airline-modal-link') as HTMLAnchorElement).href = a.href;
      airlineModal.setAttribute('aria-hidden', 'false');
      airlineModal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      document.getElementById('airline-modal-close')?.focus();
    }
    function closeAirline() {
      if (!airlineModal) return;
      airlineModal.classList.remove('is-open');
      airlineModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      airlineLastFocused?.focus();
    }

    window.addEventListener('airline:open', ((e: CustomEvent) => openAirline(e.detail.slug)) as EventListener);
    document.getElementById('airline-modal-backdrop')?.addEventListener('click', closeAirline);
    document.getElementById('airline-modal-close')?.addEventListener('click', closeAirline);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && airlineModal?.classList.contains('is-open')) closeAirline();
    });
  </script>
  <TravelBottomNav lang={lang} />
</body>
</html>
