---
import { getCreditCards } from '../../lib/cms';
import SiteNav from '../SiteNav.astro';
import PageTransition from '../PageTransition.astro';
import AmbientBackdrop from '../AmbientBackdrop.astro';
import TravelSubnav from '../travel/TravelSubnav.astro';
import RealisticCreditCard from '../travel/RealisticCreditCard.astro';
import '../../styles/theme.css';
import '../../styles/portfolio-atmosphere.css';
import '../../styles/travel.css';
import type { Lang } from '../../i18n/types';
import { HTML_LANG } from '../../i18n/types';
import { ui } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui(lang).travel;

const cards = await getCreditCards();
const banks = [...new Set(cards.map((c) => c.bank))].sort();
const benefitTypes = [
  ...new Set(cards.flatMap((c) => c.benefits.map((b) => b.benefitType))),
].sort();
const networks = [...new Set(cards.map((c) => c.cardNetwork))].sort();
---

<!DOCTYPE html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111318" />
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f4f2ea" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <title>{t.cardListTitle} — Milifix</title>
  <meta name="description" content={t.cardListDesc} />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('portfolio-theme');
        document.documentElement.dataset.theme = t === 'light' ? 'light' : t === 'dark' ? 'dark' : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      } catch (e) {
        document.documentElement.dataset.theme = 'dark';
      }
    })();
  </script>
</head>
<body class="portfolio-atmo">
  <AmbientBackdrop />
  <PageTransition />
  <div id="cursor"></div>
  <div id="cursor-ring"></div>

  <SiteNav lang={lang} variant="platform" pathname={Astro.url.pathname} />

  <main id="main-content">
    <header class="travel-hero">
      <span class="travel-hero__tag">{t.sectionCards}</span>
      <h1 class="travel-hero__title">{t.cardListTitle}</h1>
      <p class="travel-hero__desc">{t.cardListDesc}</p>
    </header>

    <TravelSubnav lang={lang} current="cards" />

    <section class="travel-section">
      <div class="travel-filter">
        {banks.length > 1 && (
          <select
            class="travel-filter__select"
            id="bank-filter"
            aria-label={t.filterByBank}
          >
            <option value="">{t.allBanks}</option>
            {banks.map((b) => (
              <option value={b}>{b}</option>
            ))}
          </select>
        )}

        {benefitTypes.length > 1 && (
          <select
            class="travel-filter__select"
            id="benefit-filter"
            aria-label={t.benefits}
          >
            <option value="">{t.benefits}</option>
            {benefitTypes.map((bt) => (
              <option value={bt}>{t.benefitTypes[bt] ?? bt}</option>
            ))}
          </select>
        )}

        {networks.length > 1 && (
          <select
            class="travel-filter__select"
            id="network-filter"
            aria-label="Network"
          >
            <option value="">Network</option>
            {networks.map((n) => (
              <option value={n}>{n.toUpperCase()}</option>
            ))}
          </select>
        )}
      </div>

      {cards.length > 0 ? (
        <div class="travel-grid travel-grid--wallet" id="card-grid">
          {cards.map((card) => (
            <div
              data-bank={card.bank}
              data-network={card.cardNetwork}
              data-benefits={card.benefits.map((b) => b.benefitType).join(',')}
            >
              <RealisticCreditCard lang={lang} card={card} />
            </div>
          ))}
        </div>
      ) : (
        <div class="travel-empty"><p>{t.noResults}</p></div>
      )}
    </section>
  </main>

  <footer class="travel-footer">{ui(lang).platform.footer}</footer>

  <script>
    const bankFilter = document.getElementById('bank-filter') as HTMLSelectElement | null;
    const benefitFilter = document.getElementById('benefit-filter') as HTMLSelectElement | null;
    const networkFilter = document.getElementById('network-filter') as HTMLSelectElement | null;
    const grid = document.getElementById('card-grid');

    function applyFilters() {
      if (!grid) return;
      const bank = bankFilter?.value ?? '';
      const benefit = benefitFilter?.value ?? '';
      const network = networkFilter?.value ?? '';

      for (const el of grid.children) {
        const item = el as HTMLElement;
        const matchBank = !bank || item.dataset.bank === bank;
        const matchBenefit =
          !benefit || (item.dataset.benefits ?? '').split(',').includes(benefit);
        const matchNetwork = !network || item.dataset.network === network;
        item.style.display = matchBank && matchBenefit && matchNetwork ? '' : 'none';
      }
    }

    bankFilter?.addEventListener('change', applyFilters);
    benefitFilter?.addEventListener('change', applyFilters);
    networkFilter?.addEventListener('change', applyFilters);
  </script>
  <script>
    import { initPortfolioCursor } from '../../scripts/portfolio-cursor';
    import { initCardTilt } from '../../scripts/card-tilt';
    initPortfolioCursor();
    initCardTilt();
  </script>
</body>
</html>
